<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Include>[CodingAgentWebUI]*,[CodingAgentWebUI.Pipeline]*,[CodingAgentWebUI.Infrastructure]*</Include>
          <Exclude>[CodingAgentWebUI.*.UnitTests]*,[CodingAgentWebUI.IntegrationTests]*,[CodingAgentWebUI.E2ETests]*</Exclude>
          <IncludeTestAssembly>false</IncludeTestAssembly>
          <SkipAutoProps>true</SkipAutoProps>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
