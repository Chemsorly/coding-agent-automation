<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Include>[CodingAgentWebUI.Agent]*,[CodingAgentWebUI.Agent.KiroCli]*,[CodingAgentWebUI.Agent.OpenCode]*,[CodingAgentWebUI.Pipeline]*,[KiroCliLib]*</Include>
          <IncludeTestAssembly>false</IncludeTestAssembly>
          <SkipAutoProps>true</SkipAutoProps>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
