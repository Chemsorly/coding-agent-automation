@inherits LayoutComponentBase
@implements IAsyncDisposable
@using CodingAgentWebUI.Pipeline.Services
@using CodingAgentWebUI.Services
@using CodingAgentWebUI.Components.Shared
@using Microsoft.JSInterop
@inject PipelineLoopService LoopService
@inject ConsolidationBadgeService BadgeService
@inject NotificationService NotificationService
@inject IJSRuntime JS

<div class="app-layout">
    <nav class="sidebar" role="navigation" aria-label="Main navigation">
        <div class="sidebar-brand">Coding Agent</div>
        <NavLink href="/agent-chat" class="sidebar-link">
            <span class="sidebar-icon"><Icon Name="message-circle" /></span>
            <span>Agent Chat</span>
        </NavLink>
        <NavLink href="/agent-coding" class="sidebar-link">
            <span class="sidebar-icon"><Icon Name="bot" /></span>
            <span>Agent Coding</span>
            @if (LoopService.IsLoopActive)
            {
                <span class="sidebar-loop-indicator" title="Pipeline loop is active">🔄</span>
            }
        </NavLink>
        <NavLink href="/agent-monitoring" class="sidebar-link">
            <span class="sidebar-icon"><Icon Name="bar-chart-2" /></span>
            <span>Agent Monitoring</span>
        </NavLink>
        <NavLink href="/consolidation" class="sidebar-link">
            <span class="sidebar-icon"><Icon Name="refresh-cw" /></span>
            <span>Consolidation</span>
            @if (BadgeService.BadgeCount > 0)
            {
                <span class="sidebar-badge">@BadgeService.BadgeCount</span>
            }
        </NavLink>
        <NavLink href="/settings" class="sidebar-link">
            <span class="sidebar-icon"><Icon Name="settings" /></span>
            <span>Settings</span>
        </NavLink>
        <NavLink href="/about" class="sidebar-link">
            <span class="sidebar-icon"><Icon Name="info" /></span>
            <span>About</span>
        </NavLink>
        <button class="sidebar-link sidebar-notification-btn" @onclick="ToggleNotificationPanel">
            <span class="sidebar-icon">🔔</span>
            <span>Notifications</span>
            @if (NotificationService.UnreadCount > 0)
            {
                <span class="sidebar-badge">@NotificationService.UnreadCount</span>
            }
        </button>
    </nav>
    <main class="main-content">
        <CascadingValue Value="this" IsFixed="true">
            @Body
        </CascadingValue>
    </main>
    <NotificationPanel IsOpen="_notificationPanelOpen" OnClose="CloseNotificationPanel" />
</div>

<ShortcutHelpOverlay IsVisible="_showShortcutHelp" OnClose="() => { _showShortcutHelp = false; StateHasChanged(); }" />

@code {
    private DotNetObjectReference<MainLayout>? _dotNetRef;
    private bool _showShortcutHelp;
    private bool _notificationPanelOpen;

    /// <summary>Event fired when Escape is pressed globally via the keyboard shortcut handler.</summary>
    public event Action? OnEscapePressed;

    protected override void OnInitialized()
    {
        LoopService.OnChange += HandleLoopChanged;
        BadgeService.OnBadgeChanged += HandleBadgeChanged;
        NotificationService.OnChange += HandleNotificationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerGlobalKeyboardHandler", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task HandleGlobalKey(string key)
    {
        switch (key)
        {
            case "Escape":
                if (_showShortcutHelp)
                    _showShortcutHelp = false;
                else
                    OnEscapePressed?.Invoke();
                break;
            case "?":
                _showShortcutHelp = !_showShortcutHelp;
                break;
        }
        try { await InvokeAsync(StateHasChanged); }
        catch (ObjectDisposedException) { }
    }

    private async void HandleLoopChanged()
    {
        try { await InvokeAsync(StateHasChanged); }
        catch (ObjectDisposedException) { }
    }

    private async void HandleBadgeChanged()
    {
        try { await InvokeAsync(StateHasChanged); }
        catch (ObjectDisposedException) { }
    }

    private async void HandleNotificationChanged()
    {
        try { await InvokeAsync(StateHasChanged); }
        catch (ObjectDisposedException) { }
    }

    private void ToggleNotificationPanel()
    {
        _notificationPanelOpen = !_notificationPanelOpen;
        if (_notificationPanelOpen)
            NotificationService.MarkAllRead();
    }

    private void CloseNotificationPanel()
    {
        _notificationPanelOpen = false;
    }

    public async ValueTask DisposeAsync()
    {
        LoopService.OnChange -= HandleLoopChanged;
        BadgeService.OnBadgeChanged -= HandleBadgeChanged;
        NotificationService.OnChange -= HandleNotificationChanged;
        try { await JS.InvokeVoidAsync("unregisterGlobalKeyboardHandler"); }
        catch (JSDisconnectedException) { }
        catch (InvalidOperationException) { }
        _dotNetRef?.Dispose();
    }
}
