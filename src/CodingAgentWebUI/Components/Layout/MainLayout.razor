@inherits LayoutComponentBase
@implements IAsyncDisposable
@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Services
@inject IPipelineLoopService LoopService
@inject ConsolidationBadgeService BadgeService
@inject IJSRuntime JS

<div class="app-layout">
    @* TODO: The @if guard and CSS display:none on .sidebar-overlay-backdrop are redundant — if @if is removed for animation purposes, CSS still hides it outside <600px *@
    @* TODO: Hamburger button is rendered at all viewports (hidden via CSS). If triggered at >600px (e.g. via accessibility tools), overlay state is set with no visible effect. Consider guarding ToggleOverlay with a viewport width check. *@
    @if (_overlayOpen)
    {
        <div class="sidebar-overlay-backdrop" @onclick="CloseOverlay"></div>
    }
    <button class="hamburger-toggle" @onclick="ToggleOverlay" aria-label="Toggle navigation"><Icon Name="menu" Size="20" /></button>
    <nav class="sidebar @SidebarCssClass" role="navigation" aria-label="Main navigation">
        <div class="sidebar-brand">
            <span class="sidebar-icon" aria-hidden="true"><Icon Name="bot" Size="20" /></span>
            <span class="sidebar-label">Coding Agent</span>
        </div>

        <NavLink href="agent-chat" class="sidebar-link">
            <span class="sidebar-icon" aria-hidden="true"><Icon Name="message-circle" Size="20" /></span>
            <span class="sidebar-label">Agent Chat</span>
        </NavLink>
        <NavLink href="agent-coding" class="sidebar-link">
            <span class="sidebar-icon" aria-hidden="true"><Icon Name="bot" Size="20" /></span>
            <span class="sidebar-label">Agent Coding</span>
            @if (LoopService.IsLoopActive)
            {
                <span class="sidebar-loop-indicator" title="Pipeline loop is active"><Icon Name="refresh-cw" Size="14" /></span>
            }
        </NavLink>
        <NavLink href="agent-monitoring" class="sidebar-link">
            <span class="sidebar-icon" aria-hidden="true"><Icon Name="bar-chart-2" Size="20" /></span>
            <span class="sidebar-label">Agent Monitoring</span>
        </NavLink>
        <NavLink href="consolidation" class="sidebar-link">
            <span class="sidebar-icon" aria-hidden="true"><Icon Name="refresh-cw" Size="20" /></span>
            <span class="sidebar-label">Consolidation</span>
            @if (BadgeService.BadgeCount > 0)
            {
                <span class="sidebar-badge">@BadgeService.BadgeCount</span>
            }
        </NavLink>
        <NavLink href="settings" class="sidebar-link">
            <span class="sidebar-icon" aria-hidden="true"><Icon Name="settings" Size="20" /></span>
            <span class="sidebar-label">Settings</span>
        </NavLink>
        <NavLink href="about" class="sidebar-link">
            <span class="sidebar-icon" aria-hidden="true"><Icon Name="info" Size="20" /></span>
            <span class="sidebar-label">About</span>
        </NavLink>
        <SidebarHealthIndicators />
        <div class="sidebar-bottom-actions">
            <button class="sidebar-toggle sidebar-theme-toggle" @onclick="ToggleTheme"
                    aria-label="@(_theme == "dark" ? "Switch to light theme" : "Switch to dark theme")"
                    title="@(_theme == "dark" ? "Light mode" : "Dark mode")">
                <Icon Name="@(_theme == "dark" ? "sun" : "moon")" Size="18" />
            </button>
            <button class="sidebar-toggle sidebar-collapse-toggle" @onclick="ToggleCollapse"
                    aria-expanded="@(_collapsed ? "false" : "true")" aria-label="@(_collapsed ? "Expand sidebar" : "Collapse sidebar")">
                <Icon Name="@(_collapsed ? "chevrons-right" : "chevrons-left")" Size="16" />
            </button>
        </div>
    </nav>
    <main class="main-content">
        <CascadingValue Value="this" IsFixed="true">
            @Body
        </CascadingValue>
    </main>
</div>

<ShortcutHelpOverlay IsVisible="_showShortcutHelp" OnClose="() => { _showShortcutHelp = false; StateHasChanged(); }" />

@code {
    private DotNetObjectReference<MainLayout>? _dotNetRef;
    private bool _showShortcutHelp;
    private bool _collapsed;
    private bool _overlayOpen;
    private bool _jsReady;
    private string _theme = "dark";

    public event Action? OnEscapePressed;

    private string SidebarCssClass =>
        (_collapsed ? "collapsed " : "") + (_overlayOpen ? "overlay-open" : "");

    protected override void OnInitialized()
    {
        LoopService.OnChange += HandleLoopChanged;
        BadgeService.OnBadgeChanged += HandleBadgeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsReady = true;
            try
            {
                _dotNetRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("registerGlobalKeyboardHandler", _dotNetRef);
                var stored = await JS.InvokeAsync<string?>("getSidebarCollapsed");
                if (stored == "true")
                {
                    _collapsed = true;
                    StateHasChanged();
                }
                var theme = await JS.InvokeAsync<string>("getTheme");
                if (!string.IsNullOrEmpty(theme))
                {
                    _theme = theme;
                    StateHasChanged();
                }
            }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
        }
    }

    [JSInvokable]
    public async Task HandleGlobalKey(string key)
    {
        switch (key)
        {
            case "Escape":
                if (_showShortcutHelp)
                    _showShortcutHelp = false;
                else
                    OnEscapePressed?.Invoke();
                break;
            case "?":
                _showShortcutHelp = !_showShortcutHelp;
                break;
        }
        try { await InvokeAsync(StateHasChanged); }
        catch (ObjectDisposedException) { }
    }

    private async Task ToggleCollapse()
    {
        _collapsed = !_collapsed;
        if (_jsReady)
        {
            try { await JS.InvokeVoidAsync("setSidebarCollapsed", _collapsed ? "true" : "false"); }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
        }
    }

    private async Task ToggleTheme()
    {
        _theme = _theme == "dark" ? "light" : "dark";
        if (_jsReady)
        {
            try { await JS.InvokeVoidAsync("setTheme", _theme); }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
        }
    }

    private void ToggleOverlay()
    {
        _overlayOpen = !_overlayOpen;
    }

    private void CloseOverlay()
    {
        _overlayOpen = false;
    }

    private async void HandleLoopChanged()
    {
        try { await InvokeAsync(StateHasChanged); }
        catch (ObjectDisposedException) { }
    }

    private async void HandleBadgeChanged()
    {
        try { await InvokeAsync(StateHasChanged); }
        catch (ObjectDisposedException) { }
    }

    public async ValueTask DisposeAsync()
    {
        LoopService.OnChange -= HandleLoopChanged;
        BadgeService.OnBadgeChanged -= HandleBadgeChanged;
        try { await JS.InvokeVoidAsync("unregisterGlobalKeyboardHandler"); }
        catch (JSDisconnectedException) { }
        catch (InvalidOperationException) { }
        _dotNetRef?.Dispose();
    }
}
