@if (IsVisible)
{
    <div class="shortcut-overlay-backdrop" @onclick="OnClose">
        <div class="shortcut-overlay" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-label="Keyboard shortcuts">
            <div class="shortcut-overlay-header">
                <h3>Keyboard Shortcuts</h3>
                <button class="agent-detail-close" @onclick="OnClose" aria-label="Close">✕</button>
            </div>
            <div class="shortcut-overlay-section">
                <h4>Global</h4>
                <dl class="shortcut-list">
                    <div class="shortcut-row"><dt><kbd>?</kbd></dt><dd>Show/hide this help</dd></div>
                    <div class="shortcut-row"><dt><kbd>Esc</kbd></dt><dd>Close drawer, modal, or overlay</dd></div>
                </dl>
            </div>
            <div class="shortcut-overlay-section">
                <h4>Drawer Navigation</h4>
                <dl class="shortcut-list">
                    <div class="shortcut-row"><dt><kbd>↓</kbd></dt><dd>Move to next item</dd></div>
                    <div class="shortcut-row"><dt><kbd>↑</kbd></dt><dd>Move to previous item</dd></div>
                    <div class="shortcut-row"><dt><kbd>Enter</kbd></dt><dd>Select and dispatch highlighted item</dd></div>
                    <div class="shortcut-row"><dt><kbd>Esc</kbd></dt><dd>Close drawer</dd></div>
                </dl>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
}
