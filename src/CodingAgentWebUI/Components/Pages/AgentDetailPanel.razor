@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models
@using CodingAgentWebUI.Pipeline.Services
@using CodingAgentWebUI.Services
@using Microsoft.AspNetCore.SignalR
@inject AgentRegistryService Registry
@inject IConfigurationStore ConfigStore
@inject IPipelineRunHistoryService HistoryService
@inject PipelineOrchestrationService PipelineService
@inject IHubContext<CodingAgentWebUI.Hubs.AgentHub, IAgentHubClient> HubContext

<div class="agent-detail-overlay @(IsOpen ? "open" : "")" @onclick="Close"></div>
<aside class="agent-detail-panel @(IsOpen ? "open" : "")">
    @if (Agent != null)
    {
        <div class="agent-detail-header">
            <h3>Agent Details</h3>
            @if (Agent.Disabled)
            {
                <span class="badge badge-disabled">DISABLED</span>
            }
            <button class="agent-detail-close" @onclick="Close" aria-label="Close panel">✕</button>
        </div>

        <!-- Identity Section -->
        <div class="agent-detail-section">
            <h4>Identity</h4>
            <div class="agent-detail-grid">
                <div class="detail-label">Agent ID</div>
                <div class="detail-value detail-mono">@Agent.AgentId</div>
                <div class="detail-label">Hostname</div>
                <div class="detail-value">@Agent.Hostname</div>
                <div class="detail-label">Type</div>
                <div class="detail-value">@Agent.AgentType</div>
                <div class="detail-label">Labels</div>
                <div class="detail-value">
                    @foreach (var label in Agent.Labels)
                    {
                        <span class="sidebar-label">@label</span>
                    }
                </div>
                <div class="detail-label">Connection</div>
                <div class="detail-value detail-mono">@Truncate(Agent.ConnectionId, 20)</div>
                <div class="detail-label">Registered</div>
                <div class="detail-value">@Agent.RegisteredAt.ToLocalTime().ToString("g")</div>
            </div>
        </div>

        <!-- Status Section -->
        <div class="agent-detail-section">
            <h4>Status</h4>
            <div class="agent-detail-grid">
                <div class="detail-label">Current</div>
                <div class="detail-value">
                    <span class="monitoring-status monitoring-status-@Agent.Status.ToString().ToLowerInvariant()">
                        @GetStatusIcon(Agent.Status) @Agent.Status
                    </span>
                </div>
                <div class="detail-label">Last Heartbeat</div>
                <div class="detail-value">@FormatTimeAgo(Agent.LastHeartbeatAt)</div>
                @if (Agent.DisconnectedAt.HasValue)
                {
                    <div class="detail-label">Disconnected At</div>
                    <div class="detail-value">@Agent.DisconnectedAt.Value.ToLocalTime().ToString("g")</div>
                }
            </div>
        </div>

        <!-- Active Job Section (when Busy) -->
        @if (Agent.Status == AgentStatus.Busy && Agent.ActiveJobId != null)
        {
            var activeRun = GetActiveRun(Agent.ActiveJobId);
            <div class="agent-detail-section">
                <h4>Active Job</h4>
                <div class="agent-detail-grid">
                    <div class="detail-label">Job ID</div>
                    <div class="detail-value detail-mono">@Truncate(Agent.ActiveJobId, 20)</div>
                    @if (activeRun != null)
                    {
                        <div class="detail-label">Issue</div>
                        <div class="detail-value">#@activeRun.IssueIdentifier @Truncate(activeRun.IssueTitle, 30)</div>
                        <div class="detail-label">Step</div>
                        <div class="detail-value">@FormatStep(activeRun.CurrentStep)</div>
                        <div class="detail-label">Elapsed</div>
                        <div class="detail-value">@((DateTime.UtcNow - activeRun.StartedAt).ToString(@"hh\:mm\:ss"))</div>
                    }
                </div>
            </div>
        }

        <!-- Matched Profile Section -->
        <div class="agent-detail-section">
            <h4>Matched Profile</h4>
            @if (_matchedProfile != null)
            {
                <div class="agent-detail-grid">
                    <div class="detail-label">Profile</div>
                    <div class="detail-value">@_matchedProfile.DisplayName</div>
                    <div class="detail-label">Profile ID</div>
                    <div class="detail-value detail-mono">@Truncate(_matchedProfile.Id, 20)</div>
                    <div class="detail-label">Provider Config</div>
                    <div class="detail-value detail-mono">@Truncate(_matchedProfile.AgentProviderConfigId, 20)</div>
                </div>
            }
            else
            {
                <div class="agent-detail-warning">⚠️ No profile matched</div>
            }
        </div>

        <!-- Job History Section -->
        <div class="agent-detail-section">
            <h4>Job History</h4>
            @if (_agentRuns.Count == 0)
            {
                <div class="agent-detail-empty">No completed jobs yet.</div>
            }
            else
            {
                <div class="agent-detail-stats">
                    <span>Total: @_agentRuns.Count</span>
                    <span>Success: @ComputeSuccessRate()%</span>
                    <span>Avg: @ComputeAverageDuration()</span>
                </div>
                <div class="agent-history-list">
                    @foreach (var run in _agentRuns)
                    {
                        <div class="agent-history-item">
                            <span class="history-issue">#@run.IssueIdentifier</span>
                            <span class="step-badge step-@run.FinalStep.ToString().ToLowerInvariant()">@GetStepIcon(run.FinalStep)</span>
                            <span class="history-duration">@FormatDuration(run.StartedAt, run.CompletedAt)</span>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Actions Section -->
        <div class="agent-detail-section agent-detail-actions">
            <h4>Actions</h4>
            @if (Agent.Disabled)
            {
                <button class="btn-enable" @onclick="EnableAgent">✓ Enable Agent</button>
            }
            else
            {
                <button class="btn-disable" @onclick="DisableAgent">⊘ Disable Agent</button>
            }
            <button class="btn-force-disconnect" @onclick="ShowDisconnectConfirm">⚡ Force Disconnect</button>
        </div>

        @if (_showDisconnectConfirm)
        {
            <div class="agent-detail-confirm">
                <p>Force disconnect <strong>@Agent.AgentId</strong>?</p>
                <p class="confirm-warning">This will deregister the agent and mark any active run as Failed.</p>
                <div class="confirm-buttons">
                    <button class="btn-force-disconnect" @onclick="ForceDisconnect">Confirm</button>
                    <button class="btn-cancel" @onclick="() => _showDisconnectConfirm = false">Cancel</button>
                </div>
            </div>
        }
    }
</aside>

@code {
    [Parameter] public AgentEntry? Agent { get; set; }
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private AgentProfile? _matchedProfile;
    private IReadOnlyList<PipelineRunSummary> _agentRuns = [];
    private bool _showDisconnectConfirm;

    protected override async Task OnParametersSetAsync()
    {
        if (Agent != null && IsOpen)
        {
            await ResolveProfile();
            _agentRuns = HistoryService.GetRunsByAgentId(Agent.AgentId, 10);
        }
        else
        {
            _matchedProfile = null;
            _agentRuns = [];
        }
        _showDisconnectConfirm = false;
    }

    private async Task ResolveProfile()
    {
        try
        {
            var profiles = await ConfigStore.LoadAgentProfilesAsync(CancellationToken.None);
            var resolver = new ProfileResolver();
            _matchedProfile = resolver.Resolve(profiles, Agent!.Labels);
        }
        catch
        {
            _matchedProfile = null;
        }
    }

    private PipelineRun? GetActiveRun(string jobId)
    {
        return PipelineService.GetAllActiveRuns().FirstOrDefault(r => r.RunId == jobId);
    }

    private void Close()
    {
        OnClose.InvokeAsync();
    }

    private void EnableAgent()
    {
        if (Agent != null)
        {
            Agent.Disabled = false;
        }
    }

    private void DisableAgent()
    {
        if (Agent != null)
        {
            Agent.Disabled = true;
        }
    }

    private void ShowDisconnectConfirm()
    {
        _showDisconnectConfirm = true;
    }

    private async Task ForceDisconnect()
    {
        if (Agent == null) return;

        try
        {
            // Send ForceDisconnect to agent if connected
            if (Agent.Status != AgentStatus.Disconnected)
            {
                try
                {
                    await HubContext.Clients.Client(Agent.ConnectionId).ForceDisconnect();
                }
                catch { /* Agent may not respond */ }
            }

            // Mark active run as Failed
            if (Agent.ActiveJobId != null)
            {
                var activeRun = PipelineService.GetAllActiveRuns()
                    .FirstOrDefault(r => r.RunId == Agent.ActiveJobId);
                if (activeRun != null)
                {
                    activeRun.FailureReason = "Force disconnected by operator";
                    activeRun.CurrentStep = PipelineStep.Failed;
                    activeRun.CompletedAt = DateTime.UtcNow;
                }
            }

            // Deregister from registry
            Registry.Deregister(Agent.AgentId);
        }
        catch { /* Best effort */ }

        _showDisconnectConfirm = false;
        await OnClose.InvokeAsync();
    }

    private int ComputeSuccessRate()
    {
        if (_agentRuns.Count == 0) return 0;
        var completed = _agentRuns.Count(r => r.FinalStep == PipelineStep.Completed);
        return (int)Math.Round(100.0 * completed / _agentRuns.Count);
    }

    private string ComputeAverageDuration()
    {
        var withDuration = _agentRuns
            .Where(r => r.CompletedAt.HasValue)
            .Select(r => r.CompletedAt!.Value - r.StartedAt)
            .ToList();
        if (withDuration.Count == 0) return "N/A";
        var avg = TimeSpan.FromTicks((long)withDuration.Average(d => d.Ticks));
        return avg.ToString(@"hh\:mm\:ss");
    }

    private static string GetStatusIcon(AgentStatus status) => status switch
    {
        AgentStatus.Idle => "🟢",
        AgentStatus.Busy => "🟡",
        AgentStatus.Disconnected => "🔴",
        _ => "⚪"
    };

    private static string GetStepIcon(PipelineStep step) => step switch
    {
        PipelineStep.Completed => "✅",
        PipelineStep.Failed => "❌",
        PipelineStep.Cancelled => "⊘",
        _ => "○"
    };

    private static string FormatStep(PipelineStep step) => step switch
    {
        PipelineStep.Created => "Created",
        PipelineStep.CloningRepository => "Cloning",
        PipelineStep.CreatingBranch => "Branching",
        PipelineStep.AnalyzingCode => "Analyzing",
        PipelineStep.GeneratingCode => "Generating",
        PipelineStep.ReviewingCode => "Reviewing",
        PipelineStep.RunningQualityGates => "Quality Gates",
        PipelineStep.CreatingPullRequest => "Creating PR",
        PipelineStep.Completed => "Completed",
        PipelineStep.Failed => "Failed",
        _ => step.ToString()
    };

    private static string FormatTimeAgo(DateTimeOffset timestamp)
    {
        var ago = DateTimeOffset.UtcNow - timestamp;
        if (ago.TotalSeconds < 60) return $"{(int)ago.TotalSeconds}s ago";
        if (ago.TotalMinutes < 60) return $"{(int)ago.TotalMinutes}m ago";
        return $"{(int)ago.TotalHours}h ago";
    }

    private static string FormatDuration(DateTime startedAt, DateTime? completedAt)
    {
        if (completedAt is null) return "—";
        var duration = completedAt.Value - startedAt;
        return duration.ToString(@"mm\:ss");
    }

    private static string Truncate(string? value, int maxLength)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        return value.Length <= maxLength ? value : value[..(maxLength - 3)] + "...";
    }
}
