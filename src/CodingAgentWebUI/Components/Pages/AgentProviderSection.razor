@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models
@using CodingAgentWebUI.Pipeline.Services
@using CodingAgentWebUI.Orchestration
@using CodingAgentWebUI.Orchestration.Dispatch
@using CodingAgentWebUI.Orchestration.Health
@using CodingAgentWebUI.Orchestration.Registry
@using CodingAgentWebUI.Services
@implements IAsyncDisposable

<section class="settings-section">
    <h2>Agent Provider Configs (referenced by Agent Profiles)</h2>
    <p class="section-description">These configurations define how agents connect to the Kiro CLI. They are linked from Agent Profiles — each profile references one provider config to determine the executable path, timeout, and model settings for matched agents.</p>
    <div class="provider-list">
        @foreach (var p in Providers)
        {
            <div class="provider-card">
                <div class="provider-info">
                    <strong>@p.DisplayName</strong>
                    <span class="provider-type">@p.ProviderType</span>
                    <span class="provider-detail">@p.Settings.GetValueOrDefault("executablePath", "") · @(p.Settings.GetValueOrDefault("timeout", "30"))min · model: @(p.Settings.GetValueOrDefault("model", "auto"))</span>
                </div>
                <div class="provider-actions">
                    <button class="btn-edit" @onclick="() => EditProvider(p)">Edit</button>
                    <button class="btn-delete" @onclick="() => OnDelete.InvokeAsync(p.Id)">Delete</button>
                </div>
            </div>
        }
    </div>
    @if (_showForm)
    {
        <div class="provider-form-row">
            <div class="provider-form">
                <h3>@(_editingProvider != null ? "Edit" : "Add") Agent Provider</h3>
                <div class="form-group">
                    <label>Provider Type</label>
                    <select @bind="_form.ProviderType"><option value="KiroCli">KiroCli</option></select>
                </div>
                <div class="form-group">
                    <label>Display Name</label>
                    <input type="text" @bind="_form.DisplayName" placeholder="Kiro CLI Agent" />
                </div>
                <div class="form-group">
                    <label>Executable Path</label>
                    <input type="text" @bind="_form.ExecutablePath" placeholder="/root/.local/bin/kiro-cli" />
                </div>
                <div class="form-group">
                    <label>Timeout (minutes)</label>
                    <input type="number" @bind="_form.TimeoutMinutes" min="1" />
                </div>
                <div class="form-group">
                    <label>Agent Name</label>
                    <input type="text" @bind="_form.AgentName" placeholder="default" />
                </div>
                <div class="form-group">
                    <label>Model</label>
                    <div class="input-with-action">
                        @if (_availableModels.Count > 0)
                        {
                            <select @bind="_form.Model">
                                <option value="auto">auto — Use CLI default (1.0x)</option>
                                @foreach (var m in _availableModels.Where(m => !m.ModelId.Equals("auto", StringComparison.OrdinalIgnoreCase)))
                                {
                                    <option value="@m.ModelId">@m.ModelId — @m.Description (@(m.RateMultiplier)x)</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="text" @bind="_form.Model" placeholder="auto" />
                        }
                        <button class="btn-edit" @onclick="FetchModels" disabled="@_loadingModels">
                            @(_loadingModels ? "Loading..." : "Fetch Models")
                        </button>
                    </div>
                    <span class="form-hint">Select a model or leave as "auto" for default. Click "Fetch Models" to query available models from the CLI.</span>
                </div>
                <div class="form-buttons">
                    <button class="btn-save" @onclick="SaveProvider">Save</button>
                    <button class="btn-cancel" @onclick="() => _showForm = false">Cancel</button>
                </div>
            </div>
            <div class="provider-help">
                <h4>🤖 Kiro CLI Setup</h4>
                <p>The agent provider runs the Kiro CLI to generate code. Kiro CLI must be installed and authenticated separately.</p>
                <p class="help-heading">Prerequisites:</p>
                <ul>
                    <li>Install Kiro CLI — it's bundled with the Docker image, or install manually</li>
                    <li>Run <code>kiro-cli login</code> once to authenticate (device code flow)</li>
                </ul>
                <p class="help-heading">Fields:</p>
                <ul>
                    <li><strong>Executable Path</strong> — full path to the kiro-cli binary (e.g. <code>/home/ubuntu/.local/bin/kiro-cli</code>)</li>
                    <li><strong>Timeout</strong> — max minutes per agent invocation before it's killed</li>
                    <li><strong>Agent Name</strong> — leave as <code>default</code> unless you have a custom agent configured</li>
                    <li><strong>Model</strong> — the LLM model to use. <code>auto</code> uses the CLI default. Click "Fetch Models" to see available options with cost multipliers</li>
                </ul>
                <p class="help-tip">💡 Auth tokens are stored in <code>~/.local/share/kiro-cli/</code> and persist across runs when using a Docker volume.</p>
            </div>
        </div>
    }
    else
    {
        <button class="btn-add" @onclick="ShowAddForm">+ Add Agent Provider</button>
    }
</section>

@code {
    [Parameter, EditorRequired] public List<ProviderConfig> Providers { get; set; } = new();
    [Parameter, EditorRequired] public IConfigurationStore ConfigStore { get; set; } = default!;
    [Parameter] public EventCallback<string> OnDelete { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback<(string Message, bool IsError)> OnShowStatus { get; set; }
    [Parameter] public ModelFetchService? ModelFetchService { get; set; }

    private CancellationTokenSource _cts = new();
    private bool _showForm;
    private ProviderConfig? _editingProvider;
    private AgentProviderForm _form = new();
    private List<AgentModelInfo> _availableModels = new();
    private bool _loadingModels;

    private void ShowAddForm()
    {
        _editingProvider = null;
        _form = new AgentProviderForm();
        _availableModels.Clear();
        _showForm = true;
    }

    private void EditProvider(ProviderConfig p)
    {
        _editingProvider = p;
        _form = new AgentProviderForm
        {
            ProviderType = p.ProviderType,
            DisplayName = p.DisplayName,
            ExecutablePath = p.Settings.GetValueOrDefault("executablePath", ""),
            TimeoutMinutes = int.TryParse(p.Settings.GetValueOrDefault("timeout", "30"), out var t) ? t : 30,
            AgentName = p.Settings.GetValueOrDefault("agentName", ""),
            Model = p.Settings.GetValueOrDefault("model", "auto")
        };
        _availableModels.Clear();
        _showForm = true;
    }

    private async Task SaveProvider()
    {
        if (string.IsNullOrWhiteSpace(_form.DisplayName))
        {
            await OnShowStatus.InvokeAsync(("Display Name is required.", true));
            return;
        }

        var model = string.IsNullOrWhiteSpace(_form.Model) ? "auto" : _form.Model.Trim();
        if (!model.Equals("auto", StringComparison.OrdinalIgnoreCase)
            && !System.Text.RegularExpressions.Regex.IsMatch(model, @"^[a-zA-Z0-9._-]+$"))
        {
            await OnShowStatus.InvokeAsync(("Model name contains invalid characters. Only letters, numbers, dots, hyphens, and underscores are allowed.", true));
            return;
        }

        var config = new ProviderConfig
        {
            Id = _editingProvider?.Id ?? Guid.NewGuid().ToString(),
            Kind = ProviderKind.Agent,
            ProviderType = _form.ProviderType,
            DisplayName = _form.DisplayName,
            Settings = new Dictionary<string, string>
            {
                ["executablePath"] = _form.ExecutablePath,
                ["timeout"] = _form.TimeoutMinutes.ToString(),
                ["agentName"] = _form.AgentName,
                ["model"] = model
            }
        };

        try
        {
            await ConfigStore.SaveProviderConfigAsync(config, _cts.Token);
            _showForm = false;
            await OnSaved.InvokeAsync();
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            await OnShowStatus.InvokeAsync(($"Failed to save: {ex.Message}", true));
        }
    }

    private async Task FetchModels()
    {
        if (ModelFetchService is null)
        {
            await OnShowStatus.InvokeAsync(("Model fetch service is not available.", true));
            return;
        }

        _loadingModels = true;
        if (!_cts.IsCancellationRequested) StateHasChanged();

        try
        {
            var (models, error) = await ModelFetchService.FetchModelsAsync(_cts.Token);

            if (error is not null)
            {
                await OnShowStatus.InvokeAsync((error, true));
                return;
            }

            _availableModels = models.ToList();
            if (_form.Model != "auto" && models.Count > 0 && !models.Any(m => m.ModelId == _form.Model))
                _form.Model = "auto";

            await OnShowStatus.InvokeAsync(($"{models.Count} model(s) loaded.", false));
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            await OnShowStatus.InvokeAsync(($"Failed to fetch models: {ex.Message}", true));
        }
        finally
        {
            _loadingModels = false;
        }
    }

    private class AgentProviderForm
    {
        public string ProviderType { get; set; } = "KiroCli";
        public string DisplayName { get; set; } = "";
        public string ExecutablePath { get; set; } = "/home/ubuntu/.local/bin/kiro-cli";
        public int TimeoutMinutes { get; set; } = 30;
        public string AgentName { get; set; } = "default";
        public string Model { get; set; } = "auto";
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
    }
}
