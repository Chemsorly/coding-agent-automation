@using CodingAgentWebUI.Pipeline.Models

<div class="pipeline-summary">
    <div class="summary-header">
        <div class="summary-title">
            <span class="summary-icon">@OutcomeIcon</span>
            <h2>
                @if (Run.RunType == PipelineRunType.Review)
                {
                    <text>PR Review @OutcomeText</text>
                }
                else
                {
                    <text>Pipeline @OutcomeText</text>
                }
            </h2>
        </div>
        <div class="summary-meta">
            @if (Run.RunType == PipelineRunType.Review)
            {
                <text>PR #@Run.IssueIdentifier · @Run.IssueTitle</text>
            }
            else
            {
                <text>Issue #@Run.IssueIdentifier · @Run.IssueTitle</text>
            }
        </div>
        <div class="summary-meta">
            Duration: @FormatDuration()
            @if (!string.IsNullOrEmpty(Run.RepositoryName))
            {
                <span> · Repo: @Run.RepositoryName</span>
            }
            @if (!string.IsNullOrEmpty(Run.ModelName))
            {
                <span> · Model: @Run.ModelName</span>
            }
        </div>
        @if (!string.IsNullOrEmpty(Run.BranchName))
        {
            <div class="summary-meta summary-branch">Branch: @Run.BranchName</div>
        }
        @if (Run.RunType == PipelineRunType.Review && !string.IsNullOrEmpty(Run.ReviewPrUrl))
        {
            <div class="summary-meta">
                🔗 <a href="@Run.ReviewPrUrl" target="_blank" rel="noopener noreferrer">View PR on GitHub →</a>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(Run.FailureReason))
    {
        <div class="summary-failure-callout" role="alert" data-testid="failure-reason">⚠️ @Run.FailureReason</div>
    }

    @if ((Run.BlacklistedFilesDetected?.Count ?? 0) > 0)
    {
        <div class="summary-blacklist-warning" role="alert">
            ⚠️ Blacklisted files excluded from commit:
            <ul>
                @foreach (var file in Run.BlacklistedFilesDetected!)
                {
                    <li>@file</li>
                }
            </ul>
        </div>
    }

    @if (Run.CurrentStep == PipelineStep.Cancelled)
    {
        <div class="summary-cancelled-step">Cancelled during: @GetLastReachedStep().ToDisplayName()</div>
    }
    else if (Run.RunType == PipelineRunType.Review)
    {
        <div class="result-strip">
            @if (Run.CodeReviewAgentsRun.Count > 0)
            {
                <span>Agents: @string.Join(", ", Run.CodeReviewAgentsRun)</span>
                <span class="result-strip-sep">│</span>
            }
            @if (Run.CodeReviewCriticalCount > 0 || Run.CodeReviewWarningCount > 0 || Run.CodeReviewSuggestionCount > 0)
            {
                <span>Findings: 🔴@(Run.CodeReviewCriticalCount) 🟡@(Run.CodeReviewWarningCount) 🔵@(Run.CodeReviewSuggestionCount)</span>
            }
            else
            {
                <span>✅ No issues found</span>
            }
        </div>
    }
    else
    {
        <div class="result-strip">
            @{ var qr = Run.LatestQualityReport; }
            <span>Compilation @(qr?.Compilation.Passed == true ? "✅" : qr is not null ? "❌" : "—")</span>
            <span class="result-strip-sep">│</span>
            <span>Tests @(qr is not null ? (qr.Tests.Passed ? "✅" : "❌") : "—") @FormatTestCounts(qr)</span>
            <span class="result-strip-sep">│</span>
            <span>Coverage @FormatCoverage(qr)</span>
            <span class="result-strip-sep">│</span>
            <span>Security @(qr?.SecurityScan is { } sec ? (sec.Passed ? "✅" : "❌") : "—")</span>
            <span class="result-strip-sep">│</span>
            <span>Files: @Run.FilesChangedCount (+@Run.LinesAdded -@Run.LinesRemoved)</span>
            <span class="result-strip-sep">│</span>
            @if (Run.CodeReviewCriticalCount > 0 || Run.CodeReviewWarningCount > 0 || Run.CodeReviewSuggestionCount > 0)
            {
                <span>Review: 🔴@(Run.CodeReviewCriticalCount) 🟡@(Run.CodeReviewWarningCount) 🔵@(Run.CodeReviewSuggestionCount)</span>
                <span class="result-strip-sep">│</span>
            }
            <span>Retries: @Run.RetryCount@(MaxRetries.HasValue ? $"/{MaxRetries}" : "")</span>
        </div>
    }

    @if (!string.IsNullOrEmpty(Run.PullRequestUrl))
    {
        <div class="summary-pr-link" data-testid="pr-link">
            🔗 PR @(!string.IsNullOrEmpty(Run.PullRequestNumber) ? $"#{Run.PullRequestNumber}" : "")
            (@(Run.IsDraftPr ? "draft" : "final")) —
            <a href="@Run.PullRequestUrl" target="_blank" rel="noopener noreferrer">View on GitHub →</a>
        </div>
    }

    <button class="btn-save" @onclick="OnBackToIssues">Back to Issues</button>
</div>

@code {
    /// <summary>The pipeline run to display in the summary.</summary>
    [Parameter, EditorRequired] public PipelineRun Run { get; set; } = default!;

    /// <summary>Maximum retry count from pipeline configuration, for "Retries: N/M" display.</summary>
    [Parameter] public int? MaxRetries { get; set; }

    /// <summary>Callback invoked when the user clicks "Back to Issues".</summary>
    [Parameter] public EventCallback OnBackToIssues { get; set; }

    private string OutcomeIcon => Run.CurrentStep switch
    {
        PipelineStep.Completed => "✅",
        PipelineStep.Failed => "❌",
        PipelineStep.Cancelled => "🚫",
        _ => "❓"
    };

    private string OutcomeText => Run.CurrentStep switch
    {
        PipelineStep.Completed => "Completed",
        PipelineStep.Failed => "Failed",
        PipelineStep.Cancelled => "Cancelled",
        _ => Run.CurrentStep.ToString()
    };

    private string FormatDuration()
    {
        var elapsed = (Run.CompletedAtOffset ?? DateTimeOffset.UtcNow) - Run.StartedAtOffset;
        if (elapsed < TimeSpan.Zero) return "—";
        if (elapsed.TotalHours >= 1)
            return $"{(int)elapsed.TotalHours}h {elapsed.Minutes:D2}m {elapsed.Seconds:D2}s";
        if (elapsed.TotalMinutes >= 1)
            return $"{(int)elapsed.TotalMinutes}m {elapsed.Seconds:D2}s";
        return $"{elapsed.Seconds}s";
    }

    private static string FormatTestCounts(QualityGateReport? qr)
    {
        if (qr is null) return "";
        var p = qr.Tests.TestsPassed?.ToString() ?? "—";
        var f = qr.Tests.TestsFailed?.ToString() ?? "—";
        var s = qr.Tests.TestsSkipped?.ToString() ?? "—";
        return $"{p}p/{f}f/{s}s";
    }

    private static string FormatCoverage(QualityGateReport? qr)
    {
        if (qr?.Coverage is not { } cov) return "—";
        if (!cov.CoveragePercent.HasValue) return cov.Passed ? "✅ —" : "❌ —";
        return $"{(cov.Passed ? "✅" : "❌")} {cov.CoveragePercent.Value.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)}%";
    }

    private PipelineStep GetLastReachedStep() => Run.GetLastReachedStep();
}
