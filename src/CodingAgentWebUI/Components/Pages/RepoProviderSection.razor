@using System.Text.RegularExpressions
@using CodingAgentWebUI.Pipeline
@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models
@using CodingAgentWebUI.Infrastructure.GitHub
@using CodingAgentWebUI.Infrastructure.GitLab

<section class="settings-section">
    <h2>Repository Providers</h2>
    <p class="section-description">Configure target repositories where agents clone, branch, and push code. The <code>requiredLabels</code> field determines which agents can work on issues from each repo.</p>
    <div class="provider-list">
        @foreach (var p in Providers)
        {
            <div class="provider-card">
                <div class="provider-info">
                    <strong>@p.DisplayName</strong>
                    <span class="provider-type">@p.ProviderType</span>
                    <span class="provider-detail">@p.Settings.GetValueOrDefault(ProviderSettingKeys.Owner, "")/@p.Settings.GetValueOrDefault(ProviderSettingKeys.Repo, "") → @p.Settings.GetValueOrDefault(ProviderSettingKeys.BaseBranch, ProviderSettingKeys.DefaultBaseBranch)</span>
                    <span class="provider-type">@p.RepositoryRole</span>
                    @if (p.RepositoryRole == RepositoryRole.Work && p.RequiredLabels is { Count: > 0 })
                    {
                        @foreach (var label in p.RequiredLabels)
                        {
                            <span class="provider-label">@label</span>
                        }
                    }
                </div>
                <div class="provider-actions">
                    <button class="btn-edit" @onclick="() => EditProvider(p)">Edit</button>
                    <button class="btn-delete" @onclick="() => { _deletingProviderId = p.Id; _showDeleteConfirm = true; }">Delete</button>
                </div>
            </div>
        }
    </div>

    @if (_showDeleteConfirm && _deletingProviderId != null)
    {
        <div class="agent-detail-confirm" style="margin-top: 12px;">
            <p>Delete this repository provider?</p>
            <div class="confirm-buttons">
                @* TODO: OnDelete.InvokeAsync(id) is fire-and-forget — if delete fails asynchronously, user gets no error feedback. *@
                <button class="btn-delete" @onclick="() => { var id = _deletingProviderId!; _showDeleteConfirm = false; _deletingProviderId = null; OnDelete.InvokeAsync(id); }">Delete</button>
                <button class="btn-cancel" @onclick="() => { _showDeleteConfirm = false; _deletingProviderId = null; }">Cancel</button>
            </div>
        </div>
    }

    @if (_showForm)
    {
        @if (_form.ProviderType == "GitLab")
        {
            <GitLabProviderForm
                SectionTitle="Repository Provider"
                DisplayNamePlaceholder="My GitLab Repo"
                IsEditing="@(_editingProvider is not null)"
                ShowBaseBranch="true"
                ProviderType="@_form.ProviderType" ProviderTypeChanged="OnProviderTypeChanged"
                DisplayName="@_form.DisplayName" DisplayNameChanged="v => _form.DisplayName = v"
                ApiUrl="@_form.GitLabApiUrl" ApiUrlChanged="v => _form.GitLabApiUrl = v"
                AccessToken="@_form.GitLabAccessToken" AccessTokenChanged="v => _form.GitLabAccessToken = v"
                ProjectId="@_form.GitLabProjectId" ProjectIdChanged="v => _form.GitLabProjectId = v"
                BaseBranch="@_form.BaseBranch" BaseBranchChanged="v => _form.BaseBranch = v"
                ValidationMessage="@_validationMessage"
                ValidationSuccess="_validationSuccess"
                Saving="_saving"
                OnSave="SaveGitLabProvider"
                OnCancel="CancelForm">
                <AdditionalFields>
                    <div class="form-group">
                        <label>Repository Role</label>
                        <select @bind="_form.RepositoryRole">
                            <option value="Work">Work</option>
                            <option value="Brain">Brain</option>
                        </select>
                    </div>
                    @if (_form.RepositoryRole != "Brain")
                    {
                        <div class="form-group">
                            <label>Required Agent Labels <span class="form-hint">(comma-separated — determines agent routing and quality gates)</span></label>
                            <input type="text" @bind="_form.RequiredLabels" placeholder="e.g. kiro, dotnet, dotnet10" />
                        </div>
                        <div class="form-group">
                            <div class="label-with-hint">
                                <label>Blacklisted Paths</label>
                                <span class="form-hint-icon" aria-hidden="true" title="Comma-separated path prefixes excluded from agent commits (e.g. .kiro, .github). Leave empty to use global defaults.">?</span>
                            </div>
                            <input type="text" @bind="_form.BlacklistedPaths" placeholder=".kiro, .github, .brain" />
                        </div>
                        <Collapsible CssClass="secrets-section" HeaderClass="secrets-section-header" BodyClass="secrets-section-body"
                                     IsExpanded="_secretsExpanded" IsExpandedChanged="v => _secretsExpanded = v">
                            <Header>🔑 Secrets (@_form.Secrets.Count)</Header>
                            <ChildContent>
                                @for (var i = 0; i < _form.Secrets.Count; i++)
                                {
                                    var index = i;
                                    var secret = _form.Secrets[index];
                                    var isRevealed = _revealedSecrets.Contains(index);
                                    <div class="secret-row">
                                        <input type="text"
                                               class="secret-key-input"
                                               value="@secret.Key"
                                               @onchange="e => UpdateSecretKey(index, e.Value?.ToString() ?? string.Empty)"
                                               placeholder="ENV_VAR_NAME" />
                                        <input type="@(isRevealed ? "text" : "password")"
                                               class="secret-value-input"
                                               value="@secret.Value"
                                               @onchange="e => UpdateSecretValue(index, e.Value?.ToString() ?? string.Empty)"
                                               placeholder="secret value" />
                                        <button type="button" class="btn-icon" title="@(isRevealed ? "Hide" : "Reveal")" @onclick="() => ToggleSecretVisibility(index)">@(isRevealed ? "🙈" : "👁")</button>
                                        <button type="button" class="btn-icon btn-icon-danger" title="Remove" @onclick="() => RemoveSecret(index)">🗑</button>
                                    </div>
                                    @if (!string.IsNullOrEmpty(secret.ValidationError))
                                    {
                                        <div class="secret-validation-error">@secret.ValidationError</div>
                                    }
                                }
                                <button type="button" class="btn-add-inline" @onclick="AddSecret">+ Add Secret</button>
                            </ChildContent>
                        </Collapsible>
                        <Collapsible CssClass="setup-steps-section" HeaderClass="setup-steps-section-header" BodyClass="setup-steps-section-body"
                                     IsExpanded="_setupStepsExpanded" IsExpandedChanged="v => _setupStepsExpanded = v">
                            <Header>⚙️ Setup Steps (@_form.SetupSteps.Count)</Header>
                            <ChildContent>
                                <span class="form-hint">Each step runs as a full shell command via <code>/bin/bash -c</code> after clone. The name is a label for logs only.</span>
                                @for (var i = 0; i < _form.SetupSteps.Count; i++)
                                {
                                    var index = i;
                                    var step = _form.SetupSteps[index];
                                    <div class="setup-step-row">
                                        <div class="setup-step-header">
                                            <span class="setup-step-number">@(index + 1).</span>
                                            <input type="text"
                                                   class="setup-step-name-input"
                                                   value="@step.Name"
                                                   @onchange="e => UpdateSetupStepName(index, e.Value?.ToString() ?? string.Empty)"
                                                   placeholder="Label (e.g. Restore dependencies)" />
                                            <div class="setup-step-actions">
                                                <button type="button" class="btn-icon" title="Move up" disabled="@(index == 0)" @onclick="() => MoveSetupStepUp(index)">↑</button>
                                                <button type="button" class="btn-icon" title="Move down" disabled="@(index == _form.SetupSteps.Count - 1)" @onclick="() => MoveSetupStepDown(index)">↓</button>
                                                <button type="button" class="btn-icon btn-icon-danger" title="Remove" @onclick="() => RemoveSetupStep(index)">🗑</button>
                                            </div>
                                        </div>
                                        <textarea class="setup-step-command-input"
                                                  rows="2"
                                                  @onchange="e => UpdateSetupStepCommand(index, e.Value?.ToString() ?? string.Empty)"
                                                  placeholder="Full shell command (e.g. dotnet restore, npm install)">@step.Command</textarea>
                                        @if (!string.IsNullOrEmpty(step.ValidationError))
                                        {
                                            <div class="setup-step-validation-error">@step.ValidationError</div>
                                        }
                                    </div>
                                }
                                <button type="button" class="btn-add-inline" @onclick="AddSetupStep">+ Add Step</button>
                            </ChildContent>
                        </Collapsible>
                    }
                    <div class="form-group">
                        <label>Steering Instructions</label>
                        <p class="form-hint">These instructions are provided to agents working on this repository. Use them for repo-specific conventions like architecture constraints, build/test commands, or file organization rules.</p>
                        <textarea @bind="_form.SteeringContent" rows="15" placeholder="## Architecture&#10;- This is a Spring Boot application using Gradle&#10;- All REST endpoints require OpenAPI annotations&#10;- Database migrations live in src/main/resources/db/migration/&#10;&#10;## Build Commands&#10;- Build: ./gradlew build&#10;- Test: ./gradlew test&#10;- Lint: ./gradlew spotlessCheck"></textarea>
                    </div>
                </AdditionalFields>
            </GitLabProviderForm>
        }
        else
        {
            <GitHubAppProviderForm
                SectionTitle="Repository Provider"
                DisplayNamePlaceholder="My GitHub Repo"
                IsEditing="@(_editingProvider is not null)"
                ProviderType="@_form.ProviderType" ProviderTypeChanged="OnProviderTypeChanged"
                DisplayName="@_form.DisplayName" DisplayNameChanged="v => _form.DisplayName = v"
                ApiUrl="@_form.ApiUrl" ApiUrlChanged="v => _form.ApiUrl = v"
                ClientId="@_form.ClientId" ClientIdChanged="v => _form.ClientId = v"
                InstallationId="@_form.InstallationId" InstallationIdChanged="v => _form.InstallationId = v"
                PrivateKeyBase64="@_form.PrivateKeyBase64" PrivateKeyBase64Changed="v => _form.PrivateKeyBase64 = v"
                Owner="@_form.Owner" OwnerChanged="v => _form.Owner = v"
                Repo="@_form.Repo" RepoChanged="v => _form.Repo = v"
                AvailableRepos="_availableRepos"
                SelectedRepo="@_selectedRepo" SelectedRepoChanged="v => _selectedRepo = v"
                LoadingRepos="_loadingRepos"
                ValidationMessage="@_validationMessage"
                ValidationSuccess="_validationSuccess"
                Saving="_saving"
                OnSave="SaveProvider"
                OnCancel="CancelForm"
                OnFetchRepos="FetchRepos">
                <AdditionalFields>
                    <div class="form-group">
                        <label>Base Branch</label>
                        <input type="text" @bind="_form.BaseBranch" placeholder="@ProviderSettingKeys.DefaultBaseBranch" />
                    </div>
                    <div class="form-group">
                        <label>Repository Role</label>
                        <select @bind="_form.RepositoryRole">
                            <option value="Work">Work</option>
                            <option value="Brain">Brain</option>
                        </select>
                    </div>
                    @if (_form.RepositoryRole != "Brain")
                    {
                        <div class="form-group">
                            <label>Required Agent Labels <span class="form-hint">(comma-separated — determines agent routing and quality gates)</span></label>
                            <input type="text" @bind="_form.RequiredLabels" placeholder="e.g. kiro, dotnet, dotnet10" />
                        </div>
                        <div class="form-group">
                            <div class="label-with-hint">
                                <label>Blacklisted Paths</label>
                                <span class="form-hint-icon" aria-hidden="true" title="Comma-separated path prefixes excluded from agent commits (e.g. .kiro, .github). Leave empty to use global defaults.">?</span>
                            </div>
                            <input type="text" @bind="_form.BlacklistedPaths" placeholder=".kiro, .github, .brain" />
                        </div>
                        <Collapsible CssClass="secrets-section" HeaderClass="secrets-section-header" BodyClass="secrets-section-body"
                                     IsExpanded="_secretsExpanded" IsExpandedChanged="v => _secretsExpanded = v">
                            <Header>🔑 Secrets (@_form.Secrets.Count)</Header>
                            <ChildContent>
                                @for (var i = 0; i < _form.Secrets.Count; i++)
                                {
                                    var index = i;
                                    var secret = _form.Secrets[index];
                                    var isRevealed = _revealedSecrets.Contains(index);
                                    <div class="secret-row">
                                        <input type="text"
                                               class="secret-key-input"
                                               value="@secret.Key"
                                               @onchange="e => UpdateSecretKey(index, e.Value?.ToString() ?? string.Empty)"
                                               placeholder="ENV_VAR_NAME" />
                                        <input type="@(isRevealed ? "text" : "password")"
                                               class="secret-value-input"
                                               value="@secret.Value"
                                               @onchange="e => UpdateSecretValue(index, e.Value?.ToString() ?? string.Empty)"
                                               placeholder="secret value" />
                                        <button type="button" class="btn-icon" title="@(isRevealed ? "Hide" : "Reveal")" @onclick="() => ToggleSecretVisibility(index)">@(isRevealed ? "🙈" : "👁")</button>
                                        <button type="button" class="btn-icon btn-icon-danger" title="Remove" @onclick="() => RemoveSecret(index)">🗑</button>
                                    </div>
                                    @if (!string.IsNullOrEmpty(secret.ValidationError))
                                    {
                                        <div class="secret-validation-error">@secret.ValidationError</div>
                                    }
                                }
                                <button type="button" class="btn-add-inline" @onclick="AddSecret">+ Add Secret</button>
                            </ChildContent>
                        </Collapsible>
                        <Collapsible CssClass="setup-steps-section" HeaderClass="setup-steps-section-header" BodyClass="setup-steps-section-body"
                                     IsExpanded="_setupStepsExpanded" IsExpandedChanged="v => _setupStepsExpanded = v">
                            <Header>⚙️ Setup Steps (@_form.SetupSteps.Count)</Header>
                            <ChildContent>
                                <span class="form-hint">Each step runs as a full shell command via <code>/bin/bash -c</code> after clone. The name is a label for logs only.</span>
                                @for (var i = 0; i < _form.SetupSteps.Count; i++)
                                {
                                    var index = i;
                                    var step = _form.SetupSteps[index];
                                    <div class="setup-step-row">
                                        <div class="setup-step-header">
                                            <span class="setup-step-number">@(index + 1).</span>
                                            <input type="text"
                                                   class="setup-step-name-input"
                                                   value="@step.Name"
                                                   @onchange="e => UpdateSetupStepName(index, e.Value?.ToString() ?? string.Empty)"
                                                   placeholder="Label (e.g. Restore dependencies)" />
                                            <div class="setup-step-actions">
                                                <button type="button" class="btn-icon" title="Move up" disabled="@(index == 0)" @onclick="() => MoveSetupStepUp(index)">↑</button>
                                                <button type="button" class="btn-icon" title="Move down" disabled="@(index == _form.SetupSteps.Count - 1)" @onclick="() => MoveSetupStepDown(index)">↓</button>
                                                <button type="button" class="btn-icon btn-icon-danger" title="Remove" @onclick="() => RemoveSetupStep(index)">🗑</button>
                                            </div>
                                        </div>
                                        <textarea class="setup-step-command-input"
                                                  rows="2"
                                                  @onchange="e => UpdateSetupStepCommand(index, e.Value?.ToString() ?? string.Empty)"
                                                  placeholder="Full shell command (e.g. dotnet restore, npm install)">@step.Command</textarea>
                                        @if (!string.IsNullOrEmpty(step.ValidationError))
                                        {
                                            <div class="setup-step-validation-error">@step.ValidationError</div>
                                        }
                                    </div>
                                }
                                <button type="button" class="btn-add-inline" @onclick="AddSetupStep">+ Add Step</button>
                            </ChildContent>
                        </Collapsible>
                    }
                    <div class="form-group">
                        <label>Steering Instructions</label>
                        <p class="form-hint">These instructions are provided to agents working on this repository. Use them for repo-specific conventions like architecture constraints, build/test commands, or file organization rules.</p>
                        <textarea @bind="_form.SteeringContent" rows="15" placeholder="## Architecture&#10;- This is a Spring Boot application using Gradle&#10;- All REST endpoints require OpenAPI annotations&#10;- Database migrations live in src/main/resources/db/migration/&#10;&#10;## Build Commands&#10;- Build: ./gradlew build&#10;- Test: ./gradlew test&#10;- Lint: ./gradlew spotlessCheck"></textarea>
                    </div>
                </AdditionalFields>
                <HelpContent>
                    <h4>🔐 GitHub App Setup</h4>
                    <p>Configure a <strong>GitHub App</strong> for authentication. See
                        <a href="https://docs.github.com/en/apps/creating-github-apps/registering-a-github-app/registering-a-github-app" target="_blank">GitHub App docs</a>.</p>
                    <p class="help-heading">Required permissions:</p>
                    <ul>
                        <li><strong>Contents: Read &amp; write</strong> — clone, push branches, commit</li>
                        <li><strong>Pull requests: Read &amp; write</strong> — create PRs</li>
                    </ul>
                    <p class="help-heading">Fields:</p>
                    <ul>
                        <li><strong>Client ID</strong> — from the App's General settings page (e.g. <code>Iv1.abc123...</code>)</li>
                        <li><strong>Installation ID</strong> — from the installation URL (<code>github.com/settings/installations/{'{'}id{'}'}</code>)</li>
                        <li><strong>Private Key</strong> — upload the .pem file downloaded from the App's settings</li>
                        <li><strong>API URL</strong> — use <code>https://api.github.com</code> for github.com, or your GitHub Enterprise URL</li>
                        <li><strong>Base Branch</strong> — the branch PRs will target (e.g. <code>main</code>, <code>develop</code>)</li>
                    </ul>
                    <p class="help-tip">💡 Use the same GitHub App as the Issue Provider — just ensure it has Contents and Pull requests permissions.</p>
                </HelpContent>
            </GitHubAppProviderForm>
        }
    }
    else
    {
        <button class="btn-add" @onclick="ShowAddForm">+ Add Repository Provider</button>
    }
</section>

@code {
    [Parameter, EditorRequired] public List<ProviderConfig> Providers { get; set; } = new();
    [Parameter, EditorRequired] public IConfigurationStore ConfigStore { get; set; } = default!;
    [Parameter, EditorRequired] public GitHubValidationService GitHubValidator { get; set; } = default!;
    [Parameter] public GitLabValidationService? GitLabValidator { get; set; }
    [Parameter] public EventCallback<string> OnDelete { get; set; }
    [Parameter] public EventCallback<ProviderConfig> OnSaved { get; set; }

    private bool _showForm;
    private ProviderConfig? _editingProvider;
    private RepoProviderForm _form = new();
    private List<(string FullName, string Owner, string Name)> _availableRepos = new();
    private string _selectedRepo = "";
    private bool _loadingRepos;
    private string? _validationMessage;
    private bool _validationSuccess;
    private bool _saving;
    private HashSet<int> _revealedSecrets = new();
    private bool _secretsExpanded;
    private bool _setupStepsExpanded;
    private bool _showDeleteConfirm;
    private string? _deletingProviderId;

    private static readonly Regex SecretKeyPattern = new(@"^[A-Za-z_][A-Za-z0-9_]*$", RegexOptions.Compiled);

    private void ShowAddForm()
    {
        _editingProvider = null;
        _form = new RepoProviderForm();
        _availableRepos.Clear();
        _selectedRepo = "";
        _validationMessage = null;
        _revealedSecrets.Clear();
        _showForm = true;
    }

    private void EditProvider(ProviderConfig p)
    {
        _editingProvider = p;
        _form = new RepoProviderForm
        {
            ProviderType = p.ProviderType,
            DisplayName = p.DisplayName,
            ApiUrl = p.Settings.GetValueOrDefault(ProviderSettingKeys.ApiUrl, ""),
            ClientId = p.Settings.GetValueOrDefault(ProviderSettingKeys.ClientId, ""),
            InstallationId = p.Settings.GetValueOrDefault(ProviderSettingKeys.InstallationId, ""),
            PrivateKeyBase64 = p.Settings.GetValueOrDefault(ProviderSettingKeys.PrivateKeyBase64, ""),
            Owner = p.Settings.GetValueOrDefault(ProviderSettingKeys.Owner, ""),
            Repo = p.Settings.GetValueOrDefault(ProviderSettingKeys.Repo, ""),
            BaseBranch = p.Settings.GetValueOrDefault(ProviderSettingKeys.BaseBranch, ProviderSettingKeys.DefaultBaseBranch),
            RepositoryRole = p.RepositoryRole.ToString(),
            RequiredLabels = p.RequiredLabels != null ? string.Join(", ", p.RequiredLabels) : p.Settings.GetValueOrDefault(ProviderSettingKeys.RequiredAgentLabels, ""),
            BlacklistedPaths = p.BlacklistedPaths != null ? string.Join(", ", p.BlacklistedPaths) : "",
            GitLabApiUrl = p.Settings.GetValueOrDefault(ProviderSettingKeys.ApiUrl, ProviderSettingKeys.DefaultGitLabApiUrl),
            GitLabAccessToken = p.Settings.GetValueOrDefault(ProviderSettingKeys.AccessToken, ""),
            GitLabProjectId = p.Settings.GetValueOrDefault(ProviderSettingKeys.ProjectId, ""),
            Secrets = p.Secrets?.Select(kv => new SecretEntry { Key = kv.Key, Value = kv.Value }).ToList() ?? new(),
            SetupSteps = p.SetupSteps?.Select(s => new SetupStepEntry { Name = s.Name, Command = s.Command }).ToList() ?? new(),
            SteeringContent = p.SteeringContent
        };
        _revealedSecrets.Clear();
        _showForm = true;
    }

    private async Task SaveProvider()
    {
        if (string.IsNullOrWhiteSpace(_form.DisplayName))
        {
            _validationMessage = "Display Name is required.";
            _validationSuccess = false;
            return;
        }

        if (!string.IsNullOrEmpty(_selectedRepo))
        {
            var selected = _availableRepos.FirstOrDefault(r => r.FullName == _selectedRepo);
            if (selected != default)
            {
                _form.Owner = selected.Owner;
                _form.Repo = selected.Name;
            }
        }

        if (string.IsNullOrWhiteSpace(_form.Owner) || string.IsNullOrWhiteSpace(_form.Repo))
        {
            _validationMessage = "Owner and Repository are required.";
            _validationSuccess = false;
            return;
        }

        _saving = true;
        _validationMessage = "Validating GitHub App credentials...";
        _validationSuccess = true;
        StateHasChanged();

        if (!long.TryParse(_form.InstallationId, out var installationId))
        {
            _validationMessage = "Installation ID must be a valid number.";
            _validationSuccess = false;
            _saving = false;
            return;
        }

        var (success, message) = await GitHubValidator.ValidateAppCredentialsAsync(
            _form.ApiUrl, _form.ClientId, installationId, _form.PrivateKeyBase64, CancellationToken.None,
            _form.Owner, _form.Repo);

        if (!success)
        {
            _validationMessage = message;
            _validationSuccess = false;
            _saving = false;
            return;
        }

        if (!ValidateSecrets())
        {
            _saving = false;
            return;
        }

        if (!ValidateSetupSteps())
        {
            _saving = false;
            return;
        }

        var config = new ProviderConfig
        {
            Id = _editingProvider?.Id ?? Guid.NewGuid().ToString(),
            Kind = ProviderKind.Repository,
            ProviderType = _form.ProviderType,
            DisplayName = _form.DisplayName,
            RepositoryRole = Enum.TryParse<RepositoryRole>(_form.RepositoryRole, out var role) ? role : RepositoryRole.Work,
            RequiredLabels = ParseLabels(_form.RequiredLabels),
            BlacklistedPaths = ParseBlacklistedPaths(_form.BlacklistedPaths),
            Secrets = BuildSecretsDictionary(),
            SetupSteps = BuildSetupStepsList(),
            SteeringContent = string.IsNullOrWhiteSpace(_form.SteeringContent) ? null : _form.SteeringContent.Trim(),
            Settings = new Dictionary<string, string>
            {
                [ProviderSettingKeys.ApiUrl] = _form.ApiUrl,
                [ProviderSettingKeys.ClientId] = _form.ClientId,
                [ProviderSettingKeys.InstallationId] = _form.InstallationId,
                [ProviderSettingKeys.PrivateKeyBase64] = _form.PrivateKeyBase64,
                [ProviderSettingKeys.Owner] = _form.Owner,
                [ProviderSettingKeys.Repo] = _form.Repo,
                [ProviderSettingKeys.BaseBranch] = _form.BaseBranch
            }
        };

        try
        {
            await ConfigStore.SaveProviderConfigAsync(config, CancellationToken.None);
            _showForm = false;
            _availableRepos.Clear();
            _validationMessage = null;
            await OnSaved.InvokeAsync(config);
        }
        catch (Exception ex)
        {
            _validationMessage = $"Failed to save: {ex.Message}";
            _validationSuccess = false;
        }
        finally
        {
            _saving = false;
        }
    }

    private void CancelForm()
    {
        _showForm = false;
        _availableRepos.Clear();
        _validationMessage = null;
        _revealedSecrets.Clear();
    }

    private async Task FetchRepos()
    {
        if (string.IsNullOrWhiteSpace(_form.ClientId) || string.IsNullOrWhiteSpace(_form.InstallationId)
            || string.IsNullOrWhiteSpace(_form.PrivateKeyBase64))
        {
            _validationMessage = "Enter Client ID, Installation ID, and Private Key first.";
            _validationSuccess = false;
            return;
        }

        if (!long.TryParse(_form.InstallationId, out var installationId))
        {
            _validationMessage = "Installation ID must be a valid number.";
            _validationSuccess = false;
            return;
        }

        _loadingRepos = true;
        _validationMessage = null;
        StateHasChanged();

        var (credOk, credMsg) = await GitHubValidator.ValidateAppCredentialsAsync(
            _form.ApiUrl, _form.ClientId, installationId, _form.PrivateKeyBase64, CancellationToken.None);
        if (!credOk)
        {
            _validationMessage = credMsg;
            _validationSuccess = false;
            _loadingRepos = false;
            return;
        }

        var repos = await GitHubValidator.ListRepositoriesWithAppAsync(
            _form.ApiUrl, _form.ClientId, installationId, _form.PrivateKeyBase64, CancellationToken.None);
        _availableRepos = repos.ToList();
        _validationMessage = $"{credMsg} — {repos.Count} repositories found";
        _validationSuccess = true;
        _loadingRepos = false;
    }

    private class RepoProviderForm
    {
        public string ProviderType { get; set; } = "GitHub";
        public string DisplayName { get; set; } = "";
        public string ApiUrl { get; set; } = ProviderSettingKeys.DefaultApiUrl;
        public string ClientId { get; set; } = "";
        public string InstallationId { get; set; } = "";
        public string PrivateKeyBase64 { get; set; } = "";
        public string Owner { get; set; } = "";
        public string Repo { get; set; } = "";
        public string BaseBranch { get; set; } = ProviderSettingKeys.DefaultBaseBranch;
        public string RepositoryRole { get; set; } = "Work";
        public string RequiredLabels { get; set; } = "";
        public string BlacklistedPaths { get; set; } = "";
        public List<SecretEntry> Secrets { get; set; } = new();
        public List<SetupStepEntry> SetupSteps { get; set; } = new();
        public string? SteeringContent { get; set; }
        // GitLab-specific fields
        public string GitLabApiUrl { get; set; } = ProviderSettingKeys.DefaultGitLabApiUrl;
        public string GitLabAccessToken { get; set; } = "";
        public string GitLabProjectId { get; set; } = "";
    }

    private class SecretEntry
    {
        public string Key { get; set; } = "";
        public string Value { get; set; } = "";
        public string? ValidationError { get; set; }
    }

    private class SetupStepEntry
    {
        public string Name { get; set; } = "";
        public string Command { get; set; } = "";
        public string? ValidationError { get; set; }
    }

    private void OnProviderTypeChanged(string newType)
    {
        _form.ProviderType = newType;
        _validationMessage = null;
        StateHasChanged();
    }

    private async Task SaveGitLabProvider()
    {
        if (string.IsNullOrWhiteSpace(_form.DisplayName))
        {
            _validationMessage = "Display Name is required.";
            _validationSuccess = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(_form.GitLabAccessToken))
        {
            _validationMessage = "Access Token is required.";
            _validationSuccess = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(_form.GitLabProjectId))
        {
            _validationMessage = "Project ID is required.";
            _validationSuccess = false;
            return;
        }

        _saving = true;
        _validationMessage = "Validating GitLab credentials...";
        _validationSuccess = true;
        StateHasChanged();

        try
        {
            var apiUrl = string.IsNullOrWhiteSpace(_form.GitLabApiUrl)
                ? ProviderSettingKeys.DefaultGitLabApiUrl
                : _form.GitLabApiUrl;

            if (GitLabValidator is not null)
            {
                var result = await GitLabValidator.ValidateAsync(
                    apiUrl, _form.GitLabAccessToken, _form.GitLabProjectId, CancellationToken.None);

                if (!result.Success)
                {
                    _validationMessage = result.ErrorMessage;
                    _validationSuccess = false;
                    _saving = false;
                    return;
                }

                _validationMessage = $"✅ Connected to {result.ProjectPath} (access: {result.AccessLevel})";
                _validationSuccess = true;
            }

            var baseBranch = string.IsNullOrWhiteSpace(_form.BaseBranch)
                ? ProviderSettingKeys.DefaultBaseBranch
                : _form.BaseBranch;

            if (!ValidateSecrets())
            {
                _saving = false;
                return;
            }

            if (!ValidateSetupSteps())
            {
                _saving = false;
                return;
            }

            var config = new ProviderConfig
            {
                Id = _editingProvider?.Id ?? Guid.NewGuid().ToString(),
                Kind = ProviderKind.Repository,
                ProviderType = "GitLab",
                DisplayName = _form.DisplayName,
                RepositoryRole = Enum.TryParse<RepositoryRole>(_form.RepositoryRole, out var role) ? role : RepositoryRole.Work,
                RequiredLabels = ParseLabels(_form.RequiredLabels),
                BlacklistedPaths = ParseBlacklistedPaths(_form.BlacklistedPaths),
                Secrets = BuildSecretsDictionary(),
                SetupSteps = BuildSetupStepsList(),
                SteeringContent = string.IsNullOrWhiteSpace(_form.SteeringContent) ? null : _form.SteeringContent.Trim(),
                Settings = new Dictionary<string, string>
                {
                    [ProviderSettingKeys.ApiUrl] = apiUrl,
                    [ProviderSettingKeys.AccessToken] = _form.GitLabAccessToken,
                    [ProviderSettingKeys.ProjectId] = _form.GitLabProjectId,
                    [ProviderSettingKeys.BaseBranch] = baseBranch
                }
            };

            await ConfigStore.SaveProviderConfigAsync(config, CancellationToken.None);
            _showForm = false;
            _availableRepos.Clear();
            _validationMessage = null;
            await OnSaved.InvokeAsync(config);
        }
        catch (Exception ex)
        {
            _validationMessage = $"Failed to save: {ex.Message}";
            _validationSuccess = false;
        }
        finally
        {
            _saving = false;
        }
    }

    private static IReadOnlyList<string>? ParseLabels(string? input)
    {
        if (string.IsNullOrWhiteSpace(input)) return null;
        var labels = input.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(l => !string.IsNullOrWhiteSpace(l))
            .ToList();
        return labels.Count > 0 ? labels : null;
    }

    private static IReadOnlyList<string>? ParseBlacklistedPaths(string? input)
    {
        if (string.IsNullOrWhiteSpace(input)) return null;
        var paths = input.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .ToList();
        return paths.Count > 0 ? paths : null;
    }

    // --- Secrets management ---

    private void AddSecret()
    {
        _form.Secrets.Add(new SecretEntry());
    }

    private void RemoveSecret(int index)
    {
        if (index >= 0 && index < _form.Secrets.Count)
        {
            _form.Secrets.RemoveAt(index);
            // Rebuild revealed set since indices shifted
            var newRevealed = new HashSet<int>();
            foreach (var i in _revealedSecrets)
            {
                if (i < index) newRevealed.Add(i);
                else if (i > index) newRevealed.Add(i - 1);
            }
            _revealedSecrets = newRevealed;
        }
    }

    private void UpdateSecretKey(int index, string value)
    {
        if (index >= 0 && index < _form.Secrets.Count)
        {
            _form.Secrets[index].Key = value;
            _form.Secrets[index].ValidationError = null;
        }
    }

    private void UpdateSecretValue(int index, string value)
    {
        if (index >= 0 && index < _form.Secrets.Count)
        {
            _form.Secrets[index].Value = value;
        }
    }

    private void ToggleSecretVisibility(int index)
    {
        if (!_revealedSecrets.Remove(index))
            _revealedSecrets.Add(index);
    }

    private bool ValidateSecrets()
    {
        if (_form.Secrets.Count == 0) return true;

        var isValid = true;
        var seenKeys = new HashSet<string>(StringComparer.Ordinal);

        foreach (var secret in _form.Secrets)
        {
            secret.ValidationError = null;

            if (string.IsNullOrWhiteSpace(secret.Key))
            {
                secret.ValidationError = "Key is required.";
                isValid = false;
                continue;
            }

            if (!SecretKeyPattern.IsMatch(secret.Key))
            {
                secret.ValidationError = "Key must match POSIX env var pattern (letters, digits, underscores; cannot start with digit).";
                isValid = false;
                continue;
            }

            if (!seenKeys.Add(secret.Key))
            {
                secret.ValidationError = "Duplicate key.";
                isValid = false;
            }
        }

        if (!isValid)
        {
            _validationMessage = "Fix secret key errors before saving.";
            _validationSuccess = false;
        }

        return isValid;
    }

    private Dictionary<string, string>? BuildSecretsDictionary()
    {
        if (_form.Secrets.Count == 0) return null;
        var dict = new Dictionary<string, string>();
        foreach (var secret in _form.Secrets)
        {
            if (!string.IsNullOrWhiteSpace(secret.Key))
                dict[secret.Key] = secret.Value;
        }
        return dict.Count > 0 ? dict : null;
    }

    // --- Setup Steps management ---

    private void AddSetupStep()
    {
        _form.SetupSteps.Add(new SetupStepEntry());
    }

    private void RemoveSetupStep(int index)
    {
        if (index >= 0 && index < _form.SetupSteps.Count)
        {
            _form.SetupSteps.RemoveAt(index);
        }
    }

    private void MoveSetupStepUp(int index)
    {
        if (index > 0 && index < _form.SetupSteps.Count)
        {
            (_form.SetupSteps[index - 1], _form.SetupSteps[index]) = (_form.SetupSteps[index], _form.SetupSteps[index - 1]);
        }
    }

    private void MoveSetupStepDown(int index)
    {
        if (index >= 0 && index < _form.SetupSteps.Count - 1)
        {
            (_form.SetupSteps[index], _form.SetupSteps[index + 1]) = (_form.SetupSteps[index + 1], _form.SetupSteps[index]);
        }
    }

    private void UpdateSetupStepName(int index, string value)
    {
        if (index >= 0 && index < _form.SetupSteps.Count)
        {
            _form.SetupSteps[index].Name = value;
            _form.SetupSteps[index].ValidationError = null;
        }
    }

    private void UpdateSetupStepCommand(int index, string value)
    {
        if (index >= 0 && index < _form.SetupSteps.Count)
        {
            _form.SetupSteps[index].Command = value;
            _form.SetupSteps[index].ValidationError = null;
        }
    }

    private bool ValidateSetupSteps()
    {
        if (_form.SetupSteps.Count == 0) return true;

        var isValid = true;

        foreach (var step in _form.SetupSteps)
        {
            step.ValidationError = null;

            if (string.IsNullOrWhiteSpace(step.Name) && string.IsNullOrWhiteSpace(step.Command))
            {
                step.ValidationError = "Name and command are required.";
                isValid = false;
            }
            else if (string.IsNullOrWhiteSpace(step.Name))
            {
                step.ValidationError = "Step name is required.";
                isValid = false;
            }
            else if (string.IsNullOrWhiteSpace(step.Command))
            {
                step.ValidationError = "Command is required.";
                isValid = false;
            }
        }

        if (!isValid)
        {
            _validationMessage = "Fix setup step errors before saving.";
            _validationSuccess = false;
        }

        return isValid;
    }

    private IReadOnlyList<SetupStep>? BuildSetupStepsList()
    {
        if (_form.SetupSteps.Count == 0) return null;
        var steps = _form.SetupSteps
            .Where(s => !string.IsNullOrWhiteSpace(s.Name) && !string.IsNullOrWhiteSpace(s.Command))
            .Select(s => new SetupStep { Name = s.Name.Trim(), Command = s.Command.Trim() })
            .ToList();
        return steps.Count > 0 ? steps : null;
    }
}
