@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models
@inherits DispatchDrawerBase<IssueSummary>

<div class="dispatch-drawer-overlay @(IsOpen ? "open" : "")" @onclick="Close"></div>
<aside class="dispatch-drawer @(IsOpen ? "open" : "")">
    @if (HeaderPrefix != null) { @HeaderPrefix }
    <div class="agent-detail-header">
        <h3>Select Epic for Decomposition</h3>
        <button class="agent-detail-close" @onclick="Close" aria-label="Close drawer">✕</button>
    </div>

    @if (Template != null)
    {
        <div class="agent-detail-section">
            <h4>Template: @Template.Name</h4>
        </div>

        @if (IsLoading)
        {
            <div class="loading-text" style="padding: 12px;">Loading epics...</div>
        }
        else
        {
            <div style="padding: 0 0 8px;">
                <input type="text" @bind="_filter" @bind:event="oninput" @bind:after="ApplyFilter"
                       placeholder="Filter by number or title..." style="width: 100%; padding: 6px 10px; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); font-size: 0.82rem;" />
            </div>

            @if (AvailableLabels.Count > 0)
            {
                <div class="drawer-label-filter" style="padding: 0 0 8px;">
                    <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 4px;">
                        <span style="font-size: 0.75rem; color: var(--text-muted);">Labels:</span>
                        @if (SelectedLabels.Count > 0)
                        {
                            <button class="btn-link" style="font-size: 0.72rem; padding: 0; color: var(--accent);" @onclick="ClearLabels">Clear</button>
                        }
                    </div>
                    <div style="display: flex; flex-wrap: wrap; gap: 4px; max-height: 72px; overflow-y: auto;">
                        @foreach (var label in AvailableLabels)
                        {
                            var isActive = SelectedLabels.Contains(label);
                            <button class="sidebar-label @UiFormatters.GetLabelClass(label) @(isActive ? "label-active" : "label-inactive")"
                                    style="cursor: pointer; font-size: 0.72rem; padding: 2px 6px; border: 1px solid @(isActive ? "var(--accent)" : "transparent"); opacity: @(isActive ? "1" : "0.7");"
                                    @onclick="() => ToggleLabel(label)">
                                @label
                            </button>
                        }
                    </div>
                </div>
            }

            @if (Issues.Count == 0)
            {
                <div class="monitoring-empty">No epics found.</div>
            }
            else
            {
                @* TODO: max-height was changed from 380px to 320px — verify this unrelated CSS change is intentional *@
                <div class="agent-history-list" tabindex="0" @onkeydown="HandleKeyDown" @onkeydown:preventDefault="ShouldPreventDefault"
                     style="max-height: calc(100vh - 320px); overflow-y: auto;">
                    @{ var idx = 0; }
                    @foreach (var issue in FilteredItems)
                    {
                        var isProcessing = IsBeingProcessed(issue.Identifier);
                        var isApproved = issue.Labels.Contains("agent:epic-approved", StringComparer.OrdinalIgnoreCase);
                        var currentIdx = idx;
                        <div class="drawer-issue-item @(isProcessing ? "drawer-issue-dispatched" : "") @(SelectedItem?.Identifier == issue.Identifier ? "drawer-issue-selected" : "") @GetHighlightClass(currentIdx)"
                             @onclick="() => SelectItem(issue)"
                             data-testid="epic-row-@issue.Identifier"
                             style="@(isProcessing ? "opacity: 0.6; pointer-events: none;" : "")">
                            <div class="drawer-issue-header">
                                <span class="drawer-issue-number">#@issue.Identifier</span>
                                @if (isApproved)
                                {
                                    <span class="badge-default" style="background: #0e8a16; color: white; font-size: 0.7rem;"><Icon Name="puzzle" Size="12" /> Create Sub-Issues</span>
                                }
                                else
                                {
                                    <span class="badge-default" style="background: #7057ff; color: white; font-size: 0.7rem;"><Icon Name="search" Size="12" /> Analysis</span>
                                }
                                @if (isProcessing)
                                {
                                    <span class="badge-default" style="background: var(--accent); color: white;">DISPATCHED</span>
                                }
                            </div>
                            <div class="drawer-issue-title">@issue.Title</div>
                            <div class="drawer-issue-labels">
                                @foreach (var label in issue.Labels.Take(5))
                                {
                                    <span class="sidebar-label @UiFormatters.GetLabelClass(label)">@label</span>
                                }
                            </div>
                        </div>
                        idx++;
                    }
                </div>

                @if (HasMore || Page > 1)
                {
                    <div style="display: flex; justify-content: center; gap: 8px; padding: 8px 0;">
                        <button class="btn-page" @onclick="PrevPage" disabled="@(Page <= 1)">← Prev</button>
                        <span class="monitoring-muted" style="align-self: center; font-size: 0.8rem;">Page @Page</span>
                        <button class="btn-page" @onclick="NextPage" disabled="@(!HasMore)">Next →</button>
                    </div>
                }
            }

            @if (SelectedItem != null)
            {
                var selectedIsApproved = SelectedItem.Labels.Contains("agent:epic-approved", StringComparer.OrdinalIgnoreCase);
                <div class="agent-detail-section" style="margin-top: 12px; border-top: 1px solid var(--border); padding-top: 12px;">
                    <h4>#@SelectedItem.Identifier — @SelectedItem.Title</h4>
                    <div class="drawer-issue-labels" style="margin-bottom: 8px;">
                        @foreach (var label in SelectedItem.Labels)
                        {
                            <span class="sidebar-label @UiFormatters.GetLabelClass(label)">@label</span>
                        }
                    </div>
                    <div style="margin-bottom: 8px; font-size: 0.8rem; font-weight: 500;">
                        @if (selectedIsApproved)
                        {
                            <span style="color: #0e8a16;"><Icon Name="puzzle" Size="14" /> Phase 2: Create Sub-Issues (Decomposition)</span>
                        }
                        else
                        {
                            <span style="color: #7057ff;"><Icon Name="search" Size="14" /> Phase 1: Analysis (DecompositionAnalysis)</span>
                        }
                    </div>
                    @if (SelectedItem.CreatedAt.HasValue)
                    {
                        <p style="font-size: 0.78rem; color: var(--text-muted); margin: 0 0 8px;">
                            Created: @SelectedItem.CreatedAt.Value.ToLocalTime().ToString("g")
                        </p>
                    }
                    <button class="btn-save" @onclick="DispatchSelected" disabled="@IsDispatching"
                            data-testid="dispatch-epic-btn"
                            style="background: #7057ff;">
                        @(IsDispatching ? "Dispatching..." : $"Start Decomposition on #{SelectedItem.Identifier}")
                    </button>
                </div>
            }
        }
    }
</aside>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<IssueSummary> Issues { get; set; } = [];
    [Parameter, EditorRequired] public bool HasMore { get; set; }
    [Parameter, EditorRequired] public int Page { get; set; }
    [Parameter] public EventCallback OnNextPage { get; set; }
    [Parameter] public EventCallback OnPrevPage { get; set; }
    [Parameter] public IReadOnlyList<string> AvailableLabels { get; set; } = [];
    [Parameter] public IReadOnlyList<string> SelectedLabels { get; set; } = [];
    [Parameter] public EventCallback<string> OnToggleLabel { get; set; }
    [Parameter] public EventCallback OnClearLabels { get; set; }

    private bool ShouldPreventDefault => false;

    protected override void OnParametersSet()
    {
        Items = Issues;
        base.OnParametersSet();
    }

    protected override bool MatchesFilter(IssueSummary item, string filter) =>
        item.Identifier.Contains(filter, StringComparison.OrdinalIgnoreCase)
        || item.Title.Contains(filter, StringComparison.OrdinalIgnoreCase);

    protected override string GetIdentifier(IssueSummary item) => item.Identifier;

    private async Task NextPage() => await OnNextPage.InvokeAsync();
    private async Task PrevPage() => await OnPrevPage.InvokeAsync();
    private async Task ToggleLabel(string label) => await OnToggleLabel.InvokeAsync(label);
    private async Task ClearLabels() => await OnClearLabels.InvokeAsync();
}
