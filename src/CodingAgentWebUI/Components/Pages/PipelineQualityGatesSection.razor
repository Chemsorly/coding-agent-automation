@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models

<section class="settings-section">
    <h2>Quality Gates</h2>
    <p class="section-description">Pipeline-level quality settings — code review, external CI integration, and stall detection. Per-stack build/test commands are in Quality Gate Configurations.</p>
    <div class="provider-form">
        <div class="form-group form-checkbox">
            <label>
                <input type="checkbox" @bind="_codeReviewEnabled" />
                Agent Code Review Enabled
            </label>
        </div>
        @if (_codeReviewEnabled)
        {
            <div class="config-sub-fields">
                <div class="form-hint" style="margin-bottom: 0.75rem;">
                    ℹ️ Review agents are configured in Settings → Reviewer Configs.
                </div>
                <div class="form-group">
                    <label>Max Review Iterations</label>
                    <input type="number" @bind="_codeReviewMaxIterations" min="1" max="5" />
                </div>
                <div class="form-group">
                    <label>Fix Prompt <span class="form-hint">(leave empty for single-pass review)</span></label>
                    <textarea @bind="_codeReviewFixPrompt" rows="3"></textarea>
                    <button type="button" class="btn-revert" disabled="@(_codeReviewFixPrompt == PipelineConfiguration.DefaultFixPrompt)" @onclick="() => _codeReviewFixPrompt = PipelineConfiguration.DefaultFixPrompt">Reset to default</button>
                </div>
            </div>
        }
        <div class="config-sub-fields" style="margin-top: 1rem;">
            <h3 style="margin-bottom: 0.5rem;">External CI Settings</h3>
            <div class="form-hint" style="margin-bottom: 0.75rem;">
                ℹ️ External CI runs automatically when a Pipeline Provider is configured on the job template.
            </div>
            <div class="form-group">
                <label>CI Timeout (minutes)</label>
                <input type="number" @bind="_externalCiTimeoutMinutes" min="1" max="60" />
            </div>
            <div class="form-group">
                <label>CI Poll Interval (seconds)</label>
                <input type="number" @bind="_externalCiPollIntervalSeconds" min="10" max="300" />
            </div>
        </div>
        <div class="pipeline-form-actions">
            <button class="btn-save" @onclick="SaveAsync">Save Quality Gate Settings</button>
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public IConfigurationStore ConfigStore { get; set; } = default!;
    // TODO: PipelineProviderCount parameter is dead code after removing the External CI checkbox — clean up here and in parent Settings.razor
    [Parameter] public int PipelineProviderCount { get; set; }
    [Parameter] public EventCallback<(string Message, bool IsError)> OnShowStatus { get; set; }

    private bool _codeReviewEnabled = true;
    private int _codeReviewMaxIterations = 1;
    private string? _codeReviewFixPrompt;
    private int _externalCiTimeoutMinutes = 15;
    private int _externalCiPollIntervalSeconds = 30;

    protected override async Task OnInitializedAsync()
    {
        var config = await ConfigStore.LoadPipelineConfigAsync(CancellationToken.None);
        _codeReviewEnabled = config.CodeReview.MaxIterations > 0;
        _codeReviewMaxIterations = config.CodeReview.MaxIterations;
        _codeReviewFixPrompt = config.CodeReview.FixPrompt;
        _externalCiTimeoutMinutes = (int)config.ExternalCiTimeout.TotalMinutes;
        _externalCiPollIntervalSeconds = (int)config.ExternalCiPollInterval.TotalSeconds;
    }

    private async Task SaveAsync()
    {
        try
        {
            await ConfigStore.UpdatePipelineConfigAsync(
                current => current with
                {
                    CodeReview = new CodeReviewConfiguration
                    {
                        MaxIterations = _codeReviewEnabled ? Math.Max(1, _codeReviewMaxIterations) : 0,
                        FixPrompt = _codeReviewFixPrompt,
                    },
                    ExternalCiTimeout = TimeSpan.FromMinutes(_externalCiTimeoutMinutes),
                    ExternalCiPollInterval = TimeSpan.FromSeconds(_externalCiPollIntervalSeconds)
                },
                CancellationToken.None);
            await OnShowStatus.InvokeAsync(("Quality gate settings saved.", false));
        }
        catch (Exception ex)
        {
            await OnShowStatus.InvokeAsync(($"Failed to save: {ex.Message}", true));
        }
    }
}
