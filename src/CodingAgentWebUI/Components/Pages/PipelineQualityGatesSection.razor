@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models

<section class="settings-section">
    <h2>Implementation</h2>
    <p class="section-description">Implementation pipeline settings — agent code review iterations, fix prompts, and external CI integration.</p>
    <div class="provider-form">
        <div class="config-sub-fields">
            <h3>External CI Settings</h3>
            <div class="form-hint">
                <Icon Name="info" /> External CI runs automatically when a Pipeline Provider is configured on the job template.
            </div>
            <div class="form-group">
                <div class="label-with-hint">
                    <label>CI Timeout (minutes)</label>
                    <span class="form-hint-icon" aria-hidden="true" title="Maximum time to wait for external CI checks to complete before marking as timed out. Default: 15 min">?</span>
                </div>
                <input type="number" @bind="_externalCiTimeoutMinutes" min="1" />
            </div>
            <div class="form-group">
                <div class="label-with-hint">
                    <label>CI Poll Interval (seconds)</label>
                    <span class="form-hint-icon" aria-hidden="true" title="How often the pipeline checks CI status while waiting for completion. Default: 30s">?</span>
                </div>
                <input type="number" @bind="_externalCiPollIntervalSeconds" min="10" max="300" />
            </div>
            <div class="form-group">
                <div class="label-with-hint">
                    <label>CI Not Started Timeout (minutes)</label>
                    <span class="form-hint-icon" aria-hidden="true" title="How long to wait for CI runs to appear before concluding CI never started and re-pushing. Prevents burning the full CI timeout when GitHub Actions fails to trigger. Default: 5 min">?</span>
                </div>
                <input type="number" @bind="_ciNotStartedTimeoutMinutes" min="1" max="30" />
            </div>
            <div class="form-group">
                <div class="label-with-hint">
                    <label>CI Not Started Max Retries</label>
                    <span class="form-hint-icon" aria-hidden="true" title="Maximum re-push retries when CI never starts. Each retry creates an empty commit and force-pushes to re-trigger GitHub Actions. Default: 5">?</span>
                </div>
                <input type="number" @bind="_ciNotStartedMaxRetries" min="0" max="20" />
            </div>
        </div>
        <div class="advanced-toggle" @onclick="() => _showAdvanced = !_showAdvanced">
            <span class="toggle-chevron @(_showAdvanced ? "expanded" : "")"><Icon Name="chevron-right" /></span>
            <span>Advanced settings</span>
        </div>
        @if (_showAdvanced)
        {
        <div class="form-group form-checkbox">
            <label>
                <input type="checkbox" @bind="_codeReviewEnabled" />
                Agent Code Review Enabled
            </label>
        </div>
        @if (_codeReviewEnabled)
        {
            <div class="config-sub-fields">
                <div class="form-hint">
                    <Icon Name="info" /> Review agents are configured in Settings → Reviewer Configs.
                </div>
                <div class="form-group">
                    <div class="label-with-hint">
                        <label>Max Review Iterations</label>
                        <span class="form-hint-icon" aria-hidden="true" title="Maximum review/fix cycles. Each iteration runs all reviewers, then applies fixes if [CRITICAL] findings exist. Default: 2">?</span>
                    </div>
                    <input type="number" @bind="_codeReviewMaxIterations" min="1" max="5" />
                </div>
                <div class="form-group">
                    <label>Fix Prompt <span class="form-hint">(leave empty for single-pass review)</span></label>
                    <textarea @bind="_codeReviewFixPrompt" rows="3"></textarea>
                    <button type="button" class="btn-revert" disabled="@(_codeReviewFixPrompt == PipelineConfiguration.DefaultFixPrompt)" @onclick="() => _codeReviewFixPrompt = PipelineConfiguration.DefaultFixPrompt">Reset to default</button>
                </div>
            </div>
        }
        }
        <div class="pipeline-form-actions">
            <button class="btn-save" @onclick="SaveAsync">Save Implementation Settings</button>
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public IConfigurationStore ConfigStore { get; set; } = default!;
    [Parameter] public EventCallback<(string Message, bool IsError)> OnShowStatus { get; set; }

    private bool _codeReviewEnabled = true;
    private int _codeReviewMaxIterations = 1;
    private string? _codeReviewFixPrompt;
    private int _externalCiTimeoutMinutes = 15;
    private int _externalCiPollIntervalSeconds = 30;
    private int _ciNotStartedTimeoutMinutes = 5;
    private int _ciNotStartedMaxRetries = 5;
    private bool _showAdvanced;

    protected override async Task OnInitializedAsync()
    {
        var config = await ConfigStore.LoadPipelineConfigAsync(CancellationToken.None);
        _codeReviewEnabled = config.CodeReview.MaxIterations > 0;
        _codeReviewMaxIterations = config.CodeReview.MaxIterations;
        _codeReviewFixPrompt = config.CodeReview.FixPrompt;
        _externalCiTimeoutMinutes = (int)config.ExternalCiTimeout.TotalMinutes;
        _externalCiPollIntervalSeconds = (int)config.ExternalCiPollInterval.TotalSeconds;
        _ciNotStartedTimeoutMinutes = (int)config.CiNotStartedTimeout.TotalMinutes;
        _ciNotStartedMaxRetries = config.CiNotStartedMaxRetries;
    }

    private async Task SaveAsync()
    {
        try
        {
            await ConfigStore.UpdatePipelineConfigAsync(
                current => current with
                {
                    CodeReview = new CodeReviewConfiguration
                    {
                        MaxIterations = _codeReviewEnabled ? Math.Max(1, _codeReviewMaxIterations) : 0,
                        FixPrompt = _codeReviewFixPrompt,
                        ReviewIsolation = current.CodeReview.ReviewIsolation,
                        InlineComments = current.CodeReview.InlineComments,
                    },
                    ExternalCiTimeout = TimeSpan.FromMinutes(_externalCiTimeoutMinutes),
                    ExternalCiPollInterval = TimeSpan.FromSeconds(_externalCiPollIntervalSeconds),
                    CiNotStartedTimeout = TimeSpan.FromMinutes(_ciNotStartedTimeoutMinutes),
                    CiNotStartedMaxRetries = _ciNotStartedMaxRetries
                },
                CancellationToken.None);
            await OnShowStatus.InvokeAsync(("Implementation settings saved.", false));
        }
        catch (Exception ex)
        {
            await OnShowStatus.InvokeAsync(($"Failed to save: {ex.Message}", true));
        }
    }
}
