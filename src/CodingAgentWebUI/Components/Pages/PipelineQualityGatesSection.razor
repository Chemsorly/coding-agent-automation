@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models

<section class="settings-section">
    <h2>Quality Gates</h2>
    <div class="provider-form">
        <div class="form-group">
            <label>Min Coverage Threshold (%)</label>
            <input type="number" @bind="_minCoverageThreshold" min="0" max="100" step="0.1" />
        </div>
        <div class="form-group form-checkbox">
            <label>
                <input type="checkbox" @bind="_codeReviewEnabled" />
                Agent Code Review Enabled
            </label>
        </div>
        @if (_codeReviewEnabled)
        {
            <div class="config-sub-fields">
                <div class="form-group">
                    <label>Max Review Iterations</label>
                    <input type="number" @bind="_codeReviewMaxIterations" min="1" max="5" />
                </div>
                <div class="form-group form-checkbox">
                    <label>
                        <input type="checkbox" @bind="_multiAgentReviewEnabled" />
                        Use Specialized Review Agents
                        <span class="form-hint-icon" aria-hidden="true" title="Run multiple specialized reviewers sequentially instead of a single prompt">?</span>
                    </label>
                </div>
                @if (_multiAgentReviewEnabled)
                {
                    <div class="config-sub-fields">
                        @for (var idx = 0; idx < _reviewAgents.Count; idx++)
                        {
                            var agentIdx = idx;
                            <div class="form-group" style="border-left: 2px solid var(--border-color, #444); padding-left: 0.75rem; margin-bottom: 1rem;">
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <label style="flex: 1;">Agent Name</label>
                                    <button type="button" class="btn-revert" @onclick="() => _reviewAgents.RemoveAt(agentIdx)">Remove</button>
                                </div>
                                <input type="text" @bind="_reviewAgents[agentIdx].Name" />
                                <label>Prompt</label>
                                <textarea @bind="_reviewAgents[agentIdx].Prompt" rows="4"></textarea>
                            </div>
                        }
                        <button type="button" class="btn-revert" @onclick="() => _reviewAgents.Add(new AgentFormEntry())">+ Add Agent</button>
                        <button type="button" class="btn-revert" @onclick="ResetReviewAgentsToDefault">Reset to defaults</button>
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label>Review Prompt</label>
                        <textarea @bind="_codeReviewPrompt" rows="4"></textarea>
                        <button type="button" class="btn-revert" disabled="@(_codeReviewPrompt == PipelineConfiguration.DefaultCodeReviewPrompt)" @onclick="() => _codeReviewPrompt = PipelineConfiguration.DefaultCodeReviewPrompt">Reset to default</button>
                    </div>
                }
                <div class="form-group">
                    <label>Fix Prompt <span class="form-hint">(leave empty for single-pass review)</span></label>
                    <textarea @bind="_codeReviewFixPrompt" rows="3"></textarea>
                    <button type="button" class="btn-revert" disabled="@(_codeReviewFixPrompt == PipelineConfiguration.DefaultFixPrompt)" @onclick="() => _codeReviewFixPrompt = PipelineConfiguration.DefaultFixPrompt">Reset to default</button>
                </div>
            </div>
        }
        <div class="form-group form-checkbox">
            <label class="@(PipelineProviderCount == 0 ? "disabled-label" : "")">
                <input type="checkbox" @bind="_externalCiEnabled" disabled="@(PipelineProviderCount == 0)" />
                External CI Quality Gate
                @if (PipelineProviderCount == 0)
                {
                    <span class="form-hint-icon" aria-hidden="true" title="Configure a Pipeline Provider first to enable this option">?</span>
                }
            </label>
        </div>
        @if (_externalCiEnabled)
        {
            <div class="config-sub-fields">
                <div class="form-group">
                    <label>CI Timeout (minutes)</label>
                    <input type="number" @bind="_externalCiTimeoutMinutes" min="1" max="60" />
                </div>
                <div class="form-group">
                    <label>CI Poll Interval (seconds)</label>
                    <input type="number" @bind="_externalCiPollIntervalSeconds" min="10" max="300" />
                </div>
            </div>
        }
        <div class="pipeline-form-actions">
            <button class="btn-save" @onclick="SaveAsync">Save Quality Gate Settings</button>
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public IConfigurationStore ConfigStore { get; set; } = default!;
    [Parameter] public int PipelineProviderCount { get; set; }
    [Parameter] public EventCallback<(string Message, bool IsError)> OnShowStatus { get; set; }

    private double _minCoverageThreshold = 80.0;
    private bool _codeReviewEnabled = true;
    private int _codeReviewMaxIterations = 1;
    private string _codeReviewPrompt = PipelineConfiguration.DefaultCodeReviewPrompt;
    private string? _codeReviewFixPrompt;
    private bool _multiAgentReviewEnabled = false;
    private List<AgentFormEntry> _reviewAgents = new();
    private bool _externalCiEnabled = false;
    private int _externalCiTimeoutMinutes = 15;
    private int _externalCiPollIntervalSeconds = 30;

    protected override async Task OnInitializedAsync()
    {
        var config = await ConfigStore.LoadPipelineConfigAsync(CancellationToken.None);
        _minCoverageThreshold = config.MinCoverageThreshold;
        _codeReviewEnabled = config.CodeReview.Enabled;
        _codeReviewMaxIterations = config.CodeReview.MaxIterations;
        _codeReviewPrompt = config.CodeReview.Prompt;
        _codeReviewFixPrompt = config.CodeReview.FixPrompt;
        _multiAgentReviewEnabled = config.CodeReview.Agents is { Count: > 0 };
        _reviewAgents = config.CodeReview.Agents is { Count: > 0 }
            ? config.CodeReview.Agents.Select(a => new AgentFormEntry { Name = a.Name, Prompt = a.Prompt }).ToList()
            : PipelineConfiguration.DefaultReviewAgents.Select(a => new AgentFormEntry { Name = a.Name, Prompt = a.Prompt }).ToList();
        _externalCiEnabled = config.ExternalCiEnabled;
        _externalCiTimeoutMinutes = (int)config.ExternalCiTimeout.TotalMinutes;
        _externalCiPollIntervalSeconds = (int)config.ExternalCiPollInterval.TotalSeconds;
    }

    private void ResetReviewAgentsToDefault()
    {
        _reviewAgents = PipelineConfiguration.DefaultReviewAgents
            .Select(a => new AgentFormEntry { Name = a.Name, Prompt = a.Prompt }).ToList();
    }

    private async Task SaveAsync()
    {
        try
        {
            await ConfigStore.UpdatePipelineConfigAsync(
                current => current with
                {
                    MinCoverageThreshold = _minCoverageThreshold,
                    CodeReview = new CodeReviewConfiguration
                    {
                        Enabled = _codeReviewEnabled,
                        MaxIterations = _codeReviewMaxIterations,
                        Prompt = _codeReviewPrompt,
                        FixPrompt = _codeReviewFixPrompt,
                        Agents = _multiAgentReviewEnabled && _reviewAgents.Count > 0
                            ? _reviewAgents
                                .Where(a => !string.IsNullOrWhiteSpace(a.Name) && !string.IsNullOrWhiteSpace(a.Prompt))
                                .Select(a => new ReviewAgentConfig { Name = a.Name.Trim(), Prompt = a.Prompt.Trim() })
                                .ToArray()
                            : null,
                    },
                    ExternalCiEnabled = _externalCiEnabled,
                    ExternalCiTimeout = TimeSpan.FromMinutes(_externalCiTimeoutMinutes),
                    ExternalCiPollInterval = TimeSpan.FromSeconds(_externalCiPollIntervalSeconds)
                },
                CancellationToken.None);
            await OnShowStatus.InvokeAsync(("Quality gate settings saved.", false));
        }
        catch (Exception ex)
        {
            await OnShowStatus.InvokeAsync(($"Failed to save: {ex.Message}", true));
        }
    }

    private class AgentFormEntry
    {
        public string Name { get; set; } = "";
        public string Prompt { get; set; } = "";
    }
}