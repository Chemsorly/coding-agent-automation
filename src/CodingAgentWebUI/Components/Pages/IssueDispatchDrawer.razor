@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models
@using System.Text.RegularExpressions
@inherits DispatchDrawerBase<IssueSummary>

<div class="dispatch-drawer-overlay @(IsOpen ? "open" : "")" @onclick="Close"></div>
<aside class="dispatch-drawer @(IsOpen ? "open" : "")">
    <div class="agent-detail-header">
        <h3>Browse Issues</h3>
        <button class="agent-detail-close" @onclick="Close" aria-label="Close drawer">✕</button>
    </div>

    @if (Template != null)
    {
        <div class="agent-detail-section">
            <h4>Template: @Template.Name</h4>
        </div>

        @if (IsLoading)
        {
            <div class="loading-text" style="padding: 12px;">Loading issues...</div>
        }
        else
        {
            <div style="padding: 0 0 8px;">
                <input type="text" @bind="_filter" @bind:event="oninput" @bind:after="ApplyFilter"
                       placeholder="Filter by number or title..." style="width: 100%; padding: 6px 10px; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); font-size: 0.82rem;" />
            </div>

            @if (Issues.Count == 0)
            {
                <div class="monitoring-empty">No open issues found.</div>
            }
            else
            {
                <div class="agent-history-list" style="max-height: calc(100vh - 320px); overflow-y: auto;">
                    @foreach (var issue in FilteredItems)
                    {
                        var isProcessing = IsBeingProcessed(issue.Identifier);
                        var readiness = GetReadiness(issue.Identifier, isProcessing);
                        <div class="drawer-issue-item @(isProcessing ? "drawer-issue-dispatched" : "") @(SelectedItem?.Identifier == issue.Identifier ? "drawer-issue-selected" : "")"
                             @onclick="() => SelectItem(issue)"
                             data-testid="issue-row-@issue.Identifier"
                             style="@(isProcessing ? "opacity: 0.6; pointer-events: none;" : "")">
                            <div class="drawer-issue-header">
                                <span class="drawer-issue-number">#@issue.Identifier</span>
                                @if (readiness == DispatchReadinessState.Queued)
                                {
                                    <span class="badge-default" style="background: var(--accent); color: white;" data-testid="badge-queued-@issue.Identifier">⏳ Queued</span>
                                }
                                else if (readiness == DispatchReadinessState.Ready)
                                {
                                    <span class="badge-default" style="background: var(--success, #22c55e); color: white;" data-testid="badge-ready-@issue.Identifier">✅ Ready</span>
                                }
                                else if (readiness == DispatchReadinessState.Blocked)
                                {
                                    <span class="badge-default" style="background: var(--danger, #ef4444); color: white;" data-testid="badge-blocked-@issue.Identifier">🚫 Blocked by @GetBlockedByText(issue.Identifier)</span>
                                }
                                else if (readiness == DispatchReadinessState.Checking)
                                {
                                    <span class="badge-default" style="background: var(--border); color: var(--text-muted);">…</span>
                                }
                            </div>
                            <div class="drawer-issue-title">@issue.Title</div>
                            @{ var preview = GetBodyPreview(issue.Description); }
                            @if (!string.IsNullOrEmpty(preview))
                            {
                                <div class="drawer-issue-preview" style="font-size: 0.75rem; color: var(--text-muted); margin-top: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@preview</div>
                            }
                            <div class="drawer-issue-labels">
                                @foreach (var label in issue.Labels.Take(5))
                                {
                                    <span class="sidebar-label @UiFormatters.GetLabelClass(label)">@label</span>
                                }
                            </div>
                        </div>
                    }
                </div>

                @if (HasMore || Page > 1)
                {
                    <div style="display: flex; justify-content: center; gap: 8px; padding: 8px 0;">
                        <button class="btn-page" @onclick="PrevPage" disabled="@(Page <= 1)">← Prev</button>
                        <span class="monitoring-muted" style="align-self: center; font-size: 0.8rem;">Page @Page</span>
                        <button class="btn-page" @onclick="NextPage" disabled="@(!HasMore)">Next →</button>
                    </div>
                }
            }

            @if (SelectedItem != null)
            {
                var selectedReadiness = GetReadiness(SelectedItem.Identifier, IsBeingProcessed(SelectedItem.Identifier));
                var isBlocked = selectedReadiness == DispatchReadinessState.Blocked;
                <div class="agent-detail-section" style="margin-top: 12px; border-top: 1px solid var(--border); padding-top: 12px;">
                    <h4>#@SelectedItem.Identifier — @SelectedItem.Title</h4>
                    <div class="drawer-issue-labels" style="margin-bottom: 8px;">
                        @foreach (var label in SelectedItem.Labels)
                        {
                            <span class="sidebar-label @UiFormatters.GetLabelClass(label)">@label</span>
                        }
                    </div>
                    @if (SelectedItem.CreatedAt.HasValue)
                    {
                        <p style="font-size: 0.78rem; color: var(--text-muted); margin: 0 0 8px;">
                            Created: @SelectedItem.CreatedAt.Value.ToLocalTime().ToString("g")
                        </p>
                    }
                    @if (isBlocked)
                    {
                        <p style="font-size: 0.78rem; color: var(--danger, #ef4444); margin: 0 0 8px;">
                            🚫 Cannot dispatch — blocked by @GetBlockedByText(SelectedItem.Identifier)
                        </p>
                    }
                    <button class="btn-save" @onclick="DispatchSelected" disabled="@(IsDispatching || isBlocked)"
                            data-testid="dispatch-issue-btn"
                            title="@(isBlocked ? $"Blocked by {GetBlockedByText(SelectedItem.Identifier)}" : "")">
                        @(IsDispatching ? "Dispatching..." : $"Start Pipeline on #{SelectedItem.Identifier}")
                    </button>
                </div>
            }
        }
    }
</aside>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<IssueSummary> Issues { get; set; } = [];
    [Parameter, EditorRequired] public bool HasMore { get; set; }
    [Parameter, EditorRequired] public int Page { get; set; }
    [Parameter] public EventCallback OnNextPage { get; set; }
    [Parameter] public EventCallback OnPrevPage { get; set; }
    [Parameter] public IReadOnlyDictionary<string, DependencyCheckResult>? ReadinessResults { get; set; }

    private static readonly Regex MarkdownStripPattern = new(@"^#{1,6}\s+|!?\[([^\]]*)\]\([^)]*\)", RegexOptions.Compiled);

    protected override void OnParametersSet()
    {
        Items = Issues;
        base.OnParametersSet();
    }

    protected override bool MatchesFilter(IssueSummary item, string filter) =>
        item.Identifier.Contains(filter, StringComparison.OrdinalIgnoreCase)
        || item.Title.Contains(filter, StringComparison.OrdinalIgnoreCase);

    protected override string GetIdentifier(IssueSummary item) => item.Identifier;

    private async Task NextPage() => await OnNextPage.InvokeAsync();
    private async Task PrevPage() => await OnPrevPage.InvokeAsync();

    // TODO: If the readiness check silently skips an issue (individual failure), it remains in Checking state indefinitely. Consider reporting a "failed" state so the user knows the check didn't succeed.
    private DispatchReadinessState GetReadiness(string identifier, bool isProcessing)
    {
        if (isProcessing) return DispatchReadinessState.Queued;
        if (ReadinessResults == null) return DispatchReadinessState.Checking;
        if (!ReadinessResults.TryGetValue(identifier, out var result)) return DispatchReadinessState.Checking;
        return result.IsReady ? DispatchReadinessState.Ready : DispatchReadinessState.Blocked;
    }

    private string GetBlockedByText(string identifier)
    {
        if (ReadinessResults != null && ReadinessResults.TryGetValue(identifier, out var result) && result.BlockedBy.Count > 0)
            return string.Join(", ", result.BlockedBy.Select(n => $"#{n}"));
        return "open dependencies";
    }

    private static string? GetBodyPreview(string? description)
    {
        if (string.IsNullOrWhiteSpace(description)) return null;
        // Strip markdown headings and links/images, take first 100 chars
        var plain = MarkdownStripPattern.Replace(description, "$1");
        // Take up to first ## heading or first 100 chars
        var headingIdx = plain.IndexOf("\n##", StringComparison.Ordinal);
        if (headingIdx > 0 && headingIdx < 100) plain = plain[..headingIdx];
        plain = plain.Replace('\n', ' ').Replace('\r', ' ').Trim();
        if (plain.Length > 100) plain = plain[..100] + "…";
        return string.IsNullOrWhiteSpace(plain) ? null : plain;
    }
}
