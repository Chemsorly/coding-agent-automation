@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models

<div class="dispatch-drawer-overlay @(IsOpen ? "open" : "")" @onclick="Close"></div>
<aside class="dispatch-drawer @(IsOpen ? "open" : "")">
    <div class="agent-detail-header">
        <h3>Browse Pull Requests</h3>
        <button class="agent-detail-close" @onclick="Close" aria-label="Close drawer">✕</button>
    </div>

    @if (Template != null)
    {
        <div class="agent-detail-section">
            <h4>Template: @Template.Name</h4>
        </div>

        @if (IsLoading)
        {
            <div class="loading-text" style="padding: 12px;">Loading pull requests...</div>
        }
        else
        {
            <div style="padding: 0 0 8px;">
                <input type="text" @bind="_filter" @bind:event="oninput" @bind:after="ApplyFilter"
                       placeholder="Filter by number or title..." style="width: 100%; padding: 6px 10px; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); font-size: 0.82rem;" />
            </div>

            @if (PullRequests.Count == 0)
            {
                <div class="monitoring-empty">No open pull requests found.</div>
            }
            else
            {
                <div class="agent-history-list" style="max-height: calc(100vh - 320px); overflow-y: auto;">
                    @foreach (var pr in _filteredPrs)
                    {
                        var isProcessing = IsBeingProcessed(pr.Identifier);
                        <div class="drawer-issue-item @(isProcessing ? "drawer-issue-dispatched" : "") @(_selectedPr?.Identifier == pr.Identifier ? "drawer-issue-selected" : "")"
                             @onclick="() => SelectPr(pr)"
                             data-testid="pr-row-@pr.Identifier"
                             style="@(isProcessing ? "opacity: 0.6; pointer-events: none;" : "")">
                            <div class="drawer-issue-header">
                                <span class="drawer-issue-number">PR #@pr.Identifier</span>
                                @if (pr.IsDraft)
                                {
                                    <span class="badge-default" style="background: var(--text-muted); color: white;">DRAFT</span>
                                }
                                @if (isProcessing)
                                {
                                    <span class="badge-default" style="background: var(--accent); color: white;">DISPATCHED</span>
                                }
                            </div>
                            <div class="drawer-issue-title">@pr.Title</div>
                            <div class="drawer-issue-labels">
                                <span class="sidebar-label" style="background: var(--bg-hover); font-size: 0.7rem;">@pr.BranchName → @pr.TargetBranch</span>
                                @foreach (var label in pr.Labels.Take(4))
                                {
                                    <span class="sidebar-label @UiFormatters.GetLabelClass(label)">@label</span>
                                }
                            </div>
                        </div>
                    }
                </div>

                @if (HasMore || Page > 1)
                {
                    <div style="display: flex; justify-content: center; gap: 8px; padding: 8px 0;">
                        <button class="btn-page" @onclick="PrevPage" disabled="@(Page <= 1)">← Prev</button>
                        <span class="monitoring-muted" style="align-self: center; font-size: 0.8rem;">Page @Page</span>
                        <button class="btn-page" @onclick="NextPage" disabled="@(!HasMore)">Next →</button>
                    </div>
                }
            }

            @if (_selectedPr != null)
            {
                <div class="agent-detail-section" style="margin-top: 12px; border-top: 1px solid var(--border); padding-top: 12px;">
                    <h4>PR #@_selectedPr.Identifier — @_selectedPr.Title</h4>
                    <div style="font-size: 0.78rem; color: var(--text-muted); margin-bottom: 4px;">
                        @_selectedPr.BranchName → @_selectedPr.TargetBranch
                    </div>
                    <div class="drawer-issue-labels" style="margin-bottom: 8px;">
                        @foreach (var label in _selectedPr.Labels)
                        {
                            <span class="sidebar-label @UiFormatters.GetLabelClass(label)">@label</span>
                        }
                    </div>
                    @if (_selectedPr.IsDraft)
                    {
                        <div class="settings-status status-error" style="margin-bottom: 8px; font-size: 0.78rem;">
                            ⚠️ This PR is a draft. Review will still be dispatched.
                        </div>
                    }
                    @if (_selectedPr.CreatedAt.HasValue)
                    {
                        <p style="font-size: 0.78rem; color: var(--text-muted); margin: 0 0 8px;">
                            Created: @_selectedPr.CreatedAt.Value.ToLocalTime().ToString("g")
                        </p>
                    }
                    <button class="btn-save" @onclick="DispatchSelected" disabled="@IsDispatching"
                            data-testid="dispatch-pr-btn"
                            style="background: var(--accent-secondary, #6366f1);">
                        @(IsDispatching ? "Dispatching..." : $"Start Review on PR #{_selectedPr.Identifier}")
                    </button>
                </div>
            }
        }
    }
</aside>

@code {
    [Parameter, EditorRequired] public bool IsOpen { get; set; }
    [Parameter, EditorRequired] public PipelineJobTemplate? Template { get; set; }
    [Parameter, EditorRequired] public IReadOnlyList<PullRequestSummary> PullRequests { get; set; } = [];
    [Parameter, EditorRequired] public bool IsLoading { get; set; }
    [Parameter, EditorRequired] public bool HasMore { get; set; }
    [Parameter, EditorRequired] public int Page { get; set; }
    [Parameter, EditorRequired] public bool IsDispatching { get; set; }
    [Parameter, EditorRequired] public Func<string, bool> IsBeingProcessed { get; set; } = _ => false;
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnNextPage { get; set; }
    [Parameter] public EventCallback OnPrevPage { get; set; }
    [Parameter] public EventCallback<PullRequestSummary> OnDispatch { get; set; }

    private string _filter = "";
    private List<PullRequestSummary> _filteredPrs = new();
    private PullRequestSummary? _selectedPr;

    protected override void OnParametersSet()
    {
        ApplyFilter();
        if (!IsOpen) { _selectedPr = null; _filter = ""; }
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(_filter))
        {
            _filteredPrs = PullRequests.ToList();
        }
        else
        {
            var f = _filter.Trim();
            _filteredPrs = PullRequests
                .Where(pr => pr.Identifier.Contains(f, StringComparison.OrdinalIgnoreCase)
                          || pr.Title.Contains(f, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private void SelectPr(PullRequestSummary pr) => _selectedPr = pr;

    private async Task Close() => await OnClose.InvokeAsync();
    private async Task NextPage() => await OnNextPage.InvokeAsync();
    private async Task PrevPage() => await OnPrevPage.InvokeAsync();

    private async Task DispatchSelected()
    {
        if (_selectedPr != null)
            await OnDispatch.InvokeAsync(_selectedPr);
    }
}
