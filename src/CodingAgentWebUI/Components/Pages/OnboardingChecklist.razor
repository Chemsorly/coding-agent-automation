@using CodingAgentWebUI.Pipeline.Models
@inject Microsoft.JSInterop.IJSRuntime JS

@if (!_dismissed && !AllComplete)
{
    <section class="onboarding-checklist">
        <div class="onboarding-header">
            <h2>🚀 Getting Started</h2>
            <button class="onboarding-dismiss" @onclick="Dismiss" title="Dismiss checklist">✕</button>
        </div>
        <p class="onboarding-description">Complete these steps to run your first pipeline:</p>
        <ol class="onboarding-steps">
            <li class="@(HasIssueProvider ? "step-complete" : "")">
                @if (HasIssueProvider) { <span class="step-icon">✅</span> } else { <span class="step-icon">☐</span> }
                <a href="/settings?section=providers-issue">Create an Issue Provider</a>
            </li>
            <li class="@(HasRepoProvider ? "step-complete" : "")">
                @if (HasRepoProvider) { <span class="step-icon">✅</span> } else { <span class="step-icon">☐</span> }
                <a href="/settings?section=providers-repository">Create a Repository Provider</a>
            </li>
            <li class="@(HasProject ? "step-complete" : "")">
                @if (HasProject) { <span class="step-icon">✅</span> } else { <span class="step-icon">☐</span> }
                <a href="/settings?section=projects">Create a Project</a>
            </li>
            <li class="@(HasTemplate ? "step-complete" : "")">
                @if (HasTemplate) { <span class="step-icon">✅</span> } else { <span class="step-icon">☐</span> }
                <a href="" @onclick="OnAddTemplate" @onclick:preventDefault>Create a Pipeline Template</a>
            </li>
            <li class="@(HasAgent ? "step-complete" : "")">
                @if (HasAgent) { <span class="step-icon">✅</span> } else { <span class="step-icon">☐</span> }
                <a href="/agent-monitoring">Register an Agent</a>
            </li>
            <li class="@(IsLoopActive ? "step-complete" : "")">
                @if (IsLoopActive) { <span class="step-icon">✅</span> } else { <span class="step-icon">☐</span> }
                <span class="step-text">Start the pipeline loop</span>
            </li>
        </ol>
    </section>
}

@code {
    private bool _dismissed;

    [Parameter, EditorRequired] public bool HasIssueProvider { get; set; }
    [Parameter, EditorRequired] public bool HasRepoProvider { get; set; }
    [Parameter, EditorRequired] public bool HasProject { get; set; }
    [Parameter, EditorRequired] public bool HasTemplate { get; set; }
    [Parameter, EditorRequired] public bool HasAgent { get; set; }
    [Parameter, EditorRequired] public bool IsLoopActive { get; set; }
    [Parameter] public EventCallback OnAddTemplate { get; set; }

    private bool AllComplete => HasIssueProvider && HasRepoProvider && HasProject && HasTemplate && HasAgent && IsLoopActive;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // TODO: Pass a CancellationToken to avoid orphaned async operations if component is disposed during JS interop
                var val = await JS.InvokeAsync<string?>("localStorageGet", "onboarding-checklist-dismissed");
                if (val == "true")
                {
                    _dismissed = true;
                    StateHasChanged();
                }
            }
            catch { /* JS interop not available */ }
        }
    }

    private async Task Dismiss()
    {
        _dismissed = true;
        try { await JS.InvokeVoidAsync("localStorageSet", "onboarding-checklist-dismissed", "true"); }
        catch { /* JS interop not available */ }
    }
}
