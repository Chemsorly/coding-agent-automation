@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models

<section class="settings-section">
    <h2>Quality Gate Configurations</h2>

    @if (_configs.Count == 0)
    {
        <div class="monitoring-empty">No quality gate configurations. The migration service will create a default on next startup, or create one manually.</div>
    }
    else
    {
        <div class="monitoring-table-wrap">
            <table class="monitoring-table">
                <colgroup>
                    <col />
                    <col />
                    <col style="width: 180px;" />
                    <col style="width: 80px;" />
                    <col style="width: 70px;" />
                    <col style="width: 60px;" />
                    <col style="width: 120px;" />
                </colgroup>
                <thead>
                    <tr>
                        <th>Display Name</th>
                        <th>Match Labels</th>
                        <th>Commands</th>
                        <th>Coverage</th>
                        <th>Enabled</th>
                        <th>Order</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var qgc in _configs.OrderBy(q => q.ExecutionOrder))
                    {
                        <tr>
                            <td>
                                @qgc.DisplayName
                                @if (qgc.MatchLabels.Count == 0)
                                {
                                    <span class="badge-global">GLOBAL</span>
                                }
                            </td>
                            <td>
                                @if (qgc.MatchLabels.Count > 0)
                                {
                                    @foreach (var label in qgc.MatchLabels)
                                    {
                                        <span class="sidebar-label">@label</span>
                                    }
                                }
                                else
                                {
                                    <span class="monitoring-muted">(all jobs)</span>
                                }
                            </td>
                            <td class="monitoring-mono" style="font-size: 0.75rem;">
                                @FormatCommands(qgc)
                            </td>
                            <td>@(qgc.CoverageThreshold.HasValue ? $"{qgc.CoverageThreshold.Value}%" : "—")</td>
                            <td>@(qgc.Enabled ? "✅" : "❌")</td>
                            <td>@qgc.ExecutionOrder</td>
                            <td>
                                <button class="btn-edit" @onclick="() => EditConfig(qgc)">Edit</button>
                                <button class="btn-delete" @onclick="() => ConfirmDelete(qgc)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (_showForm)
    {
        <div class="provider-form" style="margin-top: 12px;">
            <h3>@(_editingConfig != null ? "Edit" : "Create") Quality Gate Configuration</h3>

            @if (!string.IsNullOrEmpty(_formError))
            {
                <div class="settings-status status-error">@_formError</div>
            }

            <div class="form-group">
                <label>Display Name *</label>
                <input type="text" @bind="_form.DisplayName" placeholder="e.g. .NET Quality Gates" />
            </div>
            <div class="form-group">
                <label>Match Labels <span class="form-hint">(comma-separated, empty = global fallback)</span></label>
                <input type="text" @bind="_form.MatchLabels" placeholder="e.g. dotnet, csharp" />
            </div>
            <div class="form-group">
                <label>Compilation Command</label>
                <input type="text" @bind="_form.CompilationCommand" placeholder="e.g. dotnet" />
            </div>
            <div class="form-group">
                <label>Compilation Arguments <span class="form-hint">(space-separated)</span></label>
                <input type="text" @bind="_form.CompilationArguments" placeholder="e.g. build --no-restore" />
            </div>
            <div class="form-group">
                <label>Test Command</label>
                <input type="text" @bind="_form.TestCommand" placeholder="e.g. dotnet" />
            </div>
            <div class="form-group">
                <label>Test Arguments <span class="form-hint">(space-separated)</span></label>
                <input type="text" @bind="_form.TestArguments" placeholder="e.g. test --no-restore --no-build" />
            </div>
            <div class="form-group">
                <label>Coverage Threshold (%) <span class="form-hint">(leave empty to skip)</span></label>
                <input type="number" @bind="_form.CoverageThreshold" min="0" max="100" step="0.1" />
            </div>
            <div class="form-group form-checkbox">
                <label>
                    <input type="checkbox" @bind="_form.SecurityScanEnabled" />
                    Security Scan Enabled
                </label>
            </div>
            <div class="form-group form-checkbox">
                <label>
                    <input type="checkbox" @bind="_form.Enabled" />
                    Enabled
                </label>
            </div>
            <div class="form-group">
                <label>Execution Order <span class="form-hint">(lower runs first)</span></label>
                <input type="number" @bind="_form.ExecutionOrder" />
            </div>
            <div class="form-buttons">
                <button class="btn-save" @onclick="SaveConfig">Save</button>
                <button class="btn-cancel" @onclick="CancelForm">Cancel</button>
            </div>
        </div>
    }
    else
    {
        <button class="btn-add" style="margin-top: 12px;" @onclick="ShowAddForm">+ Add Quality Gate Configuration</button>
    }

    @if (_showDeleteConfirm && _deletingConfig != null)
    {
        <div class="agent-detail-confirm" style="margin-top: 12px;">
            <p>Delete quality gate configuration <strong>@_deletingConfig.DisplayName</strong>?</p>
            <div class="confirm-buttons">
                <button class="btn-delete" @onclick="DeleteConfig">Delete</button>
                <button class="btn-cancel" @onclick="() => _showDeleteConfirm = false">Cancel</button>
            </div>
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired] public IConfigurationStore ConfigStore { get; set; } = default!;
    [Parameter] public EventCallback<(string Message, bool IsError)> OnShowStatus { get; set; }

    private List<QualityGateConfiguration> _configs = new();
    private bool _showForm;
    private QualityGateConfiguration? _editingConfig;
    private QgcForm _form = new();
    private string? _formError;
    private bool _showDeleteConfirm;
    private QualityGateConfiguration? _deletingConfig;

    protected override async Task OnInitializedAsync()
    {
        await LoadConfigs();
    }

    private async Task LoadConfigs()
    {
        try
        {
            _configs = (await ConfigStore.LoadQualityGateConfigsAsync(CancellationToken.None)).ToList();
        }
        catch (Exception ex)
        {
            await OnShowStatus.InvokeAsync(($"Failed to load QGCs: {ex.Message}", true));
        }
    }

    private void ShowAddForm()
    {
        _editingConfig = null;
        _form = new QgcForm { Enabled = true };
        _formError = null;
        _showForm = true;
    }

    private void EditConfig(QualityGateConfiguration qgc)
    {
        _editingConfig = qgc;
        _form = new QgcForm
        {
            DisplayName = qgc.DisplayName,
            MatchLabels = string.Join(", ", qgc.MatchLabels),
            CompilationCommand = qgc.CompilationCommand ?? "",
            CompilationArguments = qgc.CompilationArguments != null ? string.Join(" ", qgc.CompilationArguments) : "",
            TestCommand = qgc.TestCommand ?? "",
            TestArguments = qgc.TestArguments != null ? string.Join(" ", qgc.TestArguments) : "",
            CoverageThreshold = qgc.CoverageThreshold,
            SecurityScanEnabled = qgc.SecurityScanEnabled,
            Enabled = qgc.Enabled,
            ExecutionOrder = qgc.ExecutionOrder
        };
        _formError = null;
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _formError = null;
    }

    private async Task SaveConfig()
    {
        _formError = null;

        if (string.IsNullOrWhiteSpace(_form.DisplayName))
        {
            _formError = "Display Name is required.";
            return;
        }

        var compilationCmd = string.IsNullOrWhiteSpace(_form.CompilationCommand) ? null : _form.CompilationCommand.Trim();
        var testCmd = string.IsNullOrWhiteSpace(_form.TestCommand) ? null : _form.TestCommand.Trim();

        if (compilationCmd == null && testCmd == null)
        {
            _formError = "At least one of Compilation Command or Test Command must be specified.";
            return;
        }

        var labels = ParseLabels(_form.MatchLabels);
        var compilationArgs = ParseArguments(_form.CompilationArguments);
        var testArgs = ParseArguments(_form.TestArguments);

        var config = new QualityGateConfiguration
        {
            Id = _editingConfig?.Id ?? Guid.NewGuid().ToString(),
            DisplayName = _form.DisplayName.Trim(),
            MatchLabels = labels,
            CompilationCommand = compilationCmd,
            CompilationArguments = compilationArgs.Count > 0 ? compilationArgs : null,
            TestCommand = testCmd,
            TestArguments = testArgs.Count > 0 ? testArgs : null,
            CoverageThreshold = _form.CoverageThreshold,
            SecurityScanEnabled = _form.SecurityScanEnabled,
            Enabled = _form.Enabled,
            ExecutionOrder = _form.ExecutionOrder
        };

        try
        {
            await ConfigStore.SaveQualityGateConfigAsync(config, CancellationToken.None);
            _showForm = false;
            await LoadConfigs();
            await OnShowStatus.InvokeAsync(("Quality gate configuration saved.", false));
        }
        catch (Exception ex)
        {
            _formError = $"Failed to save: {ex.Message}";
        }
    }

    private void ConfirmDelete(QualityGateConfiguration qgc)
    {
        _deletingConfig = qgc;
        _showDeleteConfirm = true;
    }

    private async Task DeleteConfig()
    {
        if (_deletingConfig == null) return;

        try
        {
            await ConfigStore.DeleteQualityGateConfigAsync(_deletingConfig.Id, CancellationToken.None);
            _showDeleteConfirm = false;
            _deletingConfig = null;
            await LoadConfigs();
            await OnShowStatus.InvokeAsync(("Quality gate configuration deleted.", false));
        }
        catch (Exception ex)
        {
            await OnShowStatus.InvokeAsync(($"Failed to delete: {ex.Message}", true));
        }
    }

    private static string FormatCommands(QualityGateConfiguration qgc)
    {
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(qgc.CompilationCommand))
            parts.Add($"{qgc.CompilationCommand} {string.Join(" ", qgc.CompilationArguments ?? [])}".Trim());
        if (!string.IsNullOrEmpty(qgc.TestCommand))
            parts.Add($"{qgc.TestCommand} {string.Join(" ", qgc.TestArguments ?? [])}".Trim());
        var result = string.Join(" | ", parts);
        return result.Length > 40 ? result[..37] + "..." : result;
    }

    private static IReadOnlyList<string> ParseLabels(string? input)
    {
        if (string.IsNullOrWhiteSpace(input)) return [];
        return input.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(l => !string.IsNullOrWhiteSpace(l))
            .ToList();
    }

    private static IReadOnlyList<string> ParseArguments(string? input)
    {
        if (string.IsNullOrWhiteSpace(input)) return [];
        return input.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .ToList();
    }

    private class QgcForm
    {
        public string DisplayName { get; set; } = "";
        public string MatchLabels { get; set; } = "";
        public string CompilationCommand { get; set; } = "";
        public string CompilationArguments { get; set; } = "";
        public string TestCommand { get; set; } = "";
        public string TestArguments { get; set; } = "";
        public double? CoverageThreshold { get; set; }
        public bool SecurityScanEnabled { get; set; }
        public bool Enabled { get; set; } = true;
        public int ExecutionOrder { get; set; } = 0;
    }
}
