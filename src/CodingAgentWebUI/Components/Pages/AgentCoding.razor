@page "/agent-coding"
@implements IDisposable
@using CodingAgentWebUI.Pipeline.Models
@using CodingAgentWebUI.Pipeline.Services
@using CodingAgentWebUI.Orchestration
@using CodingAgentWebUI.Orchestration.Dispatch
@using CodingAgentWebUI.Orchestration.Registry
@using CodingAgentWebUI.Services

<div class="agent-coding-page">
    <header class="agent-header">
        <h1>Agent Coding</h1>
    </header>

    @* ═══ Overlay toast stack ═══ *@
    <div class="agent-toast-stack">
        @if (LoopService.IsLoopActive && !_hideLoopToast)
        {
            <div class="agent-summary-bar loop-status-bar">
                <span class="loop-status-text">@LoopService.StatusMessage</span>
                <button class="btn-cancel loop-stop-btn" @onclick="StopLoop">⏹ Stop Loop</button>
            </div>
        }

        @if (LoopService.IsCircuitBroken)
        {
            <div class="agent-summary-bar" style="background: var(--bg-error); color: var(--error); border-color: var(--error);">
                @LoopService.StatusMessage
                <span style="margin-left: 1rem;">
                    <button class="btn-save" @onclick="ResumeLoop" style="margin-right: 0.5rem;">Resume</button>
                    <button class="btn-cancel" @onclick="StopLoop">Stop</button>
                </span>
            </div>
        }

        @* TODO: Migrate _successMessage/_errorMessage to <InlineStatus> component for inline feedback (issue #876 requirement) *@
        @* TODO: Error messages need a manual dismiss mechanism — errors must not auto-dismiss per requirements *@
        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="settings-status status-success">@_successMessage</div>
        }

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="settings-status status-error">@_errorMessage</div>
        }

        @{
            var agentRuns = RunService.GetActiveRuns();
            var agentCount = Registry.GetAllAgents().Count;
            var queueLength = Dispatcher.QueueLength;
            var implRunCount = agentRuns.Count(r => r.RunType == PipelineRunType.Implementation);
            var reviewRunCount = agentRuns.Count(r => r.RunType == PipelineRunType.Review);
        }
        @if (_showAgentSummary && (agentRuns.Count > 0 || queueLength > 0))
        {
            <div class="agent-summary-bar">
                <span>
                    <Icon Name="bot" Size="16" /> @agentCount agent(s) registered ·
                    @agentRuns.Count agent run(s) active
                    @if (implRunCount > 0 && reviewRunCount > 0)
                    {
                        <text> (🔨@implRunCount impl · </text><Icon Name="search" Size="16" /><text>@reviewRunCount review)</text>
                    }
                    else if (reviewRunCount > 0)
                    {
                        <text> (</text><Icon Name="search" Size="16" /><text>@reviewRunCount review)</text>
                    }
                    @if (queueLength > 0)
                    {
                        <text> · @queueLength job(s) queued</text>
                    }
                    · <a href="agent-monitoring" style="color: var(--accent-light);">View Dashboard →</a>
                </span>
                <button class="agent-summary-dismiss" @onclick="DismissAgentSummary" title="Dismiss">✕</button>
            </div>
        }
    </div>

    @{
        var activeRun = PipelineService.ActiveRun;
        var hasActiveRun = activeRun is not null
            && activeRun.CurrentStep is not (PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled);
        var hasFinishedRun = activeRun is { CurrentStep: PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled };
    }

    <div class="agent-content-layout @(hasActiveRun || hasFinishedRun ? "with-sidebar" : "")">
        <div class="agent-main">
            @if (!PipelineService.IsRunning && activeRun is null or { CurrentStep: PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled })
            {
                @if (hasFinishedRun && _showCompletionOnly)
                {
                    <PipelineSummary Run="activeRun!" MaxRetries="@_maxRetries" OnBackToIssues="BackToIssues" />
                }

                @if (activeRun is null || hasFinishedRun)
                {
                    @if (!_showCompletionOnly)
                    {
                        <OnboardingChecklist
                            HasIssueProvider="@(_issueProviders.Count > 0)"
                            HasRepoProvider="@(_repoProviders.Count > 0)"
                            HasProject="@(_projects.Count > 0)"
                            HasTemplate="@(_templates.Count > 0)"
                            HasAgent="@(Registry.GetAllAgents().Count > 0)"
                            IsLoopActive="LoopService.IsLoopActive"
                            OnAddTemplate="ShowAddForm" />

                        <TemplateTableSection Templates="_templates" Projects="_projects"
                            IssueProviders="_issueProviders" RepoProviders="_repoProviders"
                            BrainProviders="_brainProviders" PipelineProviders="_pipelineProviders"
                            IsLoopActive="LoopService.IsLoopActive" RecentlyToggled="_recentlyToggled"
                            TemplateStatuses="LoopService.TemplateStatuses"
                            QualityGateConfigs="_qualityGateConfigs" ReviewerConfigs="_reviewerConfigs"
                            AgentProfiles="_agentProfiles" PipelineConfig="_pipelineConfig"
                            ShowAddForm="_showAddForm" AddForm="_addForm" FormError="@_formError"
                            ShowDeleteConfirm="_showDeleteConfirm" DeletingTemplate="_deletingTemplate"
                            OnToggleEnabled="ToggleTemplateEnabled" OnToggleImplementation="ToggleImplementationEnabled"
                            OnToggleReview="ToggleReviewEnabled" OnToggleDecomposition="ToggleDecompositionEnabled"
                            OnConfirmRemove="ConfirmRemoveTemplate" OnMoveTemplate="MoveTemplateToProject"
                            OnShowAddForm="ShowAddForm" OnAddTemplate="AddTemplate"
                            OnCancelAdd="CancelAddForm" OnRemoveTemplate="RemoveTemplate" OnCancelDelete="CancelDelete" />

                        <!-- ═══ Loop Controls ═══ -->
                        <section class="settings-section" style="margin: 0 20px 16px;">
                            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
                                @if (!LoopService.IsLoopActive)
                                {
                                    <button class="btn-save" @onclick="StartLoop" disabled="@(!CanStartLoop)" title="@(!CanStartLoop ? StartLoopDisabledReason : null)"><Icon Name="play" Size="16" /> Start Loop</button>
                                }
                                else
                                {
                                    <button class="btn-cancel" @onclick="StopLoop">⏹ Stop Loop</button>
                                }
                                @if (LoopService.IsLoopActive)
                                {
                                    <span class="monitoring-muted" style="font-size: 0.82rem;">
                                        Polling template @(LoopService.CurrentCycleTemplateIndex + 1) of @LoopService.CurrentCycleTemplateCount
                                        · Processed: @LoopService.ProcessedCount · Failed: @LoopService.FailedCount
                                    </span>
                                }
                            </div>
                            @if (LoopService.ValidationErrors.Count > 0)
                            {
                                <div class="settings-status status-error" style="margin-top: 8px;">
                                    <strong>Validation errors:</strong>
                                    <ul style="margin: 4px 0 0 16px; padding: 0;">
                                        @foreach (var err in LoopService.ValidationErrors)
                                        {
                                            <li>@err</li>
                                        }
                                    </ul>
                                </div>
                            }
                        </section>

                        <!-- ═══ Manual Dispatch ═══ -->
                        <section class="settings-section" style="margin: 0 20px 16px;">
                            <h2>Manual Dispatch</h2>
                            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
                                <select value="@_manualDispatchTemplateId" @onchange="OnTemplateChanged" class="dispatch-template-select" data-testid="template-select">
                                    <option value="">-- Select Template --</option>
                                    @foreach (var t in _templates.Where(t => t.Enabled))
                                    {
                                        <option value="@t.Id">@t.Name</option>
                                    }
                                </select>
                                <button class="btn-save" @onclick="OpenEpicDrawer" disabled="@(string.IsNullOrEmpty(_manualDispatchTemplateId))" data-testid="browse-epics-btn" style="background: #7057ff;">Browse Epics</button>
                                <button class="btn-save" @onclick="OpenDrawer" disabled="@(string.IsNullOrEmpty(_manualDispatchTemplateId))" data-testid="browse-issues-btn">Browse Issues</button>
                                <button class="btn-save" @onclick="OpenPrDrawer" disabled="@(string.IsNullOrEmpty(_manualDispatchTemplateId))" data-testid="browse-prs-btn" style="background: var(--accent-secondary, #6366f1);">Browse Pull Requests</button>
                            </div>
                        </section>
                    }
                }
            }
            else if (activeRun is not null)
            {
                @if (activeRun.CurrentStep is PipelineStep.CloningRepository or PipelineStep.CreatingBranch
                    or PipelineStep.SyncingBrainRepoPreRun or PipelineStep.AnalyzingCode or PipelineStep.ReviewingAnalysis
                    or PipelineStep.GeneratingCode or PipelineStep.ReviewingCode or PipelineStep.RunningQualityGates
                    or PipelineStep.PreparingForPullRequest or PipelineStep.ReflectingOnRun
                    or PipelineStep.CreatingPullRequest or PipelineStep.Created
                    or PipelineStep.PostingAnalysis or PipelineStep.SyncingBrainRepoPostRun)
                {
                    <div class="progress-view">
                        <h2>Pipeline in Progress</h2>
                        @{ List<string> outputSnapshot; lock (_outputLock) { outputSnapshot = _outputLines.TakeLast(200).ToList(); } }
                        <OutputTerminal Lines="outputSnapshot" />
                    </div>
                }
            }
        </div>

        @if (activeRun is not null && (hasActiveRun || hasFinishedRun))
        {
            <PipelineSidebar Run="activeRun" IsRunning="PipelineService.IsRunning" OnCancel="CancelPipeline" MaxRetries="@_maxRetries" />
        }
    </div>
    <UndoSnackbar @ref="_undoSnackbar" />
</div>

<!-- Dispatch Drawers -->
<IssueDispatchDrawer IsOpen="_drawerOpen" Template="_drawerTemplate"
    Issues="_drawerIssues" IsLoading="_drawerLoading" HasMore="_drawerHasMore" Page="_drawerPage"
    IsDispatching="_drawerDispatching" IsBeingProcessed="@(id => IsIssueActive(id, _drawerTemplate?.IssueProviderId ?? ""))"
    Readiness="_drawerReadiness"
    AvailableLabels="_drawerLabels" SelectedLabels="_drawerSelectedLabels"
    OnToggleLabel="DrawerToggleLabel" OnClearLabels="DrawerClearLabels"
    OnClose="CloseDrawer" OnNextPage="DrawerNextPage" OnPrevPage="DrawerPrevPage" OnDispatch="DispatchFromDrawer">
    <HeaderPrefix>
        <nav class="dispatch-drawer-tabs" role="tablist" aria-label="Panel type">
            <button class="dispatch-drawer-tab active" role="tab" aria-selected="true">Issues</button>
            @if (ActiveDrawerTemplate?.ReviewEnabled == true)
            {
                <button class="dispatch-drawer-tab" role="tab" aria-selected="false" @onclick="SwitchToPrDrawer">Pull Requests</button>
            }
            @if (ActiveDrawerTemplate?.DecompositionEnabled == true)
            {
                <button class="dispatch-drawer-tab" role="tab" aria-selected="false" @onclick="SwitchToEpicDrawer">Epics</button>
            }
        </nav>
    </HeaderPrefix>
</IssueDispatchDrawer>

<PrDispatchDrawer IsOpen="_prDrawerOpen" Template="_prDrawerTemplate"
    PullRequests="_prDrawerPrs" IsLoading="_prDrawerLoading" HasMore="_prDrawerHasMore" Page="_prDrawerPage"
    IsDispatching="_prDrawerDispatching" IsBeingProcessed="@(id => IsIssueActive(id, _prDrawerTemplate?.IssueProviderId ?? ""))"
    AvailableLabels="_prDrawerLabels" SelectedLabels="_prDrawerSelectedLabels"
    OnToggleLabel="PrDrawerToggleLabel" OnClearLabels="PrDrawerClearLabels"
    OnClose="ClosePrDrawer" OnNextPage="PrDrawerNextPage" OnPrevPage="PrDrawerPrevPage" OnDispatch="DispatchPrReviewFromDrawer">
    <HeaderPrefix>
        <nav class="dispatch-drawer-tabs" role="tablist" aria-label="Panel type">
            <button class="dispatch-drawer-tab" role="tab" aria-selected="false" @onclick="SwitchToIssueDrawer">Issues</button>
            <button class="dispatch-drawer-tab active" role="tab" aria-selected="true">Pull Requests</button>
            @if (ActiveDrawerTemplate?.DecompositionEnabled == true)
            {
                <button class="dispatch-drawer-tab" role="tab" aria-selected="false" @onclick="SwitchToEpicDrawer">Epics</button>
            }
        </nav>
    </HeaderPrefix>
</PrDispatchDrawer>

<EpicDispatchDrawer IsOpen="_epicDrawerOpen" Template="_epicDrawerTemplate"
    Issues="_epicDrawerIssues" IsLoading="_epicDrawerLoading" HasMore="_epicDrawerHasMore" Page="_epicDrawerPage"
    IsDispatching="_epicDrawerDispatching" IsBeingProcessed="@(id => IsIssueActive(id, _epicDrawerTemplate?.IssueProviderId ?? ""))"
    AvailableLabels="_epicDrawerLabels" SelectedLabels="_epicDrawerSelectedLabels"
    OnToggleLabel="EpicDrawerToggleLabel" OnClearLabels="EpicDrawerClearLabels"
    OnClose="CloseEpicDrawer" OnNextPage="EpicDrawerNextPage" OnPrevPage="EpicDrawerPrevPage" OnDispatch="DispatchDecompositionFromDrawer">
    <HeaderPrefix>
        <nav class="dispatch-drawer-tabs" role="tablist" aria-label="Panel type">
            <button class="dispatch-drawer-tab" role="tab" aria-selected="false" @onclick="SwitchToIssueDrawer">Issues</button>
            @if (ActiveDrawerTemplate?.ReviewEnabled == true)
            {
                <button class="dispatch-drawer-tab" role="tab" aria-selected="false" @onclick="SwitchToPrDrawer">Pull Requests</button>
            }
            <button class="dispatch-drawer-tab active" role="tab" aria-selected="true">Epics</button>
        </nav>
    </HeaderPrefix>
</EpicDispatchDrawer>
