@page "/agent-coding"
@rendermode InteractiveServer
@implements IDisposable
@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models
@using CodingAgentWebUI.Pipeline.Services
@using CodingAgentWebUI.Orchestration
@using CodingAgentWebUI.Orchestration.Dispatch
@using CodingAgentWebUI.Orchestration.Health
@using CodingAgentWebUI.Orchestration.Registry
@using CodingAgentWebUI.Services
@using Serilog
@inject PipelineOrchestrationService PipelineService
@inject PipelineLoopService LoopService
@inject OrchestratorRunService RunService
@inject AgentRegistryService Registry
@inject JobDispatcherService Dispatcher
@inject IJobDispatcher JobDispatcher
@inject IConfigurationStore ConfigStore
@inject IProviderFactory ProviderFactory
@inject IJSRuntime JS

<div class="agent-coding-page">
    <header class="agent-header">
        <h1>Agent Coding</h1>
    </header>

    @if (LoopService.IsLoopActive)
    {
        <div class="settings-status status-info loop-status-bar">
            <span class="loop-status-text">@LoopService.StatusMessage</span>
            <button class="btn-revert loop-stop-btn" @onclick="StopLoop">⏹ Stop Loop</button>
        </div>
    }

    @if (LoopService.IsCircuitBroken)
    {
        <div class="settings-status status-error">
            @LoopService.StatusMessage
            <span style="margin-left: 1rem;">
                <button class="btn-save" @onclick="ResumeLoop" style="margin-right: 0.5rem;">Resume</button>
                <button class="btn-revert" @onclick="StopLoop">Stop</button>
            </span>
        </div>
    }

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="settings-status status-success">@_successMessage</div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="settings-status status-error">@_errorMessage</div>
    }

    @* Multi-agent run summary bar *@
    @{
        var agentRuns = RunService.GetActiveRuns();
        var agentCount = Registry.GetAllAgents().Count;
        var queueLength = Dispatcher.QueueLength;
        var implRunCount = agentRuns.Count(r => r.RunType == PipelineRunType.Implementation);
        var reviewRunCount = agentRuns.Count(r => r.RunType == PipelineRunType.Review);
    }
    @if (agentRuns.Count > 0 || queueLength > 0)
    {
        <div class="settings-status status-info" style="margin: 8px 20px 0;">
            <span>
                🤖 @agentCount agent(s) registered ·
                @agentRuns.Count agent run(s) active
                @if (implRunCount > 0 && reviewRunCount > 0)
                {
                    <text> (🔨@implRunCount impl · 🔍@reviewRunCount review)</text>
                }
                else if (reviewRunCount > 0)
                {
                    <text> (🔍@reviewRunCount review)</text>
                }
                @if (queueLength > 0)
                {
                    <text> · @queueLength job(s) queued</text>
                }
                · <a href="/agent-monitoring" style="color: var(--accent-light);">View Dashboard →</a>
            </span>
        </div>
    }

    @{
        var activeRun = PipelineService.ActiveRun;
        var hasActiveRun = activeRun is not null
            && activeRun.CurrentStep is not (PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled);
        var hasFinishedRun = activeRun is { CurrentStep: PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled };
    }

    <div class="agent-content-layout @(hasActiveRun || hasFinishedRun ? "with-sidebar" : "")">
        <div class="agent-main">
            @if (!PipelineService.IsRunning && activeRun is null or { CurrentStep: PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled })
            {
                <!-- Completion Summary -->
                @if (hasFinishedRun && _showCompletionOnly)
                {
                    <PipelineSummary Run="activeRun!" MaxRetries="@_maxRetries"
                                     OnBackToIssues="BackToIssues" />
                }

                @if (activeRun is null || hasFinishedRun)
                {
                    @if (!_showCompletionOnly)
                    {
                        <!-- ═══ Template Table ═══ -->
                        <section class="settings-section" style="margin: 16px 20px;">
                            <h2>Pipeline Job Templates</h2>

                            @if (_templates.Count == 0)
                            {
                                <div class="monitoring-empty">No pipeline job templates configured. Add at least one template to enable the multi-repo loop.</div>
                            }
                            else
                            {
                                <div class="monitoring-table-wrap">
                                    <table class="monitoring-table">
                                        <thead>
                                            <tr>
                                                <th>Name</th>
                                                <th>Issue Provider</th>
                                                <th>Repo Provider</th>
                                                <th>Brain</th>
                                                <th>CI</th>
                                                <th>Impl</th>
                                                <th>Review</th>
                                                <th>Decomp</th>
                                                <th>Enabled</th>
                                                <th>Status</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var template in _templates)
                                            {
                                                var status = GetTemplateStatus(template.Id);
                                                var isPolling = status?.IsCurrentlyPolling == true;
                                                var hasError = !string.IsNullOrEmpty(status?.LastError);
                                                var providerMissing = IsProviderMissing(template);

                                                <tr class="@(isPolling ? "monitoring-row-busy" : "") @(!template.Enabled ? "monitoring-row-disabled" : "")">
                                                    <td>
                                                        @template.Name
                                                        @if (providerMissing)
                                                        {
                                                            <span class="badge-disabled-table" title="Referenced provider no longer exists">⚠️</span>
                                                        }
                                                    </td>
                                                    <td class="monitoring-mono">@GetProviderDisplayName(template.IssueProviderId, _issueProviders)</td>
                                                    <td class="monitoring-mono">
                                                        @GetProviderDisplayName(template.RepoProviderId, _repoProviders)
                                                        @{ var previewLabels = GetLabelPreview(template.RepoProviderId); }
                                                        @if (previewLabels.Labels.Count > 0)
                                                        {
                                                            <button class="btn-label-preview" @onclick="() => ToggleLabelPreview(template.Id)" title="Show label-mapped resources">ℹ</button>
                                                        }
                                                    </td>
                                                    <td>@(string.IsNullOrEmpty(template.BrainProviderId) ? "—" : GetProviderDisplayName(template.BrainProviderId, _brainProviders))</td>
                                                    <td>@(string.IsNullOrEmpty(template.PipelineProviderId) ? "—" : GetProviderDisplayName(template.PipelineProviderId, _pipelineProviders))</td>
                                                    <td>
                                                        <label class="toggle-switch">
                                                            <input type="checkbox" checked="@template.ImplementationEnabled"
                                                                   @onchange="e => ToggleImplementationEnabled(template, (bool)(e.Value ?? false))" />
                                                            <span class="toggle-slider"></span>
                                                        </label>
                                                    </td>
                                                    <td>
                                                        <label class="toggle-switch">
                                                            <input type="checkbox" checked="@template.ReviewEnabled"
                                                                   @onchange="e => ToggleReviewEnabled(template, (bool)(e.Value ?? false))" />
                                                            <span class="toggle-slider"></span>
                                                        </label>
                                                    </td>
                                                    <td>
                                                        <label class="toggle-switch">
                                                            <input type="checkbox" checked="@template.DecompositionEnabled"
                                                                   @onchange="e => ToggleDecompositionEnabled(template, (bool)(e.Value ?? false))" />
                                                            <span class="toggle-slider"></span>
                                                        </label>
                                                    </td>
                                                    <td>
                                                        <label class="toggle-switch">
                                                            <input type="checkbox" checked="@template.Enabled"
                                                                   @onchange="e => ToggleTemplateEnabled(template, (bool)(e.Value ?? false))" />
                                                            <span class="toggle-slider"></span>
                                                        </label>
                                                        @if (LoopService.IsLoopActive && _recentlyToggled.Contains(template.Id))
                                                        {
                                                            <span class="monitoring-muted" style="font-size: 0.7rem; margin-left: 4px;">next cycle</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (LoopService.IsLoopActive && status != null)
                                                        {
                                                            @if (isPolling)
                                                            {
                                                                <span class="monitoring-status monitoring-status-busy">⟳ polling</span>
                                                            }
                                                            else if (hasError)
                                                            {
                                                                <span class="monitoring-status monitoring-status-disconnected" title="@status.LastError">
                                                                    ⚠ @status.ConsecutiveFailures fail(s)
                                                                </span>
                                                            }
                                                            else if (status.LastPollTime.HasValue)
                                                            {
                                                                <span class="monitoring-status monitoring-status-idle">
                                                                    @FormatTimeAgo(status.LastPollTime.Value) · @status.LastPollIssueCount issue(s)
                                                                </span>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <span class="monitoring-muted">—</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (!LoopService.IsLoopActive)
                                                        {
                                                            <button class="btn-delete" @onclick="() => ConfirmRemoveTemplate(template)">Remove</button>
                                                        }
                                                    </td>
                                                </tr>
                                                @if (_expandedPreviewTemplateId == template.Id)
                                                {
                                                    <tr class="label-preview-row">
                                                        <td colspan="10">
                                                            <div class="label-preview-inline">
                                                                <div class="label-preview-section">
                                                                    <span class="label-preview-heading">Labels:</span>
                                                                    @foreach (var label in previewLabels.Labels)
                                                                    {
                                                                        <span class="provider-label">@label</span>
                                                                    }
                                                                </div>
                                                                @if (previewLabels.QualityGates.Count > 0)
                                                                {
                                                                    <div class="label-preview-section">
                                                                        <span class="label-preview-heading">🔧 Quality Gates:</span>
                                                                        @foreach (var qg in previewLabels.QualityGates)
                                                                        {
                                                                            <span class="label-preview-item label-preview-qg">@qg</span>
                                                                        }
                                                                    </div>
                                                                }
                                                                @if (previewLabels.Reviewers.Count > 0)
                                                                {
                                                                    <div class="label-preview-section">
                                                                        <span class="label-preview-heading">📝 Reviewers:</span>
                                                                        @foreach (var rv in previewLabels.Reviewers)
                                                                        {
                                                                            <span class="label-preview-item label-preview-rv">@rv</span>
                                                                        }
                                                                    </div>
                                                                }
                                                                @if (previewLabels.Profiles.Count > 0)
                                                                {
                                                                    <div class="label-preview-section">
                                                                        <span class="label-preview-heading">🤖 Agent Profiles:</span>
                                                                        @foreach (var pr in previewLabels.Profiles)
                                                                        {
                                                                            <span class="label-preview-item label-preview-pr">@pr</span>
                                                                        }
                                                                    </div>
                                                                }
                                                                <div class="label-preview-section">
                                                                    <span class="label-preview-heading">🖥️ Agents:</span>
                                                                    @if (previewLabels.Agents.Count > 0)
                                                                    {
                                                                        @foreach (var ag in previewLabels.Agents)
                                                                        {
                                                                            <span class="label-preview-item label-preview-ag">@ag</span>
                                                                        }
                                                                        <span class="monitoring-muted">(@previewLabels.OnlineAgentCount online)</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="monitoring-muted">No agents available</span>
                                                                    }
                                                                </div>
                                                                @if (previewLabels.QualityGates.Count == 0 && previewLabels.Reviewers.Count == 0 && previewLabels.Profiles.Count == 0 && previewLabels.Agents.Count == 0)
                                                                {
                                                                    <div class="label-preview-section">
                                                                        <span class="monitoring-muted">No label-mapped resources match these labels</span>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            @* Add Template Form *@
                            @if (_showAddForm)
                            {
                                <div class="provider-form" style="margin-top: 12px;">
                                    <h3>Add Pipeline Job Template</h3>

                                    @if (!string.IsNullOrEmpty(_formError))
                                    {
                                        <div class="settings-status status-error">@_formError</div>
                                    }

                                    <div class="form-group">
                                        <label>Name *</label>
                                        <input type="text" @bind="_addForm.Name" placeholder="e.g. DotNet Main Repo" />
                                    </div>
                                    <div class="form-group">
                                        <label>Issue Provider *</label>
                                        <select @bind="_addForm.IssueProviderId">
                                            <option value="">-- Select --</option>
                                            @foreach (var p in _issueProviders)
                                            {
                                                <option value="@p.Id">@p.DisplayName</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label>Repo Provider *</label>
                                        <select @bind="_addForm.RepoProviderId">
                                            <option value="">-- Select --</option>
                                            @foreach (var p in _repoProviders)
                                            {
                                                <option value="@p.Id">@p.DisplayName</option>
                                            }
                                        </select>
                                    </div>
                                    @if (!string.IsNullOrEmpty(_addForm.RepoProviderId))
                                    {
                                        var formPreview = GetLabelPreview(_addForm.RepoProviderId);
                                        @if (formPreview.Labels.Count > 0)
                                        {
                                            <div class="label-preview-inline">
                                                <div class="label-preview-section">
                                                    <span class="label-preview-heading">Resolved Labels:</span>
                                                    @foreach (var label in formPreview.Labels)
                                                    {
                                                        <span class="provider-label">@label</span>
                                                    }
                                                </div>
                                                @if (formPreview.QualityGates.Count > 0)
                                                {
                                                    <div class="label-preview-section">
                                                        <span class="label-preview-heading">🔧 Quality Gates:</span>
                                                        @foreach (var qg in formPreview.QualityGates)
                                                        {
                                                            <span class="label-preview-item label-preview-qg">@qg</span>
                                                        }
                                                    </div>
                                                }
                                                @if (formPreview.Reviewers.Count > 0)
                                                {
                                                    <div class="label-preview-section">
                                                        <span class="label-preview-heading">📝 Reviewers:</span>
                                                        @foreach (var rv in formPreview.Reviewers)
                                                        {
                                                            <span class="label-preview-item label-preview-rv">@rv</span>
                                                        }
                                                    </div>
                                                }
                                                @if (formPreview.Profiles.Count > 0)
                                                {
                                                    <div class="label-preview-section">
                                                        <span class="label-preview-heading">🤖 Agent Profiles:</span>
                                                        @foreach (var pr in formPreview.Profiles)
                                                        {
                                                            <span class="label-preview-item label-preview-pr">@pr</span>
                                                        }
                                                    </div>
                                                }
                                                <div class="label-preview-section">
                                                    <span class="label-preview-heading">🖥️ Agents:</span>
                                                    @if (formPreview.Agents.Count > 0)
                                                    {
                                                        @foreach (var ag in formPreview.Agents)
                                                        {
                                                            <span class="label-preview-item label-preview-ag">@ag</span>
                                                        }
                                                        <span class="monitoring-muted">(@formPreview.OnlineAgentCount online)</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="monitoring-muted">No agents available</span>
                                                    }
                                                </div>
                                                @if (formPreview.QualityGates.Count == 0 && formPreview.Reviewers.Count == 0 && formPreview.Profiles.Count == 0 && formPreview.Agents.Count == 0)
                                                {
                                                    <div class="label-preview-section">
                                                        <span class="monitoring-muted">No label-mapped resources match these labels</span>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    }
                                    <div class="form-group">
                                        <label>Brain Provider (optional)</label>
                                        <select @bind="_addForm.BrainProviderId">
                                            <option value="">— None —</option>
                                            @foreach (var p in _brainProviders)
                                            {
                                                <option value="@p.Id">@p.DisplayName</option>
                                            }
                                        </select>
                                    </div>
                                    @if (!string.IsNullOrEmpty(_addForm.BrainProviderId))
                                    {
                                        <div class="form-group form-checkbox">
                                            <label>
                                                <input type="checkbox" @bind="_addForm.BrainReadOnly" />
                                                Brain Repository Read-Only
                                                <span class="form-hint-icon" aria-hidden="true" title="When enabled, the brain repo is cloned and read by the agent but no changes are written back.">?</span>
                                            </label>
                                        </div>
                                    }
                                    <div class="form-group">
                                        <label>Pipeline/CI Provider (optional)</label>
                                        <select @bind="_addForm.PipelineProviderId">
                                            <option value="">— None —</option>
                                            @foreach (var p in _pipelineProviders)
                                            {
                                                <option value="@p.Id">@p.DisplayName</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group form-checkbox">
                                        <label>
                                            <input type="checkbox" @bind="_addForm.ImplementationEnabled" />
                                            Implementation Enabled
                                            <span class="form-hint-icon" title="When enabled, this template dispatches implementation jobs from issues.">?</span>
                                        </label>
                                    </div>
                                    <div class="form-group form-checkbox">
                                        <label>
                                            <input type="checkbox" @bind="_addForm.ReviewEnabled" />
                                            Review Enabled
                                            <span class="form-hint-icon" title="When enabled, this template dispatches PR review jobs.">?</span>
                                        </label>
                                    </div>
                                    <div class="form-group form-checkbox">
                                        <label>
                                            <input type="checkbox" @bind="_addForm.DecompositionEnabled" />
                                            Decomposition Enabled
                                            <span class="form-hint-icon" title="When enabled, this template dispatches epic decomposition jobs from agent:epic labeled issues.">?</span>
                                        </label>
                                    </div>
                                    <div class="form-buttons">
                                        <button class="btn-save" @onclick="AddTemplate">Save</button>
                                        <button class="btn-cancel" @onclick="() => { _showAddForm = false; _formError = null; }">Cancel</button>
                                    </div>
                                </div>
                            }
                            else if (!LoopService.IsLoopActive)
                            {
                                <button class="btn-add" style="margin-top: 12px;" @onclick="ShowAddForm">+ Add Template</button>
                            }

                            @* Delete Confirmation *@
                            @if (_showDeleteConfirm && _deletingTemplate != null)
                            {
                                <div class="agent-detail-confirm" style="margin-top: 12px;">
                                    <p>Remove template <strong>@_deletingTemplate.Name</strong>?</p>
                                    <div class="confirm-buttons">
                                        <button class="btn-delete" @onclick="RemoveTemplate">Remove</button>
                                        <button class="btn-cancel" @onclick="() => _showDeleteConfirm = false">Cancel</button>
                                    </div>
                                </div>
                            }
                        </section>

                        <!-- ═══ Loop Controls ═══ -->
                        <section class="settings-section" style="margin: 0 20px 16px;">
                            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
                                @if (!LoopService.IsLoopActive)
                                {
                                    <button class="btn-save" @onclick="StartLoop" disabled="@(_templates.Count == 0)">▶ Start Loop</button>
                                }
                                else
                                {
                                    <button class="btn-revert" @onclick="StopLoop">⏹ Stop Loop</button>
                                }

                                @if (LoopService.IsLoopActive)
                                {
                                    <span class="monitoring-muted" style="font-size: 0.82rem;">
                                        Polling template @(LoopService.CurrentCycleTemplateIndex + 1) of @LoopService.CurrentCycleTemplateCount
                                        · Processed: @LoopService.ProcessedCount · Failed: @LoopService.FailedCount
                                    </span>
                                }
                            </div>

                            @if (LoopService.ValidationErrors.Count > 0)
                            {
                                <div class="settings-status status-error" style="margin-top: 8px;">
                                    <strong>Validation errors:</strong>
                                    <ul style="margin: 4px 0 0 16px; padding: 0;">
                                        @foreach (var err in LoopService.ValidationErrors)
                                        {
                                            <li>@err</li>
                                        }
                                    </ul>
                                </div>
                            }
                        </section>

                        <!-- ═══ Manual Dispatch ═══ -->
                        <section class="settings-section" style="margin: 0 20px 16px;">
                            <h2>Manual Dispatch</h2>
                            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
                                <select value="@_manualDispatchTemplateId" @onchange="OnTemplateChanged" class="dispatch-template-select" data-testid="template-select">
                                    <option value="">-- Select Template --</option>
                                    @foreach (var t in _templates.Where(t => t.Enabled))
                                    {
                                        <option value="@t.Id">@t.Name</option>
                                    }
                                </select>
                                <button class="btn-save" @onclick="OpenDrawer"
                                        disabled="@(string.IsNullOrEmpty(_manualDispatchTemplateId))"
                                        data-testid="browse-issues-btn">
                                    Browse Issues
                                </button>
                                <button class="btn-save" @onclick="OpenPrDrawer"
                                        disabled="@(string.IsNullOrEmpty(_manualDispatchTemplateId))"
                                        data-testid="browse-prs-btn"
                                        style="background: var(--accent-secondary, #6366f1);">
                                    Browse Pull Requests
                                </button>
                            </div>
                        </section>
                    }
                }
            }
            else if (activeRun is not null)
            {
                var run = activeRun;

                <!-- Pipeline Progress View -->
                @if (run.CurrentStep is PipelineStep.CloningRepository or PipelineStep.CreatingBranch
                    or PipelineStep.SyncingBrainRepoPreRun
                    or PipelineStep.AnalyzingCode or PipelineStep.ReviewingAnalysis
                    or PipelineStep.GeneratingCode
                    or PipelineStep.ReviewingCode
                    or PipelineStep.RunningQualityGates
                    or PipelineStep.PreparingForPullRequest
                    or PipelineStep.ReflectingOnRun
                    or PipelineStep.CreatingPullRequest or PipelineStep.Created
                    or PipelineStep.PostingAnalysis
                    or PipelineStep.SyncingBrainRepoPostRun)
                {
                    <div class="progress-view">
                        <h2>Pipeline in Progress</h2>

                        @{
                            List<string> outputSnapshot;
                            lock (_outputLock) { outputSnapshot = _outputLines.TakeLast(200).ToList(); }
                        }
                        <div class="output-panel" id="outputPanel" data-testid="output-panel">
                            @foreach (var line in outputSnapshot)
                            {
                                <div class="output-line" data-testid="output-line">@line</div>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        @if (activeRun is not null && (hasActiveRun || hasFinishedRun))
        {
            <PipelineSidebar Run="activeRun" IsRunning="PipelineService.IsRunning"
                             OnCancel="CancelPipeline" MaxRetries="@_maxRetries" />
        }
    </div>
</div>

<!-- ═══ Manual Dispatch Drawer ═══ -->
<div class="dispatch-drawer-overlay @(_drawerOpen ? "open" : "")" @onclick="CloseDrawer"></div>
<aside class="dispatch-drawer @(_drawerOpen ? "open" : "")">
    <div class="agent-detail-header">
        <h3>Browse Issues</h3>
        <button class="agent-detail-close" @onclick="CloseDrawer" aria-label="Close drawer">✕</button>
    </div>

    @if (_drawerTemplate != null)
    {
        <div class="agent-detail-section">
            <h4>Template: @_drawerTemplate.Name</h4>
        </div>

        @if (_drawerLoading)
        {
            <div class="loading-text" style="padding: 12px;">Loading issues...</div>
        }
        else
        {
            <!-- Filter -->
            <div style="padding: 0 0 8px;">
                <input type="text" @bind="_drawerFilter" @bind:event="oninput" @bind:after="FilterDrawerIssues"
                       placeholder="Filter by number or title..." style="width: 100%; padding: 6px 10px; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); font-size: 0.82rem;" />
            </div>

            @if (_drawerIssues.Count == 0)
            {
                <div class="monitoring-empty">No open issues found.</div>
            }
            else
            {
                <div class="agent-history-list" style="max-height: calc(100vh - 320px); overflow-y: auto;">
                    @foreach (var issue in _filteredDrawerIssues)
                    {
                        var isProcessing = JobDispatcher.IsIssueBeingProcessedOrQueued(issue.Identifier);
                        <div class="drawer-issue-item @(isProcessing ? "drawer-issue-dispatched" : "") @(_selectedDrawerIssue?.Identifier == issue.Identifier ? "drawer-issue-selected" : "")"
                             @onclick="() => SelectDrawerIssue(issue)"
                             data-testid="issue-row-@issue.Identifier"
                             style="@(isProcessing ? "opacity: 0.6; pointer-events: none;" : "")">
                            <div class="drawer-issue-header">
                                <span class="drawer-issue-number">#@issue.Identifier</span>
                                @if (isProcessing)
                                {
                                    <span class="badge-default" style="background: var(--accent); color: white;">DISPATCHED</span>
                                }
                            </div>
                            <div class="drawer-issue-title">@issue.Title</div>
                            <div class="drawer-issue-labels">
                                @foreach (var label in issue.Labels.Take(5))
                                {
                                    <span class="sidebar-label @GetLabelClass(label)">@label</span>
                                }
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (_drawerHasMore || _drawerPage > 1)
                {
                    <div style="display: flex; justify-content: center; gap: 8px; padding: 8px 0;">
                        <button class="btn-cancel" @onclick="DrawerPrevPage" disabled="@(_drawerPage <= 1)">← Prev</button>
                        <span class="monitoring-muted" style="align-self: center; font-size: 0.8rem;">Page @_drawerPage</span>
                        <button class="btn-cancel" @onclick="DrawerNextPage" disabled="@(!_drawerHasMore)">Next →</button>
                    </div>
                }
            }

            <!-- Selected Issue Detail -->
            @if (_selectedDrawerIssue != null)
            {
                <div class="agent-detail-section" style="margin-top: 12px; border-top: 1px solid var(--border); padding-top: 12px;">
                    <h4>#@_selectedDrawerIssue.Identifier — @_selectedDrawerIssue.Title</h4>
                    <div class="drawer-issue-labels" style="margin-bottom: 8px;">
                        @foreach (var label in _selectedDrawerIssue.Labels)
                        {
                            <span class="sidebar-label @GetLabelClass(label)">@label</span>
                        }
                    </div>
                    @if (_selectedDrawerIssue.CreatedAt.HasValue)
                    {
                        <p style="font-size: 0.78rem; color: var(--text-muted); margin: 0 0 8px;">
                            Created: @_selectedDrawerIssue.CreatedAt.Value.ToLocalTime().ToString("g")
                        </p>
                    }
                    <button class="btn-save" @onclick="DispatchFromDrawer" disabled="@_drawerDispatching"
                            data-testid="dispatch-issue-btn">
                        @(_drawerDispatching ? "Dispatching..." : $"Start Pipeline on #{_selectedDrawerIssue.Identifier}")
                    </button>
                </div>
            }
        }
    }
</aside>

<!-- ═══ Manual PR Review Dispatch Drawer ═══ -->
<div class="dispatch-drawer-overlay @(_prDrawerOpen ? "open" : "")" @onclick="ClosePrDrawer"></div>
<aside class="dispatch-drawer @(_prDrawerOpen ? "open" : "")">
    <div class="agent-detail-header">
        <h3>Browse Pull Requests</h3>
        <button class="agent-detail-close" @onclick="ClosePrDrawer" aria-label="Close drawer">✕</button>
    </div>

    @if (_prDrawerTemplate != null)
    {
        <div class="agent-detail-section">
            <h4>Template: @_prDrawerTemplate.Name</h4>
        </div>

        @if (_prDrawerLoading)
        {
            <div class="loading-text" style="padding: 12px;">Loading pull requests...</div>
        }
        else
        {
            <!-- Filter -->
            <div style="padding: 0 0 8px;">
                <input type="text" @bind="_prDrawerFilter" @bind:event="oninput" @bind:after="FilterDrawerPrs"
                       placeholder="Filter by number or title..." style="width: 100%; padding: 6px 10px; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); font-size: 0.82rem;" />
            </div>

            @if (_prDrawerPrs.Count == 0)
            {
                <div class="monitoring-empty">No open pull requests found.</div>
            }
            else
            {
                <div class="agent-history-list" style="max-height: calc(100vh - 320px); overflow-y: auto;">
                    @foreach (var pr in _filteredDrawerPrs)
                    {
                        var isProcessing = JobDispatcher.IsIssueBeingProcessedOrQueued(pr.Identifier);
                        <div class="drawer-issue-item @(isProcessing ? "drawer-issue-dispatched" : "") @(_selectedDrawerPr?.Identifier == pr.Identifier ? "drawer-issue-selected" : "")"
                             @onclick="() => SelectDrawerPr(pr)"
                             data-testid="pr-row-@pr.Identifier"
                             style="@(isProcessing ? "opacity: 0.6; pointer-events: none;" : "")">
                            <div class="drawer-issue-header">
                                <span class="drawer-issue-number">PR #@pr.Identifier</span>
                                @if (pr.IsDraft)
                                {
                                    <span class="badge-default" style="background: var(--text-muted); color: white;">DRAFT</span>
                                }
                                @if (isProcessing)
                                {
                                    <span class="badge-default" style="background: var(--accent); color: white;">DISPATCHED</span>
                                }
                            </div>
                            <div class="drawer-issue-title">@pr.Title</div>
                            <div class="drawer-issue-labels">
                                <span class="sidebar-label" style="background: var(--bg-hover); font-size: 0.7rem;">@pr.BranchName → @pr.TargetBranch</span>
                                @foreach (var label in pr.Labels.Take(4))
                                {
                                    <span class="sidebar-label @GetLabelClass(label)">@label</span>
                                }
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (_prDrawerHasMore || _prDrawerPage > 1)
                {
                    <div style="display: flex; justify-content: center; gap: 8px; padding: 8px 0;">
                        <button class="btn-cancel" @onclick="PrDrawerPrevPage" disabled="@(_prDrawerPage <= 1)">← Prev</button>
                        <span class="monitoring-muted" style="align-self: center; font-size: 0.8rem;">Page @_prDrawerPage</span>
                        <button class="btn-cancel" @onclick="PrDrawerNextPage" disabled="@(!_prDrawerHasMore)">Next →</button>
                    </div>
                }
            }

            <!-- Selected PR Detail -->
            @if (_selectedDrawerPr != null)
            {
                <div class="agent-detail-section" style="margin-top: 12px; border-top: 1px solid var(--border); padding-top: 12px;">
                    <h4>PR #@_selectedDrawerPr.Identifier — @_selectedDrawerPr.Title</h4>
                    <div style="font-size: 0.78rem; color: var(--text-muted); margin-bottom: 4px;">
                        @_selectedDrawerPr.BranchName → @_selectedDrawerPr.TargetBranch
                    </div>
                    <div class="drawer-issue-labels" style="margin-bottom: 8px;">
                        @foreach (var label in _selectedDrawerPr.Labels)
                        {
                            <span class="sidebar-label @GetLabelClass(label)">@label</span>
                        }
                    </div>
                    @if (_selectedDrawerPr.IsDraft)
                    {
                        <div class="settings-status status-error" style="margin-bottom: 8px; font-size: 0.78rem;">
                            ⚠️ This PR is a draft. Review will still be dispatched.
                        </div>
                    }
                    @if (_selectedDrawerPr.CreatedAt.HasValue)
                    {
                        <p style="font-size: 0.78rem; color: var(--text-muted); margin: 0 0 8px;">
                            Created: @_selectedDrawerPr.CreatedAt.Value.ToLocalTime().ToString("g")
                        </p>
                    }
                    <button class="btn-save" @onclick="DispatchPrReviewFromDrawer" disabled="@_prDrawerDispatching"
                            data-testid="dispatch-pr-btn"
                            style="background: var(--accent-secondary, #6366f1);">
                        @(_prDrawerDispatching ? "Dispatching..." : $"Start Review on PR #{_selectedDrawerPr.Identifier}")
                    </button>
                </div>
            }
        }
    }
</aside>

@code {
    private const string JsScrollToBottom = "scrollToBottom";
    private const string JsScrollActiveStep = "scrollActiveStepIntoView";

    private List<ProviderConfig> _issueProviders = new();
    private List<ProviderConfig> _repoProviders = new();
    private List<ProviderConfig> _pipelineProviders = new();
    private List<ProviderConfig> _brainProviders = new();
    private readonly object _outputLock = new();
    private List<string> _outputLines = new();

    // ── Label Preview State ──
    private IReadOnlyList<QualityGateConfiguration> _qualityGateConfigs = [];
    private IReadOnlyList<ReviewerConfiguration> _reviewerConfigs = [];
    private IReadOnlyList<AgentProfile> _agentProfiles = [];
    private PipelineConfiguration _pipelineConfig = new();

    private string? _errorMessage;
    private string? _successMessage;
    private bool _showCompletionOnly;
    private string? _lastRunId;
    private bool _disposed;
    private Timer? _elapsedTimer;
    private int _maxRetries = 3;

    // ── Template Table State ──
    private List<PipelineJobTemplate> _templates = new();
    private bool _showAddForm;
    private TemplateFormModel _addForm = new();
    private string? _formError;
    private bool _showDeleteConfirm;
    private PipelineJobTemplate? _deletingTemplate;
    private HashSet<string> _recentlyToggled = new();
    private string? _expandedPreviewTemplateId;

    // ── Manual Dispatch Drawer State ──
    private string _manualDispatchTemplateId = "";
    private bool _drawerOpen;
    private PipelineJobTemplate? _drawerTemplate;
    private List<IssueSummary> _drawerIssues = new();
    private List<IssueSummary> _filteredDrawerIssues = new();
    private bool _drawerLoading;
    private string _drawerFilter = "";
    private int _drawerPage = 1;
    private bool _drawerHasMore;
    private IssueSummary? _selectedDrawerIssue;
    private bool _drawerDispatching;

    // ── PR Drawer State ──
    private bool _prDrawerOpen;
    private PipelineJobTemplate? _prDrawerTemplate;
    private bool _prDrawerLoading;
    private List<PullRequestSummary> _prDrawerPrs = new();
    private List<PullRequestSummary> _filteredDrawerPrs = new();
    private string _prDrawerFilter = "";
    private int _prDrawerPage = 1;
    private bool _prDrawerHasMore;
    private PullRequestSummary? _selectedDrawerPr;
    private bool _prDrawerDispatching;

    private void OnTemplateChanged(ChangeEventArgs e)
    {
        _manualDispatchTemplateId = e.Value?.ToString() ?? "";
    }

    protected override async Task OnInitializedAsync()
    {
        PipelineService.OnChange += HandleStateChanged;
        PipelineService.OnOutputLine += HandleOutputLine;
        LoopService.OnChange += HandleStateChanged;

        _elapsedTimer = new Timer(ElapsedTimerTick, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));

        try
        {
            _issueProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Issue, CancellationToken.None)).ToList();
            var allRepoProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Repository, CancellationToken.None)).ToList();
            _pipelineProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Pipeline, CancellationToken.None)).ToList();

            _brainProviders = allRepoProviders.Where(p => p.RepositoryRole == RepositoryRole.Brain).ToList();
            _repoProviders = allRepoProviders.Where(p => p.RepositoryRole != RepositoryRole.Brain).ToList();

            var config = await ConfigStore.LoadPipelineConfigAsync(CancellationToken.None);
            _maxRetries = config.MaxRetries;
            _templates = config.PipelineJobTemplates.ToList();
            _pipelineConfig = config;

            _qualityGateConfigs = await ConfigStore.LoadQualityGateConfigsAsync(CancellationToken.None);
            _reviewerConfigs = await ConfigStore.LoadReviewerConfigsAsync(CancellationToken.None);
            _agentProfiles = await ConfigStore.LoadAgentProfilesAsync(CancellationToken.None);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load configuration: {ex.Message}";
        }
    }

    // ── Template Table Methods ──

    private void ShowAddForm()
    {
        _addForm = new TemplateFormModel();
        _formError = null;
        _showAddForm = true;
    }

    private void ToggleLabelPreview(string templateId)
    {
        _expandedPreviewTemplateId = _expandedPreviewTemplateId == templateId ? null : templateId;
    }

    private async Task AddTemplate()
    {
        _formError = null;

        if (string.IsNullOrWhiteSpace(_addForm.Name))
        {
            _formError = "Name is required.";
            return;
        }
        if (string.IsNullOrEmpty(_addForm.IssueProviderId))
        {
            _formError = "Issue Provider is required.";
            return;
        }
        if (string.IsNullOrEmpty(_addForm.RepoProviderId))
        {
            _formError = "Repo Provider is required.";
            return;
        }

        // Duplicate detection
        var isDuplicate = _templates.Any(t =>
            t.IssueProviderId == _addForm.IssueProviderId && t.RepoProviderId == _addForm.RepoProviderId);
        if (isDuplicate)
        {
            _formError = "A template with the same Issue Provider + Repo Provider combination already exists.";
            return;
        }

        var newTemplate = new PipelineJobTemplate
        {
            Id = Guid.NewGuid().ToString(),
            Name = _addForm.Name.Trim(),
            IssueProviderId = _addForm.IssueProviderId,
            RepoProviderId = _addForm.RepoProviderId,
            BrainProviderId = string.IsNullOrEmpty(_addForm.BrainProviderId) ? null : _addForm.BrainProviderId,
            PipelineProviderId = string.IsNullOrEmpty(_addForm.PipelineProviderId) ? null : _addForm.PipelineProviderId,
            BrainReadOnly = _addForm.BrainReadOnly,
            ImplementationEnabled = _addForm.ImplementationEnabled,
            ReviewEnabled = _addForm.ReviewEnabled,
            DecompositionEnabled = _addForm.DecompositionEnabled,
            Enabled = true
        };

        _templates.Add(newTemplate);
        await PersistTemplates();
        _showAddForm = false;
        _successMessage = $"Template \"{newTemplate.Name}\" added.";
        _ = ClearSuccessAfterDelay();
    }

    private void ConfirmRemoveTemplate(PipelineJobTemplate template)
    {
        _deletingTemplate = template;
        _showDeleteConfirm = true;
    }

    private async Task RemoveTemplate()
    {
        if (_deletingTemplate == null) return;
        _templates.RemoveAll(t => t.Id == _deletingTemplate.Id);
        await PersistTemplates();
        _showDeleteConfirm = false;
        _successMessage = $"Template \"{_deletingTemplate.Name}\" removed.";
        _deletingTemplate = null;
        _ = ClearSuccessAfterDelay();
    }

    private async Task ToggleTemplateEnabled(PipelineJobTemplate template, bool enabled)
    {
        var idx = _templates.FindIndex(t => t.Id == template.Id);
        if (idx < 0) return;

        _templates[idx] = template with { Enabled = enabled };
        await PersistTemplates();

        if (LoopService.IsLoopActive)
        {
            _recentlyToggled.Add(template.Id);
            _ = ClearToggleIndicator(template.Id);
        }
    }

    private async Task ToggleImplementationEnabled(PipelineJobTemplate template, bool enabled)
    {
        var idx = _templates.IndexOf(template);
        if (idx < 0) return;
        _templates[idx] = template with { ImplementationEnabled = enabled };
        await PersistTemplates();
        _recentlyToggled.Add(template.Id);
        _ = ClearRecentlyToggledAfterDelay(template.Id);
    }

    private async Task ToggleReviewEnabled(PipelineJobTemplate template, bool enabled)
    {
        var idx = _templates.IndexOf(template);
        if (idx < 0) return;
        _templates[idx] = template with { ReviewEnabled = enabled };
        await PersistTemplates();
        _recentlyToggled.Add(template.Id);
        _ = ClearRecentlyToggledAfterDelay(template.Id);
    }

    private async Task ToggleDecompositionEnabled(PipelineJobTemplate template, bool enabled)
    {
        var idx = _templates.IndexOf(template);
        if (idx < 0) return;
        _templates[idx] = template with { DecompositionEnabled = enabled };
        await PersistTemplates();
        _recentlyToggled.Add(template.Id);
        _ = ClearRecentlyToggledAfterDelay(template.Id);
    }

    private async Task ClearRecentlyToggledAfterDelay(string templateId)
    {
        await Task.Delay(3000);
        _recentlyToggled.Remove(templateId);
        try { await InvokeAsync(() => { if (!_disposed) StateHasChanged(); }); }
        catch (ObjectDisposedException) { }
    }

    private async Task PersistTemplates()
    {
        try
        {
            var config = await ConfigStore.LoadPipelineConfigAsync(CancellationToken.None);
            var updated = config with { PipelineJobTemplates = _templates.ToList() };
            await ConfigStore.SavePipelineConfigAsync(updated, CancellationToken.None);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to save: {ex.Message}";
        }
    }

    private async Task ClearToggleIndicator(string templateId)
    {
        await Task.Delay(3000);
        _recentlyToggled.Remove(templateId);
        try { await InvokeAsync(() => { if (!_disposed) StateHasChanged(); }); }
        catch (ObjectDisposedException) { }
    }

    private async Task ClearSuccessAfterDelay()
    {
        await Task.Delay(3000);
        try
        {
            await InvokeAsync(() =>
            {
                if (_disposed) return;
                _successMessage = null;
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException) { }
    }

    // ── Loop Controls ──

    private async Task StartLoop()
    {
        _errorMessage = null;
        var started = await LoopService.StartLoopAsync();
        if (!started)
        {
            if (LoopService.ValidationErrors.Count > 0)
                _errorMessage = "Loop failed to start due to validation errors (see below).";
            else if (LoopService.IsLoopActive)
                _errorMessage = "Loop is already active.";
            else
                _errorMessage = "A manual run is in progress. Wait for it to complete.";
        }
    }

    private void StopLoop()
    {
        LoopService.StopLoop();
    }

    private void ResumeLoop()
    {
        LoopService.ResumeLoop();
    }

    // ── Manual Dispatch Drawer ──

    private async Task OpenDrawer()
    {
        var template = _templates.FirstOrDefault(t => t.Id == _manualDispatchTemplateId);
        if (template == null) return;

        _drawerTemplate = template;
        _drawerOpen = true;
        _selectedDrawerIssue = null;
        _drawerFilter = "";
        _drawerPage = 1;
        await LoadDrawerIssues();
    }

    private void CloseDrawer()
    {
        _drawerOpen = false;
        _drawerTemplate = null;
        _drawerIssues.Clear();
        _filteredDrawerIssues.Clear();
        _selectedDrawerIssue = null;
    }

    private async Task LoadDrawerIssues()
    {
        if (_drawerTemplate == null) return;
        _drawerLoading = true;
        StateHasChanged();

        try
        {
            var providerConfig = _issueProviders.FirstOrDefault(p => p.Id == _drawerTemplate.IssueProviderId);
            if (providerConfig == null)
            {
                _errorMessage = "Issue provider not found for this template.";
                _drawerLoading = false;
                return;
            }

            await using var provider = ProviderFactory.CreateIssueProvider(providerConfig);
            var result = await provider.ListOpenIssuesAsync(_drawerPage, 25, CancellationToken.None);
            _drawerIssues = result.Items.ToList();
            _drawerHasMore = result.HasMore;
            FilterDrawerIssues();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load issues: {ex.Message}";
            _drawerIssues.Clear();
            _filteredDrawerIssues.Clear();
        }
        finally
        {
            _drawerLoading = false;
        }
    }

    private void FilterDrawerIssues()
    {
        if (string.IsNullOrWhiteSpace(_drawerFilter))
        {
            _filteredDrawerIssues = _drawerIssues;
        }
        else
        {
            var filter = _drawerFilter.Trim().ToLowerInvariant();
            _filteredDrawerIssues = _drawerIssues
                .Where(i => i.Identifier.Contains(filter, StringComparison.OrdinalIgnoreCase)
                         || i.Title.Contains(filter, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private async Task DrawerPrevPage()
    {
        if (_drawerPage <= 1) return;
        _drawerPage--;
        _selectedDrawerIssue = null;
        await LoadDrawerIssues();
    }

    private async Task DrawerNextPage()
    {
        if (!_drawerHasMore) return;
        _drawerPage++;
        _selectedDrawerIssue = null;
        await LoadDrawerIssues();
    }

    private void SelectDrawerIssue(IssueSummary issue)
    {
        _selectedDrawerIssue = _selectedDrawerIssue?.Identifier == issue.Identifier ? null : issue;
    }

    private async Task DispatchFromDrawer()
    {
        if (_selectedDrawerIssue == null || _drawerTemplate == null) return;

        // Validate provider IDs still exist
        if (!_issueProviders.Any(p => p.Id == _drawerTemplate.IssueProviderId) ||
            !_repoProviders.Any(p => p.Id == _drawerTemplate.RepoProviderId))
        {
            _errorMessage = "Template references providers that no longer exist.";
            return;
        }

        // Check if any agents are connected before attempting dispatch
        if (!JobDispatcher.HasRegisteredAgents)
        {
            _errorMessage = "Could not dispatch — no agents are currently connected.";
            return;
        }

        _drawerDispatching = true;
        StateHasChanged();

        try
        {
            var dispatched = await JobDispatcher.TryDispatchAsync(
                _selectedDrawerIssue.Identifier,
                _drawerTemplate.IssueProviderId,
                _drawerTemplate.RepoProviderId,
                _drawerTemplate.BrainProviderId,
                _drawerTemplate.PipelineProviderId,
                initiatedBy: "manual",
                CancellationToken.None,
                issueTitle: _selectedDrawerIssue.Title);

            if (dispatched)
            {
                _successMessage = $"✅ Dispatched #{_selectedDrawerIssue.Identifier}";
                CloseDrawer();
                _ = ClearSuccessAfterDelay();
            }
            else
            {
                _errorMessage = "Could not dispatch — issue is already being processed or queued, or no agents are available.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Dispatch failed: {ex.Message}";
        }
        finally
        {
            _drawerDispatching = false;
        }
    }

    // ── PR Drawer Methods ──

    private async Task OpenPrDrawer()
    {
        if (string.IsNullOrEmpty(_manualDispatchTemplateId)) return;
        _prDrawerTemplate = _templates.FirstOrDefault(t => t.Id == _manualDispatchTemplateId);
        if (_prDrawerTemplate == null) return;

        _prDrawerOpen = true;
        _prDrawerPage = 1;
        _prDrawerFilter = "";
        _selectedDrawerPr = null;
        await LoadPrDrawerPage();
    }

    private void ClosePrDrawer()
    {
        _prDrawerOpen = false;
        _selectedDrawerPr = null;
    }

    private async Task LoadPrDrawerPage()
    {
        if (_prDrawerTemplate == null) return;
        _prDrawerLoading = true;
        StateHasChanged();

        try
        {
            var repoConfig = _repoProviders.FirstOrDefault(p => p.Id == _prDrawerTemplate.RepoProviderId);
            if (repoConfig == null)
            {
                _prDrawerPrs = new();
                _filteredDrawerPrs = new();
                _prDrawerLoading = false;
                return;
            }

            await using var repoProvider = ProviderFactory.CreateRepositoryProvider(repoConfig);
            var result = await repoProvider.ListOpenPullRequestsAsync(_prDrawerPage, 30, null, CancellationToken.None);
            _prDrawerPrs = result.Items.ToList();
            _prDrawerHasMore = result.HasMore;
            FilterDrawerPrs();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load pull requests: {ex.Message}";
            _prDrawerPrs = new();
            _filteredDrawerPrs = new();
        }
        finally
        {
            _prDrawerLoading = false;
            StateHasChanged();
        }
    }

    private void FilterDrawerPrs()
    {
        if (string.IsNullOrWhiteSpace(_prDrawerFilter))
        {
            _filteredDrawerPrs = _prDrawerPrs;
        }
        else
        {
            var filter = _prDrawerFilter.Trim();
            _filteredDrawerPrs = _prDrawerPrs
                .Where(pr => pr.Identifier.Contains(filter, StringComparison.OrdinalIgnoreCase)
                          || pr.Title.Contains(filter, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private void SelectDrawerPr(PullRequestSummary pr) => _selectedDrawerPr = pr;

    private async Task PrDrawerNextPage()
    {
        _prDrawerPage++;
        await LoadPrDrawerPage();
    }

    private async Task PrDrawerPrevPage()
    {
        if (_prDrawerPage > 1) _prDrawerPage--;
        await LoadPrDrawerPage();
    }

    private async Task DispatchPrReviewFromDrawer()
    {
        if (_selectedDrawerPr == null || _prDrawerTemplate == null) return;
        _prDrawerDispatching = true;
        StateHasChanged();

        try
        {
            var dispatched = await JobDispatcher.TryDispatchReviewAsync(
                _selectedDrawerPr.Identifier,
                _selectedDrawerPr.BranchName,
                _selectedDrawerPr.Title,
                _selectedDrawerPr.Description,
                _selectedDrawerPr.Url,
                _selectedDrawerPr.TargetBranch,
                _prDrawerTemplate.IssueProviderId,
                _prDrawerTemplate.RepoProviderId,
                _prDrawerTemplate.BrainProviderId,
                initiatedBy: "manual",
                CancellationToken.None);

            if (dispatched)
            {
                _successMessage = $"PR #{_selectedDrawerPr.Identifier} dispatched for review.";
                _ = ClearSuccessAfterDelay();
                _selectedDrawerPr = null;
            }
            else
            {
                _errorMessage = $"PR #{_selectedDrawerPr.Identifier} is already being processed or queued.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to dispatch PR review: {ex.Message}";
        }
        finally
        {
            _prDrawerDispatching = false;
            StateHasChanged();
        }
    }

    // ── Helpers ──

    private ConfigStatusSnapshot? GetTemplateStatus(string templateId)
    {
        LoopService.TemplateStatuses.TryGetValue(templateId, out var status);
        return status;
    }

    private bool IsProviderMissing(PipelineJobTemplate template)
    {
        return !_issueProviders.Any(p => p.Id == template.IssueProviderId)
            || !_repoProviders.Any(p => p.Id == template.RepoProviderId);
    }

    private static string GetProviderDisplayName(string providerId, List<ProviderConfig> providers)
    {
        var provider = providers.FirstOrDefault(p => p.Id == providerId);
        return provider?.DisplayName ?? Truncate(providerId, 12);
    }

    private static string GetLabelClass(string label) => label switch
    {
        "agent:next" => "label-agent-next",
        "agent:in-progress" => "label-agent-progress",
        "agent:error" => "label-agent-error",
        "agent:needs-refinement" => "label-agent-refinement",
        _ => ""
    };

    private static string FormatTimeAgo(DateTimeOffset timestamp)
    {
        var ago = DateTimeOffset.UtcNow - timestamp;
        if (ago.TotalSeconds < 60) return $"{(int)ago.TotalSeconds}s ago";
        if (ago.TotalMinutes < 60) return $"{(int)ago.TotalMinutes}m ago";
        return $"{(int)ago.TotalHours}h ago";
    }

    private static string Truncate(string? value, int maxLength)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        return value.Length <= maxLength ? value : value[..(maxLength - 3)] + "...";
    }



    // ── Event Handlers ──

    private async void ElapsedTimerTick(object? state)
    {
        if (_disposed) return;
        var run = PipelineService.ActiveRun;
        if (run is null) return;
        if (run.CurrentStep is PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled)
            return;

        try
        {
            await InvokeAsync(() => { if (!_disposed) StateHasChanged(); });
        }
        catch (ObjectDisposedException) { }
    }

    private async void HandleStateChanged()
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed) return;

                var run = PipelineService.ActiveRun;
                if (run != null && run.RunId != _lastRunId)
                {
                    lock (_outputLock) { _outputLines.Clear(); }
                    _showCompletionOnly = false;
                    _lastRunId = run.RunId;
                }

                if (run is { CurrentStep: PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled })
                    _showCompletionOnly = true;

                StateHasChanged();
                try
                {
                    await JS.InvokeVoidAsync(JsScrollToBottom, "outputPanel");
                    await JS.InvokeVoidAsync(JsScrollActiveStep, "sidebarSteps");
                }
                catch (Exception ex) { Log.Debug(ex, "JS interop scroll failed during state change"); }
            });
        }
        catch (ObjectDisposedException) { }
    }

    private async void HandleOutputLine(string line)
    {
        if (_disposed) return;
        lock (_outputLock) { _outputLines.Add(line); }
        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed) return;
                StateHasChanged();
                try
                {
                    await JS.InvokeVoidAsync(JsScrollToBottom, "outputPanel");
                }
                catch (Exception ex) { Log.Debug(ex, "JS interop scroll failed during output"); }
            });
        }
        catch (ObjectDisposedException) { }
    }

    private async Task CancelPipeline()
    {
        try
        {
            await PipelineService.CancelPipelineAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Cancel error: {ex.Message}";
        }
    }

    private void BackToIssues()
    {
        _showCompletionOnly = false;
        _errorMessage = null;
    }

    public void Dispose()
    {
        _disposed = true;
        _elapsedTimer?.Dispose();
        PipelineService.OnChange -= HandleStateChanged;
        PipelineService.OnOutputLine -= HandleOutputLine;
        LoopService.OnChange -= HandleStateChanged;
    }

    // ── Label Preview ──

    private LabelPreviewResult GetLabelPreview(string repoProviderId)
    {
        var repoConfig = _repoProviders.FirstOrDefault(p => p.Id == repoProviderId);
        if (repoConfig is null)
            return new LabelPreviewResult();

        var labels = LabelResolver.ResolveRequiredLabels(repoConfig, _pipelineConfig);
        if (labels.Count == 0)
            return new LabelPreviewResult();

        var qgResolver = new QualityGateResolver();
        var matchedQgs = qgResolver.Resolve(_qualityGateConfigs, labels);

        var rvResolver = new ReviewerResolver();
        var matchedRvs = rvResolver.Resolve(_reviewerConfigs, labels);

        var profileResolver = new ProfileResolver();
        // Profiles use subset matching (profile labels ⊆ job labels)
        var matchedProfiles = _agentProfiles
            .Where(p => p.Enabled)
            .Where(p => p.MatchLabels.Count == 0 || p.MatchLabels.All(l => labels.Contains(l, StringComparer.OrdinalIgnoreCase)))
            .OrderByDescending(p => p.MatchLabels.Count)
            .ThenByDescending(p => p.Priority)
            .ToList();

        var allAgents = Registry.GetAllAgents()
            .Where(a => !a.Disabled)
            .Where(a => labels.Count == 0 || labels.All(l => a.Labels.Contains(l, StringComparer.OrdinalIgnoreCase)))
            .ToList();
        var onlineCount = allAgents.Count(a => a.Status != AgentStatus.Disconnected);

        return new LabelPreviewResult
        {
            Labels = labels,
            QualityGates = matchedQgs.Select(q => q.DisplayName).ToList(),
            Reviewers = matchedRvs.Select(r => $"{r.DisplayName} ({r.Agents.Count} agent{(r.Agents.Count != 1 ? "s" : "")})").ToList(),
            Profiles = matchedProfiles.Select(p => p.DisplayName).ToList(),
            Agents = allAgents.Select(a => a.AgentId).ToList(),
            OnlineAgentCount = onlineCount
        };
    }

    private sealed class LabelPreviewResult
    {
        public IReadOnlyList<string> Labels { get; init; } = [];
        public List<string> QualityGates { get; init; } = new();
        public List<string> Reviewers { get; init; } = new();
        public List<string> Profiles { get; init; } = new();
        public List<string> Agents { get; init; } = new();
        public int OnlineAgentCount { get; init; }
    }

