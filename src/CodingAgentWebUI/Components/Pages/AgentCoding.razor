@page "/agent-coding"
@rendermode InteractiveServer
@implements IDisposable
@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models
@using CodingAgentWebUI.Pipeline.Services
@using CodingAgentWebUI.Services
@inject PipelineOrchestrationService PipelineService
@inject PipelineLoopService LoopService
@inject OrchestratorRunService RunService
@inject AgentRegistryService Registry
@inject JobDispatcherService Dispatcher
@inject IJobDispatcher JobDispatcher
@inject IConfigurationStore ConfigStore
@inject IProviderFactory ProviderFactory
@inject IJSRuntime JS

<div class="agent-coding-page">
    <header class="agent-header">
        <h1>Agent Coding</h1>
    </header>

    @if (LoopService.IsLoopActive)
    {
        @* TODO: [RES-03] Add && !LoopService.IsCircuitBroken to avoid duplicate status message when circuit breaker trips (review finding #2) *@
        <div class="settings-status status-info loop-status-bar">
            <span class="loop-status-text">@LoopService.StatusMessage</span>
            <button class="btn-revert loop-stop-btn" @onclick="StopLoop">⏹ Stop Loop</button>
        </div>
    }

    @if (LoopService.IsCircuitBroken)
    {
        <div class="settings-status status-error">
            @LoopService.StatusMessage
            <span style="margin-left: 1rem;">
                <button class="btn-save" @onclick="ResumeLoop" style="margin-right: 0.5rem;">Resume</button>
                <button class="btn-revert" @onclick="StopLoop">Stop</button>
            </span>
        </div>
    }

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="settings-status status-success">@_successMessage</div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="settings-status status-error">@_errorMessage</div>
    }

    @* Multi-agent run summary bar *@
    @{
        var agentRuns = RunService.GetActiveRuns();
        var agentCount = Registry.GetAllAgents().Count;
        var queueLength = Dispatcher.QueueLength;
    }
    @if (agentRuns.Count > 0 || queueLength > 0)
    {
        <div class="settings-status status-info" style="margin: 8px 20px 0;">
            <span>
                🤖 @agentCount agent(s) registered ·
                @agentRuns.Count agent run(s) active
                @if (queueLength > 0)
                {
                    <text> · @queueLength job(s) queued</text>
                }
                · <a href="/agent-monitoring" style="color: var(--accent-light);">View Dashboard →</a>
            </span>
        </div>
    }

    @{
        var activeRun = PipelineService.ActiveRun;
        var hasActiveRun = activeRun is not null
            && activeRun.CurrentStep is not (PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled);
        var hasFinishedRun = activeRun is { CurrentStep: PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled };
    }

    <div class="agent-content-layout @(hasActiveRun || hasFinishedRun ? "with-sidebar" : "")">
        <div class="agent-main">
            @if (!PipelineService.IsRunning && activeRun is null or { CurrentStep: PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled })
            {
                <!-- Completion Summary -->
                @if (hasFinishedRun && _showCompletionOnly)
                {
                    <PipelineSummary Run="activeRun!" MaxRetries="@_maxRetries"
                                     OnBackToIssues="BackToIssues" />
                }

                <!-- Issue Selection + Pipeline Setup (two-column) -->
                @if (activeRun is null || hasFinishedRun)
                {
                    @if (!_showCompletionOnly)
                    {
                        <div class="pipeline-setup-layout">
                            <IssueListPanel IssueProviders="_issueProviders"
                                            ProviderFactory="ProviderFactory"
                                            InitialIssueProviderId="@_selectedIssueProviderId"
                                            IssuePageSize="_issuePageSize"
                                            SelectedIssueId="@_selectedIssueId"
                                            IsIssueProcessingOrQueued="id => JobDispatcher.IsIssueBeingProcessedOrQueued(id)"
                                            OnIssueProviderIdChanged="HandleIssueProviderIdChanged"
                                            OnIssueSelected="HandleIssueSelected"
                                            OnError="HandleChildError" />

                            <ProviderSelectionPanel RepoProviders="_repoProviders"
                                                    PipelineProviders="_pipelineProviders"
                                                    BrainProviders="_brainProviders"
                                                    SelectedIssueProviderId="@_selectedIssueProviderId"
                                                    SelectedIssueId="@_selectedIssueId"
                                                    SelectedIssueDetail="_selectedIssueDetail"
                                                    LinkedPullRequest="_linkedPullRequest"
                                                    SelectedRepoProviderId="@_selectedRepoProviderId"
                                                    SelectedAgentProviderId="@_selectedAgentProviderId"
                                                    SelectedPipelineProviderId="@_selectedPipelineProviderId"
                                                    SelectedBrainProviderId="@_selectedBrainProviderId"
                                                    SelectedRepoProviderIdChanged="HandleRepoProviderIdChanged"
                                                    SelectedPipelineProviderIdChanged="v => _selectedPipelineProviderId = v"
                                                    SelectedBrainProviderIdChanged="v => _selectedBrainProviderId = v"
                                                    OnStartPipeline="StartPipeline"
                                                    IsLoopActive="LoopService.IsLoopActive"
                                                    IsManualRunInProgress="PipelineService.IsRunning && !LoopService.IsLoopActive"
                                                    IsDispatching="_isDispatching"
                                                    IsDispatched="_isDispatched"
                                                    OnStartLoop="StartLoop"
                                                    OnStopLoop="StopLoop" />
                        </div>
                    }
                }
            }
            else if (activeRun is not null)
            {
                var run = activeRun;

                <!-- Pipeline Progress View -->
                @if (run.CurrentStep is PipelineStep.CloningRepository or PipelineStep.CreatingBranch
                    or PipelineStep.SyncingBrainRepoPreRun
                    or PipelineStep.AnalyzingCode or PipelineStep.GeneratingCode
                    or PipelineStep.ReviewingCode
                    or PipelineStep.RunningQualityGates
                    or PipelineStep.PreparingForPullRequest
                    or PipelineStep.ReflectingOnRun
                    or PipelineStep.CreatingPullRequest or PipelineStep.Created
                    or PipelineStep.PostingAnalysis
                    or PipelineStep.SyncingBrainRepoPostRun)
                {
                    <div class="progress-view">
                        <h2>Pipeline in Progress</h2>

                        @{
                            List<string> outputSnapshot;
                            lock (_outputLock) { outputSnapshot = _outputLines.TakeLast(200).ToList(); }
                        }
                        <div class="output-panel" id="outputPanel">
                            @foreach (var line in outputSnapshot)
                            {
                                <div class="output-line">@line</div>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        @if (activeRun is not null && (hasActiveRun || hasFinishedRun))
        {
            <PipelineSidebar Run="activeRun" IsRunning="PipelineService.IsRunning"
                             OnCancel="CancelPipeline" MaxRetries="@_maxRetries" />
        }
    </div>
</div>

@code {
    private List<ProviderConfig> _issueProviders = new();
    private List<ProviderConfig> _repoProviders = new();
    private List<ProviderConfig> _agentProviders = new();
    private List<ProviderConfig> _pipelineProviders = new();
    private List<ProviderConfig> _brainProviders = new();
    private readonly object _outputLock = new();
    private List<string> _outputLines = new();

    private string _selectedIssueProviderId = "";
    private string _selectedIssueId = "";
    private IssueDetail? _selectedIssueDetail;
    private LinkedPullRequest? _linkedPullRequest;
    private string _selectedRepoProviderId = "";
    private string _selectedAgentProviderId = "";
    private string _selectedPipelineProviderId = "";
    private string _selectedBrainProviderId = "";
    private string? _errorMessage;
    private string? _successMessage;
    private bool _isDispatching;
    private bool _isDispatched;
    private bool _showCompletionOnly;
    private string? _lastRunId;
    private bool _disposed;
    private Timer? _elapsedTimer;
    private int _maxRetries = 3;
    private int _issuePageSize = 25;

    private void HandleIssueProviderIdChanged(string providerId)
    {
        _selectedIssueProviderId = providerId;
        _errorMessage = null;
    }

    private async Task HandleIssueSelected((string IssueId, IssueDetail? Detail) selection)
    {
        _selectedIssueId = selection.IssueId;
        _selectedIssueDetail = selection.Detail;
        _isDispatched = false;
        _successMessage = null;
        await CheckForExistingPullRequestAsync();
    }

    private async Task HandleRepoProviderIdChanged(string providerId)
    {
        _selectedRepoProviderId = providerId;
        await CheckForExistingPullRequestAsync();
    }

    private async Task CheckForExistingPullRequestAsync()
    {
        _linkedPullRequest = null;

        if (string.IsNullOrEmpty(_selectedIssueId) || string.IsNullOrEmpty(_selectedRepoProviderId))
            return;

        var repoConfig = _repoProviders.FirstOrDefault(p => p.Id == _selectedRepoProviderId);
        if (repoConfig is null)
            return;

        try
        {
            await using var repoProvider = ProviderFactory.CreateRepositoryProvider(repoConfig);
            var prs = await repoProvider.GetAgentPullRequestsAsync(_selectedIssueId, CancellationToken.None);
            _linkedPullRequest = prs.OrderByDescending(pr => pr.Number).FirstOrDefault();
        }
        catch (Exception) { /* Non-critical — pipeline will detect rework at runtime */ }
    }

    private void HandleChildError(string? error)
    {
        _errorMessage = error;
    }

    protected override async Task OnInitializedAsync()
    {
        PipelineService.OnChange += HandleStateChanged;
        PipelineService.OnOutputLine += HandleOutputLine;
        LoopService.OnChange += HandleStateChanged;

        _elapsedTimer = new Timer(ElapsedTimerTick, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));

        try
        {
            _issueProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Issue, CancellationToken.None)).ToList();
            var allRepoProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Repository, CancellationToken.None)).ToList();
            _agentProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Agent, CancellationToken.None)).ToList();
            _pipelineProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Pipeline, CancellationToken.None)).ToList();

            _brainProviders = allRepoProviders.Where(p => p.RepositoryRole == RepositoryRole.Brain).ToList();
            _repoProviders = allRepoProviders.Where(p => p.RepositoryRole != RepositoryRole.Brain).ToList();

            var config = await ConfigStore.LoadPipelineConfigAsync(CancellationToken.None);
            _maxRetries = config.MaxRetries;
            _issuePageSize = Math.Clamp(config.IssuePageSize, 1, 100);

            if (config.LastUsedProviderIds.TryGetValue("issue", out var lastIssue) && _issueProviders.Any(p => p.Id == lastIssue))
                _selectedIssueProviderId = lastIssue;
            if (config.LastUsedProviderIds.TryGetValue("repository", out var lastRepo) && _repoProviders.Any(p => p.Id == lastRepo))
                _selectedRepoProviderId = lastRepo;
            if (config.LastUsedProviderIds.TryGetValue("agent", out var lastAgent) && _agentProviders.Any(p => p.Id == lastAgent))
                _selectedAgentProviderId = lastAgent;
            if (config.LastUsedProviderIds.TryGetValue("brain", out var lastBrain) && _brainProviders.Any(p => p.Id == lastBrain))
                _selectedBrainProviderId = lastBrain;
            if (config.LastUsedProviderIds.TryGetValue("pipeline", out var lastPipeline) && _pipelineProviders.Any(p => p.Id == lastPipeline))
                _selectedPipelineProviderId = lastPipeline;

            // Auto-select if only one provider of each type (fallback when no last-used)
            if (string.IsNullOrEmpty(_selectedIssueProviderId) && _issueProviders.Count == 1) _selectedIssueProviderId = _issueProviders[0].Id;
            if (string.IsNullOrEmpty(_selectedRepoProviderId) && _repoProviders.Count == 1) _selectedRepoProviderId = _repoProviders[0].Id;
            if (string.IsNullOrEmpty(_selectedAgentProviderId) && _agentProviders.Count == 1) _selectedAgentProviderId = _agentProviders[0].Id;
            if (string.IsNullOrEmpty(_selectedPipelineProviderId) && _pipelineProviders.Count == 1) _selectedPipelineProviderId = _pipelineProviders[0].Id;

            // Issue loading is handled by IssueListPanel on firstRender when InitialIssueProviderId is set
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load providers: {ex.Message}";
        }
    }

    private async void ElapsedTimerTick(object? state)
    {
        if (_disposed) return;
        var run = PipelineService.ActiveRun;
        if (run is null) return;
        if (run.CurrentStep is PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled)
            return;

        try
        {
            await InvokeAsync(() => { if (!_disposed) StateHasChanged(); });
        }
        catch (ObjectDisposedException) { }
    }

    private async void HandleStateChanged()
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed) return;

                var run = PipelineService.ActiveRun;
                if (run != null && run.RunId != _lastRunId)
                {
                    lock (_outputLock) { _outputLines.Clear(); }
                    _showCompletionOnly = false;
                    _lastRunId = run.RunId;
                }

                if (run is { CurrentStep: PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled })
                    _showCompletionOnly = true;

                StateHasChanged();
                try
                {
                    await JS.InvokeVoidAsync("scrollToBottom", "outputPanel");
                    await JS.InvokeVoidAsync("scrollActiveStepIntoView", "sidebarSteps");
                }
                catch { }
            });
        }
        catch (ObjectDisposedException) { }
    }

    private async void HandleOutputLine(string line)
    {
        if (_disposed) return;
        lock (_outputLock) { _outputLines.Add(line); }
        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed) return;
                StateHasChanged();
                try
                {
                    await JS.InvokeVoidAsync("scrollToBottom", "outputPanel");
                }
                catch { }
            });
        }
        catch (ObjectDisposedException) { }
    }

    private async Task StartPipeline()
    {
        _errorMessage = null;
        _successMessage = null;

        if (PipelineService.IsRunning)
        {
            _errorMessage = "A pipeline run is already in progress.";
            return;
        }

        if (LoopService.IsLoopActive)
        {
            _errorMessage = "Stop the loop to run manually.";
            return;
        }

        var canStart = !string.IsNullOrEmpty(_selectedIssueProviderId)
            && !string.IsNullOrEmpty(_selectedIssueId)
            && !string.IsNullOrEmpty(_selectedRepoProviderId);

        if (!canStart)
        {
            _errorMessage = "Please select an issue and repository provider.";
            return;
        }

        lock (_outputLock) { _outputLines.Clear(); }
        _showCompletionOnly = false;
        _isDispatching = true;
        _isDispatched = false;

        // Capture all IDs as locals before Task.Run — the user can change dropdowns while dispatch is in flight (review finding #1)
        var dispatchedIssueId = _selectedIssueId;
        var issueProviderId = _selectedIssueProviderId;
        var repoProviderId = _selectedRepoProviderId;
        var brainProviderId = string.IsNullOrEmpty(_selectedBrainProviderId) ? null : _selectedBrainProviderId;
        var pipelineProviderId = string.IsNullOrEmpty(_selectedPipelineProviderId) ? null : _selectedPipelineProviderId;

        try
        {
            // TODO: [ARC-10] Pass a component-scoped CancellationToken instead of CancellationToken.None so dispatch can be cancelled on navigation (review finding #2)
            _ = Task.Run(async () =>
            {
                try
                {
                    var dispatched = await JobDispatcher.TryDispatchAsync(
                        dispatchedIssueId,
                        issueProviderId, repoProviderId,
                        brainProviderId,
                        pipelineProviderId,
                        initiatedBy: "manual",
                        CancellationToken.None);

                    // TODO: [UX-22] Wrap InvokeAsync in try/catch ObjectDisposedException for consistency with the auto-clear path (review finding #3)
                    await InvokeAsync(() =>
                    {
                        if (_disposed) return;
                        _isDispatching = false;
                        if (dispatched)
                        {
                            _isDispatched = true;
                            _successMessage = $"✅ Dispatched #{dispatchedIssueId}";
                        }
                        else
                        {
                            _errorMessage = "Could not dispatch — issue is already being processed or queued, or no agents are available.";
                        }
                        StateHasChanged();
                    });

                    if (dispatched)
                    {
                        await Task.Delay(3000);
                        try
                        {
                            await InvokeAsync(() =>
                            {
                                if (_disposed) return;
                                _successMessage = null;
                                StateHasChanged();
                            });
                        }
                        catch (ObjectDisposedException) { }
                    }
                }
                catch (Exception ex)
                {
                    // TODO: [UX-22] Wrap InvokeAsync in try/catch ObjectDisposedException for consistency (review finding #3)
                    await InvokeAsync(() =>
                    {
                        if (_disposed) return;
                        _isDispatching = false;
                        _errorMessage = $"Pipeline dispatch failed: {ex.Message}";
                        StateHasChanged();
                    });
                }
            });
        }
        catch (Exception ex)
        {
            // TODO: [UX-22] Add explicit StateHasChanged() for consistency with inner paths (review finding from correctness review #1)
            _isDispatching = false;
            _errorMessage = $"Failed to dispatch pipeline: {ex.Message}";
        }
    }

    private void StartLoop()
    {
        _errorMessage = null;

        var canStart = !string.IsNullOrEmpty(_selectedIssueProviderId)
            && !string.IsNullOrEmpty(_selectedRepoProviderId);

        if (!canStart)
        {
            _errorMessage = "Please select an issue provider and repository provider.";
            return;
        }

        var started = LoopService.StartLoop(
            _selectedIssueProviderId, _selectedRepoProviderId,
            string.IsNullOrEmpty(_selectedBrainProviderId) ? null : _selectedBrainProviderId,
            string.IsNullOrEmpty(_selectedPipelineProviderId) ? null : _selectedPipelineProviderId);

        if (!started)
            _errorMessage = LoopService.IsLoopActive
                ? "Loop is already active."
                : "A manual run is in progress. Wait for it to complete.";
    }

    private void StopLoop()
    {
        LoopService.StopLoop();
    }

    private void ResumeLoop()
    {
        LoopService.ResumeLoop();
    }

    private async Task CancelPipeline()
    {
        try
        {
            await PipelineService.CancelPipelineAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Cancel error: {ex.Message}";
        }
    }

    private void BackToIssues()
    {
        _showCompletionOnly = false;
        _errorMessage = null;
    }

    public void Dispose()
    {
        _disposed = true;
        _elapsedTimer?.Dispose();
        PipelineService.OnChange -= HandleStateChanged;
        PipelineService.OnOutputLine -= HandleOutputLine;
        LoopService.OnChange -= HandleStateChanged;
    }
}
