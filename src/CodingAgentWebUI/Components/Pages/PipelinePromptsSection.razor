@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models

<section class="settings-section">
    <h2>Prompts</h2>
    <p class="section-description">System prompts sent to agents during analysis and implementation phases. Customize to adjust agent behavior and output format.</p>
    <div class="provider-form">
        <div class="form-group">
            <label>Analysis Prompt</label>
            <textarea @bind="_analysisPrompt" rows="6"></textarea>
            <button type="button" class="btn-revert" disabled="@(_analysisPrompt == PipelineConfiguration.DefaultAnalysisPrompt)" @onclick="() => _analysisPrompt = PipelineConfiguration.DefaultAnalysisPrompt">Reset to default</button>
        </div>
        <div class="form-group">
            <label>Implementation Prompt</label>
            <textarea @bind="_implementationPrompt" rows="6"></textarea>
            <button type="button" class="btn-revert" disabled="@(_implementationPrompt == PipelineConfiguration.DefaultImplementationPrompt)" @onclick="() => _implementationPrompt = PipelineConfiguration.DefaultImplementationPrompt">Reset to default</button>
        </div>
        <div class="advanced-toggle" @onclick="() => _showAdvanced = !_showAdvanced">
            <span class="toggle-chevron @(_showAdvanced ? "expanded" : "")">▶</span>
            <span>Advanced settings</span>
        </div>
        @if (_showAdvanced)
        {
        <div class="config-sub-fields" style="margin-top: 1rem;">
            <h3>Analysis Review (Adversarial)</h3>
            <div class="form-hint">
                ℹ️ When enabled, a second agent reviews the analysis in an isolated session and feeds findings back for refinement before implementation begins.
            </div>
            <div class="form-group form-checkbox">
                <label>
                    <input type="checkbox" @bind="_analysisReviewEnabled" />
                    Enable Analysis Review
                </label>
            </div>
            <div class="form-group">
                <label>Analysis Review Prompt</label>
                <textarea @bind="_analysisReviewPrompt" rows="6" disabled="@(!_analysisReviewEnabled)"></textarea>
                <button type="button" class="btn-revert" disabled="@(!_analysisReviewEnabled || _analysisReviewPrompt == PipelineConfiguration.DefaultAnalysisReviewPrompt)" @onclick="() => _analysisReviewPrompt = PipelineConfiguration.DefaultAnalysisReviewPrompt">Reset to default</button>
            </div>
            <div class="form-group">
                <label>Analysis Refinement Prompt</label>
                <textarea @bind="_analysisRefinementPrompt" rows="6" disabled="@(!_analysisReviewEnabled)"></textarea>
                <button type="button" class="btn-revert" disabled="@(!_analysisReviewEnabled || _analysisRefinementPrompt == PipelineConfiguration.DefaultAnalysisRefinementPrompt)" @onclick="() => _analysisRefinementPrompt = PipelineConfiguration.DefaultAnalysisRefinementPrompt">Reset to default</button>
            </div>
        </div>
        <div class="config-sub-fields" style="margin-top: 1rem;">
            <h3>Acceptance Criteria</h3>
            <div class="form-group form-checkbox">
                <label>
                    <input type="checkbox" @bind="_acceptanceCriteriaEnabled" />
                    Enable Acceptance Criteria Check
                </label>
            </div>
            <div class="form-group">
                <label>Acceptance Criteria Prompt</label>
                <textarea @bind="_acceptanceCriteriaPrompt" rows="6" disabled="@(!_acceptanceCriteriaEnabled)"></textarea>
                <button type="button" class="btn-revert" disabled="@(!_acceptanceCriteriaEnabled || _acceptanceCriteriaPrompt == DefaultPrompts.AcceptanceCriteriaCompliance)" @onclick="() => _acceptanceCriteriaPrompt = DefaultPrompts.AcceptanceCriteriaCompliance">Reset to default</button>
            </div>
        </div>
        }
        <div class="pipeline-form-actions">
            <button class="btn-save" @onclick="SaveAsync">Save Prompt Settings</button>
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public IConfigurationStore ConfigStore { get; set; } = default!;
    [Parameter] public EventCallback<(string Message, bool IsError)> OnShowStatus { get; set; }

    private string _analysisPrompt = PipelineConfiguration.DefaultAnalysisPrompt;
    private string _implementationPrompt = PipelineConfiguration.DefaultImplementationPrompt;
    private bool _acceptanceCriteriaEnabled = true;
    private string _acceptanceCriteriaPrompt = DefaultPrompts.AcceptanceCriteriaCompliance;
    private bool _analysisReviewEnabled = true;
    private string _analysisReviewPrompt = PipelineConfiguration.DefaultAnalysisReviewPrompt;
    private string _analysisRefinementPrompt = PipelineConfiguration.DefaultAnalysisRefinementPrompt;
    private bool _showAdvanced;

    protected override async Task OnInitializedAsync()
    {
        var config = await ConfigStore.LoadPipelineConfigAsync(CancellationToken.None);
        _analysisPrompt = config.AnalysisPrompt;
        _implementationPrompt = config.ImplementationPrompt;
        _acceptanceCriteriaEnabled = config.AcceptanceCriteriaEnabled;
        _acceptanceCriteriaPrompt = config.AcceptanceCriteriaPrompt;
        _analysisReviewEnabled = config.AnalysisReviewEnabled;
        _analysisReviewPrompt = config.AnalysisReviewPrompt;
        _analysisRefinementPrompt = config.AnalysisRefinementPrompt;
    }

    private async Task SaveAsync()
    {
        try
        {
            await ConfigStore.UpdatePipelineConfigAsync(
                current => current with
                {
                    AnalysisPrompt = _analysisPrompt,
                    ImplementationPrompt = _implementationPrompt,
                    AcceptanceCriteriaEnabled = _acceptanceCriteriaEnabled,
                    AcceptanceCriteriaPrompt = _acceptanceCriteriaPrompt,
                    AnalysisReviewEnabled = _analysisReviewEnabled,
                    AnalysisReviewPrompt = _analysisReviewPrompt,
                    AnalysisRefinementPrompt = _analysisRefinementPrompt
                },
                CancellationToken.None);
            await OnShowStatus.InvokeAsync(("Prompt settings saved.", false));
        }
        catch (Exception ex)
        {
            await OnShowStatus.InvokeAsync(($"Failed to save: {ex.Message}", true));
        }
    }
}
