<div class="output-panel" id="@PanelId" data-testid="output-panel">
    @foreach (var line in Lines)
    {
        <div class="output-line" data-testid="output-line">@line</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<string> Lines { get; set; } = [];
    [Parameter] public string PanelId { get; set; } = "outputPanel";
}
