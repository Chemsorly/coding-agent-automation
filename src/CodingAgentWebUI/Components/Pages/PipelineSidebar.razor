@using CodingAgentWebUI.Pipeline.Models

<aside class="pipeline-sidebar" id="pipelineSidebar">
    <div class="sidebar-header">
        <div class="sidebar-elapsed">⏱ Elapsed: @GetElapsedTime()</div>
        <div class="sidebar-issue" title="@Run.WorkspacePath">
            @if (Run.RunType == PipelineRunType.Review)
            {
                <span class="run-type-badge run-type-review" style="font-size: 0.75rem;">🔍 Review</span>
                <text> PR #@Run.IssueIdentifier · @Truncate(Run.IssueTitle, 30)</text>
            }
            else
            {
                <text>Issue #@Run.IssueIdentifier · @Truncate(Run.IssueTitle, 30)</text>
            }
        </div>
        @if (Run.IssueLabels.Count > 0)
        {
            <div class="sidebar-labels">
                🏷
                @foreach (var label in Run.IssueLabels)
                {
                    <span class="sidebar-label">@label</span>
                }
            </div>
        }
    </div>

    <div class="sidebar-steps" id="sidebarSteps">
        @foreach (var phase in _phases)
        {
            var visibleSteps = GetVisibleSteps(phase.Steps);
            if (visibleSteps.Count == 0) continue;

            var phaseState = GetPhaseState(visibleSteps);
            var isPhaseExpanded = IsPhaseExpanded(phase.Name, phaseState);
            var completedCount = CountCompleted(visibleSteps);
            var phaseStateClass = PhaseStateCssClass(phaseState);
            var phaseTestId = phase.TestId;

            <div @key="phase.Name" class="phase-group phase-group-@phaseStateClass"
                 data-testid="phase-@phaseTestId"
                 data-phase-state="@phaseStateClass">
                <div class="phase-header" @onclick="() => TogglePhase(phase.Name)">
                    <span class="phase-chevron">@(isPhaseExpanded ? "▾" : "▸")</span>
                    <span class="phase-icon">@GetPhaseIcon(phaseState)</span>
                    <span class="phase-name">@phase.Name</span>
                    <span class="phase-counter">@GetPhaseCounter(phaseState, completedCount, visibleSteps.Count)</span>
                </div>

                <div class="phase-body @(isPhaseExpanded ? "" : "phase-body-collapsed")"
                     aria-hidden="@(isPhaseExpanded ? "false" : "true")">
                    @foreach (var step in visibleSteps)
                    {
                        var state = GetStepState(step);
                        var isExpanded = state is StepState.Active or StepState.Failed or StepState.Revisited
                            || _expandedSteps.Contains(step)
                            || (state == StepState.Completed && HasDetails(step));
                        var stepStateClass = StepStateCssClass(state);

                        <div @key="step" class="step-card step-card-@stepStateClass"
                             id="step-@step.ToString()"
                             data-testid="pipeline-step-@step"
                             data-step-state="@stepStateClass"
                             @onclick="() => ToggleStep(step, state)" @onclick:stopPropagation="true">
                            <div class="step-card-header">
                                <span class="step-card-icon">@GetStepIcon(state)</span>
                                <span class="step-card-name">@FormatStepName(step)</span>
                            </div>

                            @if (isExpanded)
                            {
                                <div class="step-card-details">
                                    @RenderStepDetails(step, state)

                                    @if (state == StepState.Failed && !string.IsNullOrEmpty(Run.FailureReason))
                                    {
                                        <div class="step-detail step-detail-error">@Run.FailureReason</div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @if (IsRunning)
    {
        <div class="sidebar-footer">
            <button class="btn-sidebar-cancel" @onclick="OnCancel" data-testid="cancel-pipeline-btn">Cancel Pipeline</button>
        </div>
    }
</aside>

@code {
    /// <summary>The active pipeline run to display in the sidebar.</summary>
    [Parameter, EditorRequired] public PipelineRun Run { get; set; } = default!;

    /// <summary>Whether the pipeline is currently running (controls cancel button visibility).</summary>
    [Parameter] public bool IsRunning { get; set; }

    /// <summary>Callback invoked when the user clicks the cancel button.</summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    /// <summary>Maximum retry count from pipeline configuration (for QG attempt display).</summary>
    [Parameter] public int MaxRetries { get; set; } = 3;

    private readonly HashSet<PipelineStep> _expandedSteps = new();
    /// <summary>Phases manually expanded by the user (overrides auto-collapse for completed/pending).</summary>
    private readonly HashSet<string> _expandedPhases = new();
    /// <summary>Phases manually collapsed by the user (overrides auto-expand for active/failed/retry).</summary>
    private readonly HashSet<string> _collapsedPhases = new();
    private string? _lastRunId;

    private static readonly PhaseDefinition[] _phases =
    {
        new("Preparation", "preparation", new[] {
            PipelineStep.Created,
            PipelineStep.CloningRepository,
            PipelineStep.SyncingBrainRepoPreRun,
            PipelineStep.CreatingBranch,
            PipelineStep.VerifyingBaseline
        }),
        new("Analysis", "analysis", new[] {
            PipelineStep.AnalyzingCode,
            PipelineStep.ReviewingAnalysis,
            PipelineStep.PostingAnalysis
        }),
        new("Code Generation", "code-generation", new[] {
            PipelineStep.GeneratingCode,
            PipelineStep.ReviewingCode,
            PipelineStep.RunningQualityGates
        }),
        new("Review", "review", new[] {
            PipelineStep.ExtractingLinkedIssues,
            PipelineStep.ReviewingCode,
            PipelineStep.PostingFindings
        }),
        new("Decomposition Analysis", "decomposition-analysis", new[] {
            PipelineStep.DownloadingOpenIssues,
            PipelineStep.ExploringCodebase,
            PipelineStep.GeneratingPlan,
            PipelineStep.ReviewingPlan,
            PipelineStep.PostingPlan
        }),
        new("Decomposition", "decomposition", new[] {
            PipelineStep.GeneratingSubIssues,
            PipelineStep.CreatingIssues,
            PipelineStep.PostingSummary
        }),
        new("Finalization", "finalization", new[] {
            PipelineStep.PreparingForPullRequest,
            PipelineStep.CreatingPullRequest,
            PipelineStep.ReflectingOnRun,
            PipelineStep.SyncingBrainRepoPostRun
        })
    };

    private enum StepState { Completed, Active, Pending, Failed, Cancelled, Revisited }
    private enum PhaseState { Completed, Active, Pending, Failed, Cancelled, Retry }

    private sealed record PhaseDefinition(string Name, string TestId, PipelineStep[] Steps);

    protected override void OnParametersSet()
    {
        if (Run.RunId != _lastRunId)
        {
            _expandedSteps.Clear();
            _expandedPhases.Clear();
            _collapsedPhases.Clear();
            _lastRunId = Run.RunId;
        }
    }

    // ─── Phase-level logic ───────────────────────────────────────────────

    /// <summary>Filters out steps that should be hidden (skipped features, disabled brain, etc.).</summary>
    private List<PipelineStep> GetVisibleSteps(PipelineStep[] steps)
    {
        var visible = new List<PipelineStep>(steps.Length);
        foreach (var step in steps)
        {
            // Hide ReviewingAnalysis when skipped
            if (step == PipelineStep.ReviewingAnalysis
                && GetStepState(step) == StepState.Pending
                && Run.HighWaterMark > PipelineStep.ReviewingAnalysis)
                continue;

            // Hide brain sync steps when brain provider is not configured
            if (step is PipelineStep.SyncingBrainRepoPreRun or PipelineStep.SyncingBrainRepoPostRun
                && Run.BrainProviderConfigId == null)
                continue;

            // Hide implementation-only steps for review runs
            if (Run.RunType == PipelineRunType.Review
                && step is PipelineStep.VerifyingBaseline or PipelineStep.AnalyzingCode
                    or PipelineStep.ReviewingAnalysis or PipelineStep.PostingAnalysis
                    or PipelineStep.GeneratingCode or PipelineStep.RunningQualityGates
                    or PipelineStep.PreparingForPullRequest or PipelineStep.CreatingPullRequest
                    or PipelineStep.ReflectingOnRun or PipelineStep.SyncingBrainRepoPostRun)
                continue;

            // Hide review-only steps for implementation runs
            if (Run.RunType == PipelineRunType.Implementation
                && step is PipelineStep.ExtractingLinkedIssues or PipelineStep.PostingFindings)
                continue;

            // Hide duplicate ReviewingCode in the "Review" phase for implementation runs
            // (it's already shown in "Code Generation" phase)
            if (Run.RunType == PipelineRunType.Implementation
                && step == PipelineStep.ReviewingCode
                && steps.Contains(PipelineStep.ExtractingLinkedIssues))
                continue;

            // Hide decomposition-only phases for non-decomposition runs
            if (Run.RunType is not PipelineRunType.DecompositionAnalysis
                && step is PipelineStep.DownloadingOpenIssues or PipelineStep.ExploringCodebase
                    or PipelineStep.GeneratingPlan or PipelineStep.ReviewingPlan or PipelineStep.PostingPlan)
                continue;

            if (Run.RunType is not PipelineRunType.Decomposition
                && step is PipelineStep.GeneratingSubIssues or PipelineStep.CreatingIssues or PipelineStep.PostingSummary)
                continue;

            // Hide non-decomposition phases for decomposition runs
            if (Run.RunType is PipelineRunType.DecompositionAnalysis or PipelineRunType.Decomposition
                && step is PipelineStep.CreatingBranch or PipelineStep.VerifyingBaseline
                    or PipelineStep.AnalyzingCode or PipelineStep.ReviewingAnalysis or PipelineStep.PostingAnalysis
                    or PipelineStep.GeneratingCode or PipelineStep.ReviewingCode or PipelineStep.RunningQualityGates
                    or PipelineStep.ExtractingLinkedIssues or PipelineStep.PostingFindings
                    or PipelineStep.PreparingForPullRequest or PipelineStep.CreatingPullRequest
                    or PipelineStep.ReflectingOnRun or PipelineStep.SyncingBrainRepoPostRun)
                continue;

            visible.Add(step);
        }
        return visible;
    }

    /// <summary>Computes the aggregate phase state from its visible sub-steps.</summary>
    private PhaseState GetPhaseState(List<PipelineStep> visibleSteps)
    {
        var hasActive = false;
        var hasFailed = false;
        var hasCancelled = false;
        var hasRevisited = false;
        var allCompleted = true;
        var allPending = true;

        foreach (var step in visibleSteps)
        {
            var state = GetStepState(step);
            if (state != StepState.Completed) allCompleted = false;
            if (state != StepState.Pending) allPending = false;
            if (state == StepState.Active) hasActive = true;
            if (state == StepState.Failed) hasFailed = true;
            if (state == StepState.Cancelled) hasCancelled = true;
            if (state == StepState.Revisited) hasRevisited = true;
        }

        if (hasFailed) return PhaseState.Failed;
        if (hasCancelled) return PhaseState.Cancelled;
        if (hasActive) return PhaseState.Active;

        if (hasRevisited)
        {
            // Distinguish genuine retries from sub-operations:
            // A genuine retry means the pipeline went back to fix something (RetryCount > 0
            // or quality gates failed). A sub-operation means the current step is running
            // a child operation (e.g., PreparingForPullRequest runs final quality gates,
            // temporarily setting CurrentStep back to RunningQualityGates).
            // Show as Retry only when there's evidence of an actual retry attempt.
            if (Run.RetryCount > 0) return PhaseState.Retry;

            // If the first visible step in this phase was already reached (is Revisited)
            // and the current step is in a preceding phase, this is likely a sub-operation.
            // Show as Active (in progress) rather than Retry.
            return PhaseState.Active;
        }

        if (allCompleted) return PhaseState.Completed;
        if (allPending) return PhaseState.Pending;

        // Mix of completed and pending (partially done) — treat as active
        return PhaseState.Active;
    }

    /// <summary>Determines if a phase should be visually expanded, considering both auto-expansion and user overrides.</summary>
    private bool IsPhaseExpanded(string phaseName, PhaseState state)
    {
        // User explicitly collapsed an auto-expanded phase
        if (_collapsedPhases.Contains(phaseName)) return false;
        // User explicitly expanded a normally-collapsed phase
        if (_expandedPhases.Contains(phaseName)) return true;
        // Auto-expand active, failed, and retry phases
        return state is PhaseState.Active or PhaseState.Failed or PhaseState.Retry;
    }

    private static string GetPhaseIcon(PhaseState state) => state switch
    {
        PhaseState.Completed => "✅",
        PhaseState.Active => "▶",
        PhaseState.Failed => "❌",
        PhaseState.Cancelled => "⊘",
        PhaseState.Retry => "🔄",
        _ => "○"
    };

    private static string GetPhaseCounter(PhaseState state, int completed, int total) => state switch
    {
        PhaseState.Completed => $"{total}/{total} ✓",
        PhaseState.Active => $"{completed}/{total} in progress",
        PhaseState.Failed => $"{completed}/{total} failed",
        PhaseState.Retry => "(retry)",
        PhaseState.Cancelled => $"{completed}/{total} cancelled",
        _ => $"0/{total}"
    };

    /// <summary>Toggles phase expansion. Works for all phases including auto-expanded ones.</summary>
    private void TogglePhase(string phaseName)
    {
        // If currently in the collapsed override set, remove it (re-expand)
        if (_collapsedPhases.Remove(phaseName)) return;
        // If currently in the expanded override set, remove it (re-collapse)
        if (_expandedPhases.Remove(phaseName)) return;

        // No override exists — determine current visual state and toggle
        var phase = _phases.FirstOrDefault(p => p.Name == phaseName);
        if (phase == null) return;

        var visibleSteps = GetVisibleSteps(phase.Steps);
        var phaseState = GetPhaseState(visibleSteps);

        if (phaseState is PhaseState.Active or PhaseState.Failed or PhaseState.Retry)
        {
            // Auto-expanded → user wants to collapse
            _collapsedPhases.Add(phaseName);
        }
        else
        {
            // Auto-collapsed (Completed, Cancelled, Pending) → user wants to expand
            _expandedPhases.Add(phaseName);
        }
    }

    /// <summary>Counts completed steps without LINQ allocation.</summary>
    private int CountCompleted(List<PipelineStep> visibleSteps)
    {
        var count = 0;
        foreach (var step in visibleSteps)
            if (GetStepState(step) == StepState.Completed) count++;
        return count;
    }

    // ─── CSS class helpers (avoid ToString + ToLowerInvariant allocations) ─

    private static string PhaseStateCssClass(PhaseState state) => state switch
    {
        PhaseState.Completed => "completed",
        PhaseState.Active => "active",
        PhaseState.Pending => "pending",
        PhaseState.Failed => "failed",
        PhaseState.Cancelled => "cancelled",
        PhaseState.Retry => "retry",
        _ => "pending"
    };

    private static string StepStateCssClass(StepState state) => state switch
    {
        StepState.Completed => "completed",
        StepState.Active => "active",
        StepState.Pending => "pending",
        StepState.Failed => "failed",
        StepState.Cancelled => "cancelled",
        StepState.Revisited => "revisited",
        _ => "pending"
    };

    // ─── Step-level logic (unchanged) ────────────────────────────────────

    private StepState GetStepState(PipelineStep step)
    {
        var current = Run.CurrentStep;

        if (current is PipelineStep.Failed or PipelineStep.Cancelled)
        {
            var last = GetLastReachedStep();
            if ((int)step < (int)last) return StepState.Completed;
            if ((int)step == (int)last)
                return current == PipelineStep.Failed ? StepState.Failed : StepState.Cancelled;
            return StepState.Pending;
        }

        if (current == PipelineStep.Completed)
            return (int)step <= (int)PipelineStep.SyncingBrainRepoPostRun ? StepState.Completed : StepState.Pending;

        if (step == current) return StepState.Active;

        if ((int)step > (int)current && (int)step <= (int)Run.HighWaterMark)
            return StepState.Revisited;

        return (int)step < (int)current ? StepState.Completed : StepState.Pending;
    }

    private PipelineStep GetLastReachedStep() => Run.GetLastReachedStep();

    private static string GetStepIcon(StepState state) => state switch
    {
        StepState.Completed => "✅",
        StepState.Active => "▶",
        StepState.Failed => "❌",
        StepState.Cancelled => "⊘",
        StepState.Revisited => "🔄",
        _ => "○"
    };

    private static string FormatStepName(PipelineStep step) => step switch
    {
        PipelineStep.Created => "Pipeline Created",
        PipelineStep.CloningRepository => "Cloning Repository",
        PipelineStep.SyncingBrainRepoPreRun => "Loading Brain Context",
        PipelineStep.CreatingBranch => "Creating Branch",
        PipelineStep.VerifyingBaseline => "Verifying Baseline",
        PipelineStep.AnalyzingCode => "Analyzing Code",
        PipelineStep.ReviewingAnalysis => "Reviewing Analysis",
        PipelineStep.PostingAnalysis => "Posting Analysis",
        PipelineStep.GeneratingCode => "Generating Code",
        PipelineStep.ReviewingCode => "Reviewing Code",
        PipelineStep.RunningQualityGates => "Running Quality Gates",
        PipelineStep.ExtractingLinkedIssues => "Extracting Linked Issues",
        PipelineStep.PostingFindings => "Posting Review Findings",
        PipelineStep.PreparingForPullRequest => "Preparing for Pull Request",
        PipelineStep.CreatingPullRequest => "Creating Pull Request",
        PipelineStep.ReflectingOnRun => "Reflecting on Run",
        PipelineStep.SyncingBrainRepoPostRun => "Saving Brain Knowledge",
        PipelineStep.DownloadingOpenIssues => "Downloading Issues",
        PipelineStep.ExploringCodebase => "Exploring Codebase",
        PipelineStep.GeneratingPlan => "Generating Plan",
        PipelineStep.ReviewingPlan => "Reviewing Plan",
        PipelineStep.PostingPlan => "Posting Plan",
        PipelineStep.GeneratingSubIssues => "Generating Sub-Issues",
        PipelineStep.CreatingIssues => "Creating Issues",
        PipelineStep.PostingSummary => "Posting Summary",
        _ => step.ToString()
    };

    private void ToggleStep(PipelineStep step, StepState state)
    {
        if (state == StepState.Pending) return;
        if (!_expandedSteps.Remove(step))
            _expandedSteps.Add(step);
    }

    private bool HasDetails(PipelineStep step) => step switch
    {
        PipelineStep.Created => !string.IsNullOrEmpty(Run.ModelName),
        PipelineStep.CloningRepository => !string.IsNullOrEmpty(Run.RepositoryName),
        PipelineStep.SyncingBrainRepoPreRun => Run.BrainProviderConfigId != null,
        PipelineStep.CreatingBranch => !string.IsNullOrEmpty(Run.BranchName),
        PipelineStep.VerifyingBaseline => Run.BaselineHealthPassed.HasValue,
        PipelineStep.AnalyzingCode => true,
        PipelineStep.ReviewingAnalysis => true,
        PipelineStep.GeneratingCode => true,
        PipelineStep.ReviewingCode => true,
        PipelineStep.RunningQualityGates => Run.LatestQualityReport != null,
        PipelineStep.ExtractingLinkedIssues => true,
        PipelineStep.PostingFindings => true,
        PipelineStep.PreparingForPullRequest => false,
        PipelineStep.CreatingPullRequest => !string.IsNullOrEmpty(Run.PullRequestUrl),
        PipelineStep.ReflectingOnRun => Run.BrainProviderConfigId != null,
        PipelineStep.SyncingBrainRepoPostRun => Run.BrainProviderConfigId != null,
        _ => false
    };

    // ─── Step detail rendering ───────────────────────────────────────────

    private RenderFragment RenderStepDetails(PipelineStep step, StepState state) => __builder =>
    {
        if (step == PipelineStep.CloningRepository && !string.IsNullOrEmpty(Run.RepositoryName))
        {
            <div class="step-detail">@Run.RepositoryName</div>
        }
        else if (step == PipelineStep.SyncingBrainRepoPreRun && Run.BrainProviderConfigId != null)
        {
            <div class="step-detail">
                @if (state == StepState.Active)
                {
                    <span>Syncing...</span>
                }
                else if (Run.BrainContextLoaded)
                {
                    <span>✅ @Run.BrainKnowledgeFileCount knowledge files loaded</span>
                }
                else
                {
                    <span>⚠️ Brain context unavailable</span>
                }
            </div>
        }
        else if (step == PipelineStep.Created && !string.IsNullOrEmpty(Run.ModelName))
        {
            <div class="step-detail">Model: @Run.ModelName</div>
        }
        else if (step == PipelineStep.CreatingBranch && !string.IsNullOrEmpty(Run.BranchName))
        {
            <div class="step-detail step-detail-mono">@Truncate(Run.BranchName, 36)</div>
        }
        else if (step == PipelineStep.VerifyingBaseline && Run.BaselineHealthPassed.HasValue)
        {
            <div class="step-detail">@(Run.BaselineHealthPassed.Value ? "✅ Baseline healthy" : "⚠️ Pre-existing issues")</div>
        }
        else if (step == PipelineStep.AnalyzingCode)
        {
            <div class="step-detail">@(Run.AnalysisSkipped ? "Skipped (existing)" : "Agent analysis")</div>
            if (Run.AnalysisRecommendation == "not_ready")
            {
                <div class="step-detail">⚠️ Needs refinement</div>
            }
            else if (Run.AnalysisRecommendation == "wont_do")
            {
                <div class="step-detail">🚫 Won't do</div>
            }
        }
        else if (step == PipelineStep.ReviewingAnalysis)
        {
            <div class="step-detail">Adversarial review</div>
        }
        else if (step == PipelineStep.GeneratingCode)
        {
            <div class="step-detail-box">
                @if (state == StepState.Active)
                {
                    <div>🤖 Agent active</div>
                }
                @if (Run.FilesChangedCount > 0)
                {
                    <div>Files changed: @Run.FilesChangedCount</div>
                }
                @if (Run.LinesAdded > 0 || Run.LinesRemoved > 0)
                {
                    <div>+@Run.LinesAdded -@Run.LinesRemoved</div>
                }
                @if (state != StepState.Active && Run.FilesChangedCount == 0 && Run.LinesAdded == 0 && Run.LinesRemoved == 0)
                {
                    <div>No file changes recorded</div>
                }
            </div>
        }
        else if (step == PipelineStep.ReviewingCode)
        {
            <div class="step-detail-box">
                @if (state == StepState.Active && Run.CodeReviewIterationInProgress > 0)
                {
                    <div>🔍 Iteration @Run.CodeReviewIterationInProgress/@Run.CodeReviewIterationsTotal</div>
                    <div class="step-detail-sub">Agent is reviewing &amp; fixing code</div>
                }
                else if (Run.CodeReviewIterationsCompleted > 0)
                {
                    <div>@Run.CodeReviewIterationsCompleted/@Run.CodeReviewIterationsTotal iteration(s) done</div>
                }
                else if (state != StepState.Active && state != StepState.Pending)
                {
                    <div>Review complete</div>
                }
                @if (Run.CodeReviewAgentsRun.Count > 0)
                {
                    <div class="step-detail-sub">Agents: @string.Join(", ", Run.CodeReviewAgentsRun)</div>
                }
                @if (Run.CodeReviewCriticalCount > 0 || Run.CodeReviewWarningCount > 0 || Run.CodeReviewSuggestionCount > 0)
                {
                    <div class="step-detail-sub">🔴 @Run.CodeReviewCriticalCount critical · 🟡 @Run.CodeReviewWarningCount warning · 🔵 @Run.CodeReviewSuggestionCount suggestion</div>
                }
            </div>
        }
        else if (step == PipelineStep.RunningQualityGates)
        {
            if (Run.LatestQualityReport is { } qr)
            {
                <div class="step-detail-box">
                    @if (qr.AllPassed)
                    {
                        <div class="qg-header-pass">All gates passed ✅</div>
                    }
                    else
                    {
                        <div class="qg-header-fail">Attempt @(Run.QualityGateHistory.Count)/@(MaxRetries + 1)</div>
                    }

                    @if (qr.QgcResults.Count > 1)
                    {
                        @foreach (var qgcResult in qr.QgcResults)
                        {
                            <div class="qgc-sub-item @(qgcResult.Passed ? "qgc-pass" : "qgc-fail")">
                                <div class="qgc-sub-header">
                                    @(qgcResult.Passed ? "✅" : "❌") @qgcResult.DisplayName
                                </div>
                                <div class="qgc-sub-details">
                                    @if (qgcResult.Compilation is { } comp)
                                    {
                                        <span class="@(comp.Passed ? "qg-pass" : "qg-fail")">Build: @(comp.Passed ? "OK" : "FAIL")</span>
                                    }
                                    @if (qgcResult.Tests is { } tests)
                                    {
                                        <span class="@(tests.Passed ? "qg-pass" : "qg-fail")">Tests: @(tests.TestsPassed ?? 0)/@((tests.TestsPassed ?? 0) + (tests.TestsFailed ?? 0))</span>
                                    }
                                    @if (qgcResult.Coverage is { } cov)
                                    {
                                        <span class="@(cov.Passed ? "qg-pass" : "qg-fail")">Cov: @(cov.CoveragePercent?.ToString("F1") ?? "N/A")%</span>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="qg-line @(qr.Compilation.Passed ? "qg-pass" : "qg-fail")">
                            @(qr.Compilation.Passed ? "✅" : "❌") Compilation
                        </div>
                        <div class="qg-line @(qr.Tests.Passed ? "qg-pass" : "qg-fail")">
                            @(qr.Tests.Passed ? "✅" : "❌") Tests
                            <span class="qg-sub">@(qr.Tests.TestsPassed ?? 0) passed, @(qr.Tests.TestsFailed ?? 0) failed</span>
                        </div>
                        @if (qr.Coverage is { } cov)
                        {
                            <div class="qg-line @(cov.Passed ? "qg-pass" : "qg-fail")">
                                @(cov.Passed ? "✅" : "❌") Coverage
                                <span class="qg-sub">@(cov.CoveragePercent.HasValue ? $"{cov.CoveragePercent.Value.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)}%" : "N/A")</span>
                            </div>
                        }
                        @if (qr.SecurityScan is { } sec)
                        {
                            <div class="qg-line @(sec.Passed ? "qg-pass" : "qg-fail")">
                                @(sec.Passed ? "✅" : "❌") Security
                            </div>
                        }
                        else
                        {
                            <div class="qg-line qg-skip">— Security</div>
                        }
                    }

                    @if (qr.ExternalCi is { } ci)
                    {
                        <div class="qg-line @(ci.Passed ? "qg-pass" : "qg-fail")">
                            @(ci.Passed ? "✅" : "❌") External CI
                            @if (!ci.Passed && !string.IsNullOrEmpty(ci.Details))
                            {
                                <span class="qg-sub">@Truncate(ci.Details, 60)</span>
                            }
                        </div>
                    }

                    @{
                        var history = Run.QualityGateHistory.ToArray();
                    }
                    @if (history.Length > 1)
                    {
                        <div class="qg-history">
                            <div class="qg-history-title">Previous attempts:</div>
                            @for (var i = 0; i < history.Length - 1; i++)
                            {
                                var h = history[i];
                                var covPct = h.Coverage?.CoveragePercent;
                                <div class="qg-history-item">
                                    #@(i + 1): @(h.AllPassed ? "Passed ✅" : covPct.HasValue ? $"Coverage {covPct.Value.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)}% ❌" : "Failed ❌")
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }
        else if (step == PipelineStep.ExtractingLinkedIssues)
        {
            <div class="step-detail">
                @if (state == StepState.Active)
                {
                    <span>Extracting linked issues...</span>
                }
                else
                {
                    var linkedCount = Run.LinkedIssueContexts?.Count ?? 0;
                    @if (linkedCount > 0)
                    {
                        <span>✅ @linkedCount linked issue(s) found</span>
                    }
                    else
                    {
                        <span>⚠️ No linked issues (using PR metadata)</span>
                    }
                }
            </div>
        }
        else if (step == PipelineStep.PostingFindings)
        {
            <div class="step-detail-box">
                @if (state == StepState.Active)
                {
                    <span>Posting review findings...</span>
                }
                else
                {
                    @if (Run.CodeReviewCriticalCount > 0 || Run.CodeReviewWarningCount > 0 || Run.CodeReviewSuggestionCount > 0)
                    {
                        <div>🔴 @Run.CodeReviewCriticalCount critical · 🟡 @Run.CodeReviewWarningCount warning · 🔵 @Run.CodeReviewSuggestionCount suggestion</div>
                    }
                    else
                    {
                        <div>✅ No issues found</div>
                    }
                    @if (!string.IsNullOrEmpty(Run.ReviewPrUrl))
                    {
                        <div><a href="@Run.ReviewPrUrl" target="_blank" rel="noopener noreferrer" @onclick:stopPropagation="true">🔗 View PR</a></div>
                    }
                }
            </div>
        }
        else if (step == PipelineStep.CreatingPullRequest && !string.IsNullOrEmpty(Run.PullRequestUrl))
        {
            <div class="step-detail-box">
                <div>PR @(!string.IsNullOrEmpty(Run.PullRequestNumber) ? $"#{Run.PullRequestNumber}" : "") @(Run.IsDraftPr ? "(draft)" : "(final)")</div>
                @if (Run.FilesChangedCount > 0)
                {
                    <div>@Run.FilesChangedCount files changed</div>
                }
                @if (Run.BlacklistedFilesDetected.Count > 0)
                {
                    <div class="step-detail-warning">⚠️ @Run.BlacklistedFilesDetected.Count file(s) excluded (blacklisted)</div>
                }
                <div><a href="@Run.PullRequestUrl" target="_blank" rel="noopener noreferrer" @onclick:stopPropagation="true">🔗 View on GitHub</a></div>
            </div>
        }
        else if (step == PipelineStep.ReflectingOnRun && Run.BrainProviderConfigId != null)
        {
            <div class="step-detail">
                @if (state == StepState.Active)
                {
                    <span>Reflecting on run...</span>
                }
                else
                {
                    <span>✅ Reflection complete</span>
                }
            </div>
        }
        else if (step == PipelineStep.SyncingBrainRepoPostRun && Run.BrainProviderConfigId != null)
        {
            <div class="step-detail">
                @if (state == StepState.Active)
                {
                    <span>Syncing...</span>
                }
                else if (Run.BrainUpdatesPushed)
                {
                    <span>✅ @Run.BrainFilesCommitted file(s) pushed</span>
                }
                else
                {
                    <span>⚠️ Brain updates not persisted</span>
                }
            </div>
        }
        else if (step == PipelineStep.DownloadingOpenIssues)
        {
            <div class="step-detail">
                @if (state == StepState.Active)
                {
                    <span>Downloading open issues...</span>
                }
                else if (Run.OpenIssuesDownloaded > 0)
                {
                    <span>✅ @Run.OpenIssuesDownloaded issues downloaded</span>
                }
                else
                {
                    <span>No open issues found</span>
                }
            </div>
        }
        else if (step == PipelineStep.ExploringCodebase)
        {
            <div class="step-detail">
                @if (state == StepState.Active)
                {
                    <span>🔍 Agent exploring codebase...</span>
                }
                else
                {
                    <span>Codebase explored</span>
                }
            </div>
        }
        else if (step == PipelineStep.GeneratingPlan)
        {
            <div class="step-detail">
                @if (state == StepState.Active)
                {
                    <span>📝 Generating decomposition plan...</span>
                }
                else
                {
                    <span>✅ Plan generated</span>
                }
            </div>
        }
        else if (step == PipelineStep.ReviewingPlan)
        {
            <div class="step-detail">
                @if (state == StepState.Active)
                {
                    <span>🔍 Adversarial review in progress...</span>
                }
                else
                {
                    <span>✅ Plan validated</span>
                }
            </div>
        }
        else if (step == PipelineStep.PostingPlan)
        {
            <div class="step-detail">
                @if (state == StepState.Active)
                {
                    <span>Posting plan comment...</span>
                }
                else
                {
                    <span>✅ Plan posted for review</span>
                }
            </div>
        }
        else if (step == PipelineStep.GeneratingSubIssues)
        {
            <div class="step-detail">
                @if (state == StepState.Active)
                {
                    <span>🤖 Agent generating sub-issues...</span>
                }
                else
                {
                    <span>Sub-issue files generated</span>
                }
            </div>
        }
        else if (step == PipelineStep.CreatingIssues)
        {
            <div class="step-detail-box">
                @if (state == StepState.Active)
                {
                    <span>Creating GitHub issues...</span>
                }
                @if (Run.DecompositionSubIssuesAttempted > 0)
                {
                    <div>✅ @Run.DecompositionSubIssuesCreated/@Run.DecompositionSubIssuesAttempted created</div>
                    @if (Run.DecompositionSubIssuesCreated < Run.DecompositionSubIssuesAttempted)
                    {
                        <div class="step-detail-warning">⚠️ @(Run.DecompositionSubIssuesAttempted - Run.DecompositionSubIssuesCreated) failed</div>
                    }
                }
            </div>
        }
        else if (step == PipelineStep.PostingSummary)
        {
            <div class="step-detail">
                @if (state == StepState.Active)
                {
                    <span>Posting summary comment...</span>
                }
                else
                {
                    <span>✅ Summary posted</span>
                }
            </div>
        }
    };

    // ─── Utilities ───────────────────────────────────────────────────────

    private string GetElapsedTime()
    {
        var elapsed = (Run.CompletedAt ?? DateTime.UtcNow) - Run.StartedAt;
        return elapsed.ToString(@"hh\:mm\:ss");
    }

    private static string Truncate(string? value, int maxLength)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        return value.Length <= maxLength ? value : value[..(maxLength - 3)] + "...";
    }
}
