@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models
@inject IProjectStore ProjectStore

<div class="settings-tree">
    <div class="tree-group">
        <div class="tree-group-header" @onclick="ToggleProviders" aria-expanded="@_providersExpanded.ToString().ToLower()">
            <span class="tree-chevron"><Icon Name="@(_providersExpanded ? "chevron-down" : "chevron-right")" /></span>
            Providers
        </div>
        @if (_providersExpanded)
        {
            <div class="tree-group-children">
                <div class="tree-node @(SelectedNode == SettingsNodes.ProvidersIssue ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.ProvidersIssue)">
                    Issue
                </div>
                <div class="tree-node @(SelectedNode == SettingsNodes.ProvidersRepository ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.ProvidersRepository)">
                    Repository
                </div>
                <div class="tree-node @(SelectedNode == SettingsNodes.ProvidersAgent ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.ProvidersAgent)">
                    Agent
                </div>
                <div class="tree-node @(SelectedNode == SettingsNodes.ProvidersPipeline ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.ProvidersPipeline)">
                    Pipeline
                </div>
            </div>
        }
    </div>

    <div class="tree-group">
        <div class="tree-group-header" @onclick="ToggleProjects" aria-expanded="@_projectsExpanded.ToString().ToLower()">
            <span class="tree-chevron"><Icon Name="@(_projectsExpanded ? "chevron-down" : "chevron-right")" /></span>
            Projects
        </div>
        @if (_projectsExpanded)
        {
            <div class="tree-group-children">
                <div class="tree-node @(SelectedNode == SettingsNodes.Projects ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.Projects)">
                    Manage
                </div>
                @foreach (var project in _projects)
                {
                    var nodeId = $"{SettingsNodes.ProjectDetail}:{project.Id}";
                    var isDefault = project.Id == WellKnownIds.DefaultProjectId;
                    <div class="tree-node @(SelectedNode == nodeId ? "active" : "")"
                         @onclick="() => SelectNode(nodeId)">
                        @project.Name
                        @if (isDefault)
                        {
                            <span class="badge-default">default</span>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <div class="tree-group">
        <div class="tree-group-header" @onclick="TogglePipeline" aria-expanded="@_pipelineExpanded.ToString().ToLower()">
            <span class="tree-chevron"><Icon Name="@(_pipelineExpanded ? "chevron-down" : "chevron-right")" /></span>
            Global Defaults
        </div>
        @if (_pipelineExpanded)
        {
            <div class="tree-group-children">
                <div class="tree-node @(SelectedNode == SettingsNodes.PipelineGeneral ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.PipelineGeneral)">
                    General
                </div>
                <div class="tree-node @(SelectedNode == SettingsNodes.PipelineLoop ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.PipelineLoop)">
                    Pipeline Loop
                </div>
                <div class="tree-node @(SelectedNode == SettingsNodes.PipelinePrompts ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.PipelinePrompts)">
                    Prompts
                </div>
                <div class="tree-node @(SelectedNode == SettingsNodes.PipelineDecomposition ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.PipelineDecomposition)">
                    Decomposition
                </div>
                <div class="tree-node @(SelectedNode == SettingsNodes.PipelineImplementation ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.PipelineImplementation)">
                    Implementation
                </div>
                <div class="tree-node @(SelectedNode == SettingsNodes.PipelineReview ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.PipelineReview)">
                    Review
                </div>
                <div class="tree-node @(SelectedNode == SettingsNodes.PipelineConsolidation ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.PipelineConsolidation)">
                    Consolidation
                </div>
                <div class="tree-node @(SelectedNode == SettingsNodes.PipelineAdvanced ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.PipelineAdvanced)">
                    Advanced
                </div>
            </div>
        }
    </div>

    <div class="tree-group">
        <div class="tree-group-header" @onclick="ToggleLabelRouting" aria-expanded="@_labelRoutingExpanded.ToString().ToLower()">
            <span class="tree-chevron"><Icon Name="@(_labelRoutingExpanded ? "chevron-down" : "chevron-right")" /></span>
            Label Routing
        </div>
        @if (_labelRoutingExpanded)
        {
            <div class="tree-group-children">
                <div class="tree-node @(SelectedNode == SettingsNodes.AgentProfiles ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.AgentProfiles)">
                    Agent Profiles
                </div>
                <div class="tree-node @(SelectedNode == SettingsNodes.QualityGateConfigs ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.QualityGateConfigs)">
                    Quality Gate Configs
                </div>
                <div class="tree-node @(SelectedNode == SettingsNodes.ReviewerConfigs ? "active" : "")"
                     @onclick="() => SelectNode(SettingsNodes.ReviewerConfigs)">
                    Reviewer Configs
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public string SelectedNode { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> OnNodeSelected { get; set; }

    private bool _providersExpanded = true;
    private bool _projectsExpanded = true;
    private bool _pipelineExpanded = true;
    private bool _labelRoutingExpanded = true;

    private IReadOnlyList<PipelineProject> _projects = [];

    protected override async Task OnInitializedAsync()
    {
        _projects = await ProjectStore.LoadProjectsAsync(CancellationToken.None);
    }

    public async Task RefreshProjectsAsync()
    {
        _projects = await ProjectStore.LoadProjectsAsync(CancellationToken.None);
        StateHasChanged();
    }

    private void ToggleProviders()
    {
        _providersExpanded = !_providersExpanded;
    }

    private void ToggleProjects()
    {
        _projectsExpanded = !_projectsExpanded;
    }

    private void TogglePipeline()
    {
        _pipelineExpanded = !_pipelineExpanded;
    }

    private void ToggleLabelRouting()
    {
        _labelRoutingExpanded = !_labelRoutingExpanded;
    }

    private async Task SelectNode(string nodeId)
    {
        await OnNodeSelected.InvokeAsync(nodeId);
    }
}
