@page "/settings"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models
@using CodingAgentWebUI.Infrastructure.GitHub
@using CodingAgentWebUI.Orchestration
@using CodingAgentWebUI.Orchestration.Dispatch
@using CodingAgentWebUI.Orchestration.Health
@using CodingAgentWebUI.Orchestration.Registry
@using CodingAgentWebUI.Services
@using Serilog
@inject IConfigurationStore ConfigStore
@inject GitHubValidationService GitHubValidator
@inject IProviderFactory ProviderFactory
@inject ModelFetchService ModelFetchService

<div class="settings-page">
    <header class="settings-header">
        <h1>Settings</h1>
    </header>

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <div class="settings-status @(_isError ? "status-error" : "status-success")">@_statusMessage</div>
    }

    <div class="settings-layout">
        <SettingsTreeNav SelectedNode="@_selectedNode"
                         OnNodeSelected="SelectNode"
                         PipelineProviderCount="_pipelineProviders.Count" />

        <div class="settings-content">
            @switch (_selectedNode)
            {
                case SettingsNodes.ProvidersIssue:
                    <IssueProviderSection
                        Providers="_issueProviders"
                        ConfigStore="ConfigStore"
                        GitHubValidator="GitHubValidator"
                        ProviderFactory="ProviderFactory"
                        OnDelete="id => DeleteProvider(id, ProviderKind.Issue)"
                        OnSaved="OnIssueProviderSaved" />
                    break;
                case SettingsNodes.ProvidersRepository:
                    <RepoProviderSection
                        Providers="_repoProviders"
                        ConfigStore="ConfigStore"
                        GitHubValidator="GitHubValidator"
                        OnDelete="id => DeleteProvider(id, ProviderKind.Repository)"
                        OnSaved="OnGitHubProviderSaved" />
                    break;
                case SettingsNodes.ProvidersAgent:
                    <AgentProviderSection
                        Providers="_agentProviders"
                        ConfigStore="ConfigStore"
                        OnDelete="id => DeleteProvider(id, ProviderKind.Agent)"
                        OnSaved="OnAgentProviderSaved"
                        OnShowStatus="s => ShowStatus(s.Message, s.IsError)"
                        ModelFetchService="ModelFetchService" />
                    break;
                case SettingsNodes.ProvidersPipeline:
                    <PipelineProviderSection
                        Providers="_pipelineProviders"
                        ConfigStore="ConfigStore"
                        GitHubValidator="GitHubValidator"
                        OnDelete="id => DeleteProvider(id, ProviderKind.Pipeline)"
                        OnSaved="OnGitHubProviderSaved" />
                    break;
                case SettingsNodes.PipelineGeneral:
                    <PipelineGeneralSection
                        ConfigStore="ConfigStore"
                        OnShowStatus="s => ShowStatus(s.Message, s.IsError)" />
                    break;
                case SettingsNodes.PipelineLoop:
                    <PipelineLoopSection
                        ConfigStore="ConfigStore"
                        OnShowStatus="s => ShowStatus(s.Message, s.IsError)" />
                    break;
                case SettingsNodes.PipelinePrompts:
                    <PipelinePromptsSection
                        ConfigStore="ConfigStore"
                        OnShowStatus="s => ShowStatus(s.Message, s.IsError)" />
                    break;
                case SettingsNodes.PipelineQuality:
                    <PipelineQualityGatesSection
                        ConfigStore="ConfigStore"
                        PipelineProviderCount="_pipelineProviders.Count"
                        OnShowStatus="s => ShowStatus(s.Message, s.IsError)" />
                    break;
                case SettingsNodes.PipelineSecurity:
                    <PipelineSecuritySection
                        ConfigStore="ConfigStore"
                        OnShowStatus="s => ShowStatus(s.Message, s.IsError)" />
                    break;
                case SettingsNodes.AgentProfiles:
                    <AgentProfileSection
                        ConfigStore="ConfigStore"
                        AgentProviders="_agentProviders"
                        OnShowStatus="s => ShowStatus(s.Message, s.IsError)" />
                    break;
                case SettingsNodes.QualityGateConfigs:
                    <QualityGateConfigSection
                        ConfigStore="ConfigStore"
                        OnShowStatus="s => ShowStatus(s.Message, s.IsError)" />
                    break;
                case SettingsNodes.ReviewerConfigs:
                    <ReviewerConfigSection
                        ConfigStore="ConfigStore"
                        OnShowStatus="s => ShowStatus(s.Message, s.IsError)" />
                    break;
            }
        </div>
    </div>
</div>

<SettingsModals @ref="_modals"
    ProviderFactory="ProviderFactory"
    ConfigStore="ConfigStore"
    IssueProviders="_issueProviders"
    RepoProviders="_repoProviders"
    PipelineProviders="_pipelineProviders"
    OnLabelsConfigured="LoadAllData"
    OnProvidersCreated="OnRelatedProvidersCreated" />

@code {
    private CancellationTokenSource _cts = new();
    private SettingsModals? _modals;
    private string _selectedNode = SettingsNodes.ProvidersIssue;

    private List<ProviderConfig> _issueProviders = new();
    private List<ProviderConfig> _repoProviders = new();
    private List<ProviderConfig> _agentProviders = new();
    private List<ProviderConfig> _pipelineProviders = new();

    private string? _statusMessage;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        await LoadAllData();
    }

    private async Task LoadAllData()
    {
        try
        {
            _issueProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Issue, _cts.Token)).ToList();
            _repoProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Repository, _cts.Token)).ToList();
            _agentProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Agent, _cts.Token)).ToList();
            _pipelineProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Pipeline, _cts.Token)).ToList();
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            ShowStatus($"Failed to load settings: {ex.Message}", isError: true);
        }
    }

    private async Task OnIssueProviderSaved(ProviderConfig config)
    {
        await LoadAllData();
        ShowStatus("Issue provider saved.");

        var hasLabels = false;
        try
        {
            await using var provider = ProviderFactory.CreateIssueProvider(config);
            hasLabels = await provider.HasAgentLabelsAsync(_cts.Token);
        }
        catch (OperationCanceledException) { return; }
        catch (Exception ex)
        {
            Log.Warning(ex, "Failed to check agent labels for provider {ProviderId}", config.Id);
        }

        if (_cts.IsCancellationRequested) return;

        if (!hasLabels)
            _modals?.ShowConfigureLabels(config);
        else
            _modals?.ShowRelatedProviders(config);
    }

    private async Task OnGitHubProviderSaved(ProviderConfig config)
    {
        await LoadAllData();
        ShowStatus($"{config.Kind} provider saved.");
        _modals?.ShowRelatedProviders(config);
    }

    private async Task OnAgentProviderSaved()
    {
        await LoadAllData();
        ShowStatus("Agent provider saved.");
    }

    private async Task OnRelatedProvidersCreated()
    {
        await LoadAllData();
        ShowStatus("Related providers created.");
    }

    private async Task DeleteProvider(string id, ProviderKind kind)
    {
        try
        {
            await ConfigStore.DeleteProviderConfigAsync(id, kind, _cts.Token);
            await LoadAllData();
            ShowStatus($"{kind} provider deleted.");
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            ShowStatus($"Failed to delete: {ex.Message}", isError: true);
        }
    }

    private void ShowStatus(string message, bool isError = false)
    {
        _statusMessage = message;
        _isError = isError;
    }

    private void SelectNode(string nodeId)
    {
        _selectedNode = nodeId;
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
    }
}
