@page "/agent-monitoring"
@rendermode InteractiveServer
@implements IDisposable
@using CodingAgentWebUI.Pipeline.Interfaces
@using CodingAgentWebUI.Pipeline.Models
@using CodingAgentWebUI.Pipeline.Services
@using CodingAgentWebUI.Orchestration
@using CodingAgentWebUI.Orchestration.Dispatch
@using CodingAgentWebUI.Orchestration.Health
@using CodingAgentWebUI.Orchestration.Registry
@using CodingAgentWebUI.Services
@using Serilog
@inject AgentRegistryService Registry
@inject JobDispatcherService Dispatcher
@inject OrchestratorRunService RunService
@inject PipelineOrchestrationService PipelineService
@inject IConfigurationStore ConfigStore
@inject IConsolidationService ConsolidationService
@inject ConsolidationQueueService ConsolidationQueue
@inject IHubContext<CodingAgentWebUI.Hubs.AgentHub, IAgentHubClient> HubContext
@inject ILabelSwapper LabelSwapper
@inject IPipelineRunHistoryService HistoryService
@inject IJSRuntime JS
@using Microsoft.AspNetCore.SignalR

<div class="agent-monitoring-page">
    <header class="agent-header">
        <h1>Agent Monitoring</h1>
    </header>

    <!-- Active Runs -->
    <section class="settings-section" style="margin: 16px 20px;">
        <h2>🔄 Active Runs (@(_activeRuns.Count + _activeConsolidationRuns.Count))</h2>
        @{
            var implRuns = _activeRuns.Count(r => r.RunType == PipelineRunType.Implementation);
            var reviewRuns = _activeRuns.Count(r => r.RunType == PipelineRunType.Review);
            var decompRuns = _activeRuns.Count(r => r.RunType is PipelineRunType.DecompositionAnalysis or PipelineRunType.Decomposition);
            var consolidationRuns = _activeConsolidationRuns.Count;
        }
        @if (_activeRuns.Count + _activeConsolidationRuns.Count > 0)
        {
            <div class="monitoring-run-counts" style="margin-bottom: 8px; font-size: 0.85rem; color: var(--text-muted);">
                🔨 @implRuns implementation · 🔍 @reviewRuns review · 🧩 @decompRuns decomposition · 🧠 @consolidationRuns consolidation
            </div>
        }
        @if (_activeRuns.Count == 0 && _activeConsolidationRuns.Count == 0)
        {
            <div class="monitoring-empty">No active pipeline runs.</div>
        }
        else
        {
            <div class="monitoring-table-wrap">
                <table class="monitoring-table">
                    <thead>
                        <tr>
                            <th>Run ID</th>
                            <th>Type</th>
                            <th>Issue</th>
                            <th>Agent</th>
                            <th>Step</th>
                            <th>Started</th>
                            <th>Elapsed</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var run in _activeRuns)
                        {
                            var elapsed = DateTime.UtcNow - run.StartedAt;
                            <tr class="monitoring-row-clickable"
                                @onclick="() => OpenRunDetail(run.RunId)">
                                <td class="monitoring-mono" title="@run.RunId">@run.RunId</td>
                                <td>
                                    @if (run.RunType == PipelineRunType.Review)
                                    {
                                        <span class="run-type-badge run-type-review" title="PR Review">🔍 Review</span>
                                    }
                                    else if (run.RunType == PipelineRunType.DecompositionAnalysis)
                                    {
                                        <span class="run-type-badge run-type-decomp" title="Decomposition Analysis">🧩 Decomp (Analysis)</span>
                                    }
                                    else if (run.RunType == PipelineRunType.Decomposition)
                                    {
                                        <span class="run-type-badge run-type-decomp" title="Decomposition">🧩 Decomp</span>
                                    }
                                    else
                                    {
                                        <span class="run-type-badge run-type-impl" title="Implementation">🔨 Impl</span>
                                    }
                                </td>
                                <td title="#@run.IssueIdentifier @run.IssueTitle">
                                    @if (run.RunType == PipelineRunType.Review)
                                    {
                                        <text>PR #@run.IssueIdentifier @run.IssueTitle</text>
                                    }
                                    else
                                    {
                                        <text>#@run.IssueIdentifier @run.IssueTitle</text>
                                    }
                                </td>
                                <td title="@(run.AgentId ?? "local")">@(run.AgentId ?? "local")</td>
                                <td>
                                    <span class="monitoring-step monitoring-step-@run.CurrentStep.ToString().ToLowerInvariant()">
                                        @run.CurrentStep.ToDisplayName()
                                    </span>
                                </td>
                                <td>@run.StartedAt.ToLocalTime().ToString("HH:mm:ss")</td>
                                <td>@elapsed.ToString(@"hh\:mm\:ss")</td>
                                <td>
                                    @if (run.AgentId != null)
                                    {
                                        <button class="btn-cancel-small" @onclick:stopPropagation="true"
                                                @onclick="() => CancelAgentRun(run)">
                                            Cancel
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn-cancel-small" @onclick:stopPropagation="true"
                                                @onclick="CancelLocalRun">
                                            Cancel
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                        @foreach (var cRun in _activeConsolidationRuns)
                        {
                            var cElapsed = DateTime.UtcNow - cRun.StartedAtUtc;
                            var cAgent = _agents.FirstOrDefault(a => a.ActiveJobId == cRun.RunId);
                            <tr>
                                <td class="monitoring-mono" title="@cRun.RunId">@cRun.RunId</td>
                                <td>
                                    <span class="run-type-badge run-type-consolidation" title="@FormatConsolidationRunType(cRun.Type)">
                                        @GetConsolidationTypeIcon(cRun.Type) @FormatConsolidationRunTypeShort(cRun.Type)
                                    </span>
                                </td>
                                <td title="@(cRun.TemplateName ?? "Global")">@(cRun.TemplateName ?? "Global")</td>
                                <td title="@(cAgent?.AgentId ?? "—")">@(cAgent?.AgentId ?? "—")</td>
                                <td>
                                    <span class="monitoring-step monitoring-step-running">Running</span>
                                </td>
                                <td>@cRun.StartedAtUtc.ToLocalTime().ToString("HH:mm:ss")</td>
                                <td>@cElapsed.ToString(@"hh\:mm\:ss")</td>
                                <td>—</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </section>

    @* ── Run Detail Modal ── *@
    @if (_showRunDetailModal)
    {
        var modalRun = _activeRuns.FirstOrDefault(r => r.RunId == _selectedRunId);
        if (modalRun != null)
        {
            var modalAgent = modalRun.AgentId != null ? Registry.GetByAgentId(modalRun.AgentId) : null;
            <div class="modal-overlay" tabindex="-1" @ref="_modalOverlayRef" @onclick="DismissRunDetailModal" @onkeydown="HandleModalKeyDown">
                <div class="modal-card modal-card-wide" @onclick:stopPropagation="true"
                     role="dialog" aria-modal="true" aria-labelledby="run-detail-title">
                    <h3 id="run-detail-title">
                        Run @Truncate(modalRun.RunId, 12) — #@modalRun.IssueIdentifier @Truncate(modalRun.IssueTitle, 40)
                    </h3>

                    <div class="modal-two-column">
                        <div class="modal-column-left">
                            <div class="modal-provider-list">
                                <h4 style="font-size: 0.85rem; margin: 0 0 6px;">Providers</h4>
                                @{ var issueConfig = ResolveProvider(modalRun.IssueProviderConfigId); }
                                <div><strong>Issue:</strong> @(issueConfig?.DisplayName ?? "Unknown") (@(issueConfig?.ProviderType ?? "—"))</div>
                                @{ var repoConfig = ResolveProvider(modalRun.RepoProviderConfigId); }
                                <div><strong>Repository:</strong> @(repoConfig?.DisplayName ?? modalRun.RepositoryName ?? "Unknown") (@(repoConfig?.ProviderType ?? "—"))</div>
                                @{
                                    var agentProviderConfig = ResolveProvider(modalRun.AgentProviderConfigId);
                                }
                                <div><strong>Agent:</strong> @(agentProviderConfig?.DisplayName ?? modalRun.AgentId ?? "local") (@(agentProviderConfig?.ProviderType ?? "—")) — Model: @(modalRun.ModelName ?? "—")</div>
                                @if (modalRun.BrainProviderConfigId != null)
                                {
                                    var brainConfig = ResolveProvider(modalRun.BrainProviderConfigId);
                                    <div><strong>Brain:</strong> @(brainConfig?.DisplayName ?? "Unknown")</div>
                                }
                                @if (modalRun.PipelineProviderConfigId != null)
                                {
                                    var pipelineConfig = ResolveProvider(modalRun.PipelineProviderConfigId);
                                    <div><strong>Pipeline:</strong> @(pipelineConfig?.DisplayName ?? "Unknown") (@(pipelineConfig?.ProviderType ?? "—"))</div>
                                }
                            </div>

                            <div class="monitoring-detail-grid">
                                <div><strong>Retries:</strong> @modalRun.RetryCount/@_maxRetries</div>
                                @if (modalRun.TotalCost is not null and > 0m)
                                {
                                    <div><strong>Cost:</strong> @CostFormatter.FormatCost(modalRun.TotalCost)</div>
                                }
                                @if (modalRun.TotalTokens > 0)
                                {
                                    <div><strong>Tokens:</strong> @CostFormatter.FormatTokens(modalRun.TotalTokens)</div>
                                }
                                @if (modalRun.BranchName != null)
                                {
                                    <div><strong>Branch:</strong> @modalRun.BranchName</div>
                                }
                                @if (!string.IsNullOrEmpty(modalRun.ResolvedProfileId))
                                {
                                    <div><strong>Profile:</strong> @ResolveProfileName(modalRun.ResolvedProfileId)</div>
                                }
                                @if (modalRun.ResolvedQualityGateConfigIds.Count > 0)
                                {
                                    <div><strong>Quality Gates:</strong> @string.Join(", ", modalRun.ResolvedQualityGateConfigIds.Select(ResolveQgcName))</div>
                                }
                            </div>

                            @* ── Agent Info Section ── *@
                            <div class="modal-agent-section">
                                <h4 style="font-size: 0.85rem; margin: 12px 0 6px;">Agent</h4>
                                @if (modalAgent != null)
                                {
                                    <div class="agent-detail-grid">
                                        <div class="detail-label">Agent ID</div>
                                        <div class="detail-value detail-mono">@modalAgent.AgentId</div>
                                        <div class="detail-label">Hostname</div>
                                        <div class="detail-value">@modalAgent.Hostname</div>
                                        <div class="detail-label">Labels</div>
                                        <div class="detail-value">
                                            @foreach (var label in modalAgent.Labels)
                                            {
                                                <span class="sidebar-label">@label</span>
                                            }
                                        </div>
                                        <div class="detail-label">Connection</div>
                                        <div class="detail-value detail-mono">@Truncate(modalAgent.ConnectionId, 20)</div>
                                        <div class="detail-label">Status</div>
                                        <div class="detail-value">
                                            <span class="monitoring-status monitoring-status-@modalAgent.Status.ToString().ToLowerInvariant()">
                                                @GetStatusIcon(modalAgent.Status) @modalAgent.Status
                                            </span>
                                            @if (modalAgent.Disabled)
                                            {
                                                <span class="badge-disabled-table">disabled</span>
                                            }
                                        </div>
                                        <div class="detail-label">Last Heartbeat</div>
                                        <div class="detail-value">@FormatTimeAgo(modalAgent.LastHeartbeatAt)</div>
                                    </div>



                                    @* Agent Actions *@
                                    <div style="margin-top: 8px; display: flex; gap: 8px;">
                                        @if (modalAgent.Disabled)
                                        {
                                            <button class="btn-enable" @onclick="() => EnableAgent(modalAgent)">✓ Enable</button>
                                        }
                                        else
                                        {
                                            <button class="btn-disable" @onclick="() => DisableAgent(modalAgent)">⊘ Disable</button>
                                        }
                                        <button class="btn-force-disconnect" @onclick="ShowDisconnectConfirm">⚡ Force Disconnect</button>
                                    </div>

                                    @if (_showDisconnectConfirm)
                                    {
                                        <div class="agent-detail-confirm">
                                            <p>Force disconnect <strong>@modalAgent.AgentId</strong>?</p>
                                            <p class="confirm-warning">This will deregister the agent and mark any active run as Failed.</p>
                                            <div class="confirm-buttons">
                                                <button class="btn-force-disconnect" @onclick="() => ForceDisconnect(modalAgent)">Confirm</button>
                                                <button class="btn-cancel" @onclick="() => _showDisconnectConfirm = false">Cancel</button>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="monitoring-empty" style="font-size: 0.85rem;">Agent unavailable (disconnected or deregistered).</div>
                                }
                            </div>

                            @{
                                var buffer = RunService.GetOutputBuffer(modalRun.RunId);
                                var outputLines = buffer.GetAll();
                            }
                            @if (outputLines.Count > 0)
                            {
                                <div>
                                    <h4 style="font-size: 0.85rem; margin: 0 0 6px;">Output (last @Math.Min(outputLines.Count, 100) lines)</h4>
                                    <div class="output-panel" id="modalOutputPanel">
                                        @foreach (var line in outputLines.TakeLast(100))
                                        {
                                            <div class="output-line">@line</div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="modal-column-right">
                            <PipelineSidebar Run="modalRun" IsRunning="true" MaxRetries="@_maxRetries"
                                             OnCancel="() => CancelAgentRun(modalRun)" />

                            @* ── Feedback Section ── *@
                            <CodingAgentWebUI.Components.Shared.FeedbackSection Feedback="modalRun.Feedback" />
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button class="btn-cancel" @onclick="DismissRunDetailModal">Close</button>
                        @if (modalRun.AgentId != null)
                        {
                            <button class="btn-cancel-small" style="color: var(--error); border-color: var(--error);"
                                    @onclick="() => CancelAgentRun(modalRun)">
                                Cancel Run
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    }

    <!-- Registered Agents -->
    <section class="settings-section" style="margin: 16px 20px;">
        <h2>🤖 Registered Agents (@_agents.Count)</h2>
        @if (_agents.Count == 0)
        {
            <div class="monitoring-empty">No agents registered. Start agent containers to connect.</div>
        }
        else
        {
            <div class="monitoring-table-wrap">
                <table class="monitoring-table">
                    <thead>
                        <tr>
                            <th>Agent ID</th>
                            <th>Labels</th>
                            <th>Status</th>
                            <th>Active Job</th>
                            <th>Last Heartbeat</th>
                            <th>Registered</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var agent in _agents)
                        {
                            <tr class="monitoring-row-@agent.Status.ToString().ToLowerInvariant() @(agent.Disabled ? "monitoring-row-disabled" : "") monitoring-row-clickable"
                                @onclick="() => SelectAgent(agent.AgentId)">
                                <td class="monitoring-mono" title="@agent.AgentId">@agent.AgentId</td>
                                <td>
                                    @foreach (var label in agent.Labels)
                                    {
                                        <span class="sidebar-label">@label</span>
                                    }
                                </td>
                                <td>
                                    <span class="monitoring-status monitoring-status-@agent.Status.ToString().ToLowerInvariant()">
                                        @GetStatusIcon(agent.Status) @agent.Status
                                    </span>
                                    @if (agent.Disabled)
                                    {
                                        <span class="badge-disabled-table">disabled</span>
                                    }
                                </td>
                                <td class="monitoring-mono" title="@(agent.ActiveJobId ?? "")">@(agent.ActiveJobId ?? "—")</td>
                                <td>@FormatTimeAgo(agent.LastHeartbeatAt)</td>
                                <td>@agent.RegisteredAt.ToLocalTime().ToString("HH:mm:ss")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <!-- Job Queue -->
    <section class="settings-section" style="margin: 16px 20px;">
        <h2>📋 Job Queue (@(_queuedJobs.Count + _queuedConsolidationRuns.Count))</h2>
        @if (_queuedJobs.Count == 0 && _queuedConsolidationRuns.Count == 0)
        {
            <div class="monitoring-empty">No pending jobs in queue.</div>
        }
        else
        {
            <div class="monitoring-table-wrap">
                <table class="monitoring-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Type</th>
                            <th>Issue</th>
                            <th>Initiated By</th>
                            <th>Enqueued At</th>
                            <th>Wait Time</th>
                            <th>Required Labels</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var position = 1; }
                        @foreach (var job in _queuedJobs)
                        {
                            var waitTime = DateTimeOffset.UtcNow - job.EnqueuedAt;
                            <tr>
                                <td>@position</td>
                                <td>
                                    @if (job.RunType == PipelineRunType.Review)
                                    {
                                        <span class="run-type-badge run-type-review" title="PR Review">🔍 Review</span>
                                    }
                                    else if (job.RunType == PipelineRunType.DecompositionAnalysis)
                                    {
                                        <span class="run-type-badge run-type-decomp" title="Decomposition Analysis">🧩 Decomp (A)</span>
                                    }
                                    else if (job.RunType == PipelineRunType.Decomposition)
                                    {
                                        <span class="run-type-badge run-type-decomp" title="Decomposition">🧩 Decomp</span>
                                    }
                                    else
                                    {
                                        <span class="run-type-badge run-type-impl" title="Implementation">🔨 Impl</span>
                                    }
                                </td>
                                <td title="#@job.IssueIdentifier @job.IssueTitle">#@job.IssueIdentifier @job.IssueTitle</td>
                                <td title="@job.InitiatedBy">@job.InitiatedBy</td>
                                <td>@job.EnqueuedAt.ToLocalTime().ToString("HH:mm:ss")</td>
                                <td>@waitTime.ToString(@"hh\:mm\:ss")</td>
                                <td>
                                    @if (job.RequiredLabels.Count > 0)
                                    {
                                        @foreach (var label in job.RequiredLabels)
                                        {
                                            <span class="sidebar-label">@label</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="monitoring-muted">any</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn-cancel-small" @onclick="() => RemoveFromQueue(job.IssueIdentifier, job.IssueProviderId)">
                                        Remove
                                    </button>
                                </td>
                            </tr>
                            position++;
                        }
                        @foreach (var cRun in _queuedConsolidationRuns)
                        {
                            var cWaitTime = DateTime.UtcNow - cRun.StartedAtUtc;
                            <tr>
                                <td>@position</td>
                                <td>
                                    <span class="run-type-badge run-type-consolidation" title="@FormatConsolidationRunType(cRun.Type)">
                                        @GetConsolidationTypeIcon(cRun.Type) @FormatConsolidationRunTypeShort(cRun.Type)
                                    </span>
                                </td>
                                <td title="@(cRun.TemplateName ?? "Global")">@(cRun.TemplateName ?? "Global")</td>
                                <td>consolidation</td>
                                <td>@cRun.StartedAtUtc.ToLocalTime().ToString("HH:mm:ss")</td>
                                <td>@cWaitTime.ToString(@"hh\:mm\:ss")</td>
                                <td>
                                    @if (cRun.QueuedRequiredLabels is { Count: > 0 })
                                    {
                                        @foreach (var label in cRun.QueuedRequiredLabels)
                                        {
                                            <span class="sidebar-label">@label</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="monitoring-muted">any</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn-cancel-small" @onclick="() => CancelConsolidationRun(cRun.RunId)">
                                        Remove
                                    </button>
                                </td>
                            </tr>
                            position++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <!-- Recent Runs -->
    <section class="settings-section" style="margin: 16px 20px;">
        <div class="monitoring-section-toggle" @onclick="() => _historyExpanded = !_historyExpanded"
             role="button" tabindex="0">
            <h2>📜 Recent Runs (@_runHistory.Count)</h2>
            <span class="monitoring-toggle-icon">@(_historyExpanded ? "▾" : "▸")</span>
        </div>
        <div style="margin: 8px 0;">
            <a href="/api/export/runs.json" download class="btn-cancel" style="text-decoration: none; display: inline-block; font-size: 0.8rem; padding: 4px 12px;">
                📥 Export All (JSON)
            </a>
            <a href="/api/export/runs.json?feedbackOnly=true" download class="btn-cancel" style="text-decoration: none; display: inline-block; font-size: 0.8rem; padding: 4px 12px; margin-left: 8px;">
                📥 Feedback Only (JSON)
            </a>
        </div>
        @if (_historyExpanded)
        {
            @if (_runHistory.Count == 0)
            {
                <div class="monitoring-empty">No completed runs yet.</div>
            }
            else
            {
                <div class="monitoring-table-wrap">
                    <table class="monitoring-table">
                        <thead>
                            <tr>
                                <th>Run ID</th>
                                <th>Type</th>
                                <th>Project</th>
                                <th>Issue</th>
                                <th>Agent</th>
                                <th>Final Step</th>
                                <th>Started</th>
                                <th>Duration</th>
                                <th>Tokens</th>
                                <th>PR</th>
                                <th>Initiated By</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var run in _runHistory.Take(20))
                            {
                                <tr class="monitoring-row-clickable"
                                    @onclick="() => OpenHistoryRunDetail(run)">
                                    <td class="monitoring-mono" title="@run.RunId">@run.RunId</td>
                                    <td>
                                        @if (run.RunType == PipelineRunType.Review)
                                        {
                                            <span class="run-type-badge run-type-review" title="PR Review">🔍</span>
                                        }
                                        else if (run.RunType is PipelineRunType.DecompositionAnalysis or PipelineRunType.Decomposition)
                                        {
                                            <span class="run-type-badge run-type-decomp" title="@(run.RunType == PipelineRunType.DecompositionAnalysis ? "Decomposition Analysis" : "Decomposition")">🧩</span>
                                        }
                                        else
                                        {
                                            <span class="run-type-badge run-type-impl" title="Implementation">🔨</span>
                                        }
                                    </td>
                                    <td>@(string.IsNullOrEmpty(run.ProjectName) ? "—" : run.ProjectName)</td>
                                    <td title="#@run.IssueIdentifier @run.IssueTitle">
                                        @if (run.RunType == PipelineRunType.Review)
                                        {
                                            <text>PR #@run.IssueIdentifier @run.IssueTitle</text>
                                        }
                                        else
                                        {
                                            <text>#@run.IssueIdentifier @run.IssueTitle</text>
                                        }
                                    </td>
                                    <td>@(run.AgentId ?? "local")</td>
                                    <td>
                                        <span class="step-badge step-@run.FinalStep.ToString().ToLowerInvariant()">
                                            @run.FinalStep.ToDisplayName()
                                        </span>
                                    </td>
                                    <td title="@run.StartedAt.ToString("yyyy-MM-dd HH:mm:ss")">@FormatTimestamp(run.StartedAt)</td>
                                    <td>@FormatDuration(run.StartedAt, run.CompletedAt)</td>
                                    <td><span class="token-badge">@CostFormatter.FormatTokens(run.TotalTokens)</span></td>
                                    <td>
                                        @if (run.RunType == PipelineRunType.Review && !string.IsNullOrEmpty(run.ReviewPrUrl))
                                        {
                                            <a href="@run.ReviewPrUrl" target="_blank" rel="noopener">PR</a>
                                        }
                                        else if (!string.IsNullOrEmpty(run.PullRequestUrl))
                                        {
                                            <a href="@run.PullRequestUrl" target="_blank" rel="noopener">PR</a>
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </td>
                                    <td>@run.InitiatedBy</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    </section>

    @* ── History Run Detail Modal ── *@
    @if (_showHistoryDetailModal && _selectedHistoryRun != null)
    {
        <div class="modal-overlay" tabindex="-1" @ref="_historyModalOverlayRef"
             @onclick="DismissHistoryDetailModal" @onkeydown="HandleHistoryModalKeyDown">
            <div class="modal-card" @onclick:stopPropagation="true"
                 role="dialog" aria-modal="true" aria-labelledby="history-detail-title">
                <h3 id="history-detail-title">
                    @if (_selectedHistoryRun.RunType == PipelineRunType.Review)
                    {
                        <span class="run-type-badge run-type-review">🔍 Review</span>
                    }
                    else if (_selectedHistoryRun.RunType is PipelineRunType.DecompositionAnalysis or PipelineRunType.Decomposition)
                    {
                        <span class="run-type-badge run-type-decomp">🧩 Decomp</span>
                    }
                    Run @Truncate(_selectedHistoryRun.RunId, 12) — #@_selectedHistoryRun.IssueIdentifier @Truncate(_selectedHistoryRun.IssueTitle, 40)
                </h3>

                @if (!string.IsNullOrEmpty(_selectedHistoryRun.FailureReason))
                {
                    <div class="summary-failure-callout" role="alert">⚠️ @_selectedHistoryRun.FailureReason</div>
                }

                <div class="modal-provider-list">
                    <div><strong>Run Type:</strong> @FormatRunType(_selectedHistoryRun.RunType)</div>
                    <div><strong>Final Step:</strong>
                        <span class="step-badge step-@_selectedHistoryRun.FinalStep.ToString().ToLowerInvariant()">
                            @_selectedHistoryRun.FinalStep.ToDisplayName()
                        </span>
                    </div>
                    <div><strong>Duration:</strong> @FormatDuration(_selectedHistoryRun.StartedAt, _selectedHistoryRun.CompletedAt)</div>
                    @* TODO: [UX-24] Add AgentProviderConfigId to PipelineRunSummary and resolve display name/type here *@
                    <div><strong>Agent:</strong> @(_selectedHistoryRun.AgentId ?? "local")</div>
                    <div><strong>Initiated By:</strong> @_selectedHistoryRun.InitiatedBy</div>
                    @if (_selectedHistoryRun.RunType == PipelineRunType.Review)
                    {
                        @if (!string.IsNullOrEmpty(_selectedHistoryRun.ReviewPrUrl))
                        {
                            <div><strong>PR Under Review:</strong> <a href="@_selectedHistoryRun.ReviewPrUrl" target="_blank" rel="noopener">@_selectedHistoryRun.ReviewPrUrl</a></div>
                        }
                        @if (_selectedHistoryRun.CodeReviewAgentsRun.Count > 0)
                        {
                            <div><strong>Review Agents:</strong> @string.Join(", ", _selectedHistoryRun.CodeReviewAgentsRun)</div>
                        }
                        @if (_selectedHistoryRun.CodeReviewCriticalCount > 0 || _selectedHistoryRun.CodeReviewWarningCount > 0 || _selectedHistoryRun.CodeReviewSuggestionCount > 0)
                        {
                            <div><strong>Findings:</strong> 🔴 @_selectedHistoryRun.CodeReviewCriticalCount critical · 🟡 @_selectedHistoryRun.CodeReviewWarningCount warning · 🔵 @_selectedHistoryRun.CodeReviewSuggestionCount suggestion</div>
                        }
                        else
                        {
                            <div><strong>Findings:</strong> ✅ No issues found</div>
                        }
                    }
                    @if (_selectedHistoryRun.RunType is PipelineRunType.DecompositionAnalysis or PipelineRunType.Decomposition)
                    {
                        @if (_selectedHistoryRun.DecompositionSubIssuesAttempted > 0)
                        {
                            <div><strong>Sub-Issues:</strong> @_selectedHistoryRun.DecompositionSubIssuesCreated/@_selectedHistoryRun.DecompositionSubIssuesAttempted created</div>
                        }
                    }
                    @if (_selectedHistoryRun.TotalCost is not null and > 0m)
                    {
                        <div><strong>Cost:</strong> @CostFormatter.FormatCost(_selectedHistoryRun.TotalCost)</div>
                    }
                    @if (_selectedHistoryRun.TotalTokens > 0)
                    {
                        <div><strong>Tokens:</strong> @CostFormatter.FormatTokens(_selectedHistoryRun.TotalTokens)</div>
                    }
                    @if (_selectedHistoryRun.ModelName != null)
                    {
                        <div><strong>Model:</strong> @_selectedHistoryRun.ModelName</div>
                    }
                    @if (_selectedHistoryRun.BrainRepoUsed)
                    {
                        <div><strong>Brain:</strong> Used @(_selectedHistoryRun.BrainUpdatesPushed ? "(updates pushed)" : "(read-only)")</div>
                    }
                    @if (_selectedHistoryRun.IsRework)
                    {
                        <div><strong>Rework:</strong> Yes</div>
                    }
                    @if (!string.IsNullOrEmpty(_selectedHistoryRun.PullRequestUrl) && _selectedHistoryRun.RunType != PipelineRunType.Review)
                    {
                        <div><strong>PR:</strong> <a href="@_selectedHistoryRun.PullRequestUrl" target="_blank" rel="noopener">@_selectedHistoryRun.PullRequestUrl</a></div>
                    }
                    @if (_selectedHistoryRun.RetryCount > 0)
                    {
                        <div><strong>Retries:</strong> @_selectedHistoryRun.RetryCount</div>
                    }
                </div>

                @* ── Feedback Section ── *@
                <CodingAgentWebUI.Components.Shared.FeedbackSection Feedback="_selectedHistoryRun.Feedback" />

                <div style="margin-top: 12px; text-align: right;">
                    <button class="btn-cancel" @onclick="DismissHistoryDetailModal">Close</button>
                </div>
            </div>
        </div>
    }

</div>

@code {
    private const string JsScrollToBottom = "scrollToBottom";
    private const string JsScrollActiveStep = "scrollActiveStepIntoView";

    private IReadOnlyList<PipelineRun> _activeRuns = [];
    private IReadOnlyList<AgentEntry> _agents = [];
    private IReadOnlyList<PendingJob> _queuedJobs = [];
    private IReadOnlyList<ConsolidationRun> _activeConsolidationRuns = [];
    private IReadOnlyList<ConsolidationRun> _queuedConsolidationRuns = [];
    private Dictionary<string, ProviderConfig> _providerConfigLookup = new();
    private Dictionary<string, AgentProfile> _profileLookup = new();
    private Dictionary<string, QualityGateConfiguration> _qgcLookup = new();
    private IReadOnlyList<PipelineRunSummary> _runHistory = [];
    private bool _historyExpanded = true;
    private string? _selectedRunId;
    private bool _showRunDetailModal;
    private bool _scrollModalOnNextRender;
    private bool _focusModalOnNextRender;
    private ElementReference _modalOverlayRef;
    private PipelineRunSummary? _selectedHistoryRun;
    private bool _showHistoryDetailModal;
    private ElementReference _historyModalOverlayRef;
    private bool _disposed;
    private Timer? _refreshTimer;
    private int _maxRetries = 3;
    private bool _showDisconnectConfirm;

    protected override async Task OnInitializedAsync()
    {
        PipelineService.OnChange += HandleStateChanged;
        ConsolidationService.OnChange += HandleStateChanged;

        // Refresh every 2 seconds for heartbeat/elapsed updates
        _refreshTimer = new Timer(RefreshTick, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(2));

        try
        {
            var config = await ConfigStore.LoadPipelineConfigAsync(CancellationToken.None);
            _maxRetries = config.MaxRetries;
        }
        catch (Exception ex)
        {
            Log.Warning(ex, "Failed to load pipeline config, using defaults");
        }

        try
        {
            var allConfigs = new List<ProviderConfig>();
            foreach (var kind in Enum.GetValues<ProviderKind>())
                allConfigs.AddRange(await ConfigStore.LoadProviderConfigsAsync(kind, CancellationToken.None));
            _providerConfigLookup = allConfigs.DistinctBy(c => c.Id).ToDictionary(c => c.Id);
        }
        catch (Exception ex)
        {
            Log.Warning(ex, "Failed to load provider configs");
        }

        try
        {
            var profiles = await ConfigStore.LoadAgentProfilesAsync(CancellationToken.None);
            _profileLookup = profiles.ToDictionary(p => p.Id);
        }
        catch (Exception ex)
        {
            Log.Warning(ex, "Failed to load agent profiles");
        }

        try
        {
            var qgcs = await ConfigStore.LoadQualityGateConfigsAsync(CancellationToken.None);
            _qgcLookup = qgcs.ToDictionary(q => q.Id);
        }
        catch (Exception ex)
        {
            Log.Warning(ex, "Failed to load quality gate configs");
        }

        await RefreshDataAsync(includeConsolidation: true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_scrollModalOnNextRender && _showRunDetailModal)
        {
            _scrollModalOnNextRender = false;
            try
            {
                await Task.Delay(50);
                await JS.InvokeVoidAsync(JsScrollActiveStep, "sidebarSteps");
                await JS.InvokeVoidAsync(JsScrollToBottom, "modalOutputPanel");
            }
            catch (Exception ex) { Log.Debug(ex, "JS interop scroll failed in modal render"); }
        }

        if (_focusModalOnNextRender && _showRunDetailModal)
        {
            _focusModalOnNextRender = false;
            try
            {
                await _modalOverlayRef.FocusAsync();
            }
            catch (Exception ex) { Log.Debug(ex, "Modal focus failed"); }
        }
    }

    private Task RefreshDataAsync(bool includeConsolidation = false)
    {
        _activeRuns = PipelineService.GetAllActiveRuns();
        _agents = Registry.GetAllAgents();
        _queuedJobs = Dispatcher.GetQueuedJobs();
        _runHistory = PipelineService.GetRunHistory();

        return includeConsolidation ? RefreshConsolidationAsync() : Task.CompletedTask;
    }

    private async Task RefreshConsolidationAsync()
    {
        try
        {
            var allConsolidationRuns = await ConsolidationService.GetRunHistoryAsync(CancellationToken.None);
            _activeConsolidationRuns = allConsolidationRuns
                .Where(r => r.Status == ConsolidationRunStatus.Running)
                .ToList();
            _queuedConsolidationRuns = allConsolidationRuns
                .Where(r => r.Status == ConsolidationRunStatus.Queued)
                .ToList();
        }
        catch (Exception ex)
        {
            Log.Debug(ex, "Failed to load consolidation runs for monitoring page");
        }
    }

    private async void RefreshTick(object? state)
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed) return;
                await RefreshDataAsync();
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException) { }
    }

    private async void HandleStateChanged()
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed) return;
                await RefreshDataAsync(includeConsolidation: true);
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException) { }
    }

    private void OpenRunDetail(string runId)
    {
        _selectedRunId = runId;
        _showRunDetailModal = true;
        _scrollModalOnNextRender = true;
        _focusModalOnNextRender = true;
    }

    private void DismissRunDetailModal()
    {
        _showRunDetailModal = false;
        _selectedRunId = null;
    }

    private void OpenHistoryRunDetail(PipelineRunSummary run)
    {
        _selectedHistoryRun = run;
        _showHistoryDetailModal = true;
    }

    private void DismissHistoryDetailModal()
    {
        _showHistoryDetailModal = false;
        _selectedHistoryRun = null;
    }

    private void HandleHistoryModalKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            DismissHistoryDetailModal();
    }

    private void HandleModalKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            DismissRunDetailModal();
    }

    private async Task CancelAgentRun(PipelineRun run)
    {
        if (run.AgentId == null) return;

        var agent = Registry.GetByAgentId(run.AgentId);
        if (agent == null) return;

        // Short-circuit: if the run is orphan-restored (agent crashed and lost its state),
        // the agent can't act on CancelJob — fail the run immediately on the orchestrator side.
        if (agent.OrphanRestoredAt is not null)
        {
            Log.Information("Cancel short-circuit: run {RunId} is orphan-restored, failing immediately on orchestrator", run.RunId);
            run.FailureReason = "Cancelled — agent lost job state (container restart)";
            run.CompletedAt = DateTime.UtcNow;
            run.CompletedAtOffset = DateTimeOffset.UtcNow;
            run.CurrentStep = PipelineStep.Cancelled;

            HistoryService.AddRunToHistory(run);
            RunService.RemoveRun(run.RunId);
            Dispatcher.MarkIssueComplete(run.IssueIdentifier, run.IssueProviderConfigId);

            lock (agent.SyncRoot)
            {
                agent.ActiveJobId = null;
                agent.OrphanRestoredAt = null;
            }
            Registry.TransitionStatus(agent.AgentId, AgentStatus.Idle);

            try
            {
                await LabelSwapper.SwapLabelAsync(
                    run.IssueProviderConfigId, run.IssueIdentifier, AgentLabels.Cancelled,
                    run.RunType == PipelineRunType.Review ? LabelTargetKind.PullRequest : LabelTargetKind.Issue,
                    CancellationToken.None);
            }
            catch (Exception ex) { Log.Warning(ex, "Failed to swap label for cancelled orphan run {RunId}", run.RunId); }

            await RefreshDataAsync();
            StateHasChanged();
            return;
        }

        try
        {
            await HubContext.Clients.Client(agent.ConnectionId).CancelJob(run.RunId);
        }
        catch (Exception ex) { Log.Warning(ex, "Failed to cancel run {RunId} on agent {AgentId}", run.RunId, run.AgentId); }
    }

    private async Task CancelLocalRun()
    {
        await PipelineService.CancelPipelineAsync();
    }

    private async Task RemoveFromQueue(string issueIdentifier, string issueProviderId)
    {
        Dispatcher.RemoveFromQueue(issueIdentifier, issueProviderId);
        await RefreshDataAsync();
        StateHasChanged();
    }

    private async Task CancelConsolidationRun(string runId)
    {
        await ConsolidationService.CancelQueuedRunAsync(runId, CancellationToken.None);
        await RefreshDataAsync(includeConsolidation: true);
        StateHasChanged();
    }

    private void SelectAgent(string agentId)
    {
        // Find the active run for this agent and open the run detail modal
        var run = _activeRuns.FirstOrDefault(r => r.AgentId == agentId);
        if (run != null)
        {
            OpenRunDetail(run.RunId);
        }
    }

    private void EnableAgent(AgentEntry agent) => agent.Disabled = false;

    private void DisableAgent(AgentEntry agent) => agent.Disabled = true;

    private void ShowDisconnectConfirm() => _showDisconnectConfirm = true;

    private async Task ForceDisconnect(AgentEntry agent)
    {
        try
        {
            if (agent.Status != AgentStatus.Disconnected)
            {
                try { await HubContext.Clients.Client(agent.ConnectionId).ForceDisconnect(); }
                catch (Exception ex) { Log.Warning(ex, "Agent {AgentId} did not respond to force disconnect", agent.AgentId); }
            }

            if (agent.ActiveJobId != null)
            {
                var activeRun = PipelineService.GetAllActiveRuns()
                    .FirstOrDefault(r => r.RunId == agent.ActiveJobId);
                if (activeRun != null)
                {
                    activeRun.FailureReason = "Force disconnected by operator";
                    activeRun.CurrentStep = PipelineStep.Failed;
                    activeRun.CompletedAt = DateTime.UtcNow;
                }
            }

            Registry.Deregister(agent.AgentId);
        }
        catch (Exception ex)
        {
            Log.Warning(ex, "Force disconnect failed for agent {AgentId}", agent.AgentId);
        }

        _showDisconnectConfirm = false;
        DismissRunDetailModal();
    }

    private static string GetStatusIcon(AgentStatus status) => status switch
    {
        AgentStatus.Idle => "🟢",
        AgentStatus.Busy => "🟡",
        AgentStatus.Disconnected => "🔴",
        _ => "⚪"
    };

    private static string FormatRunType(PipelineRunType runType) => runType switch
    {
        PipelineRunType.Review => "PR Review",
        PipelineRunType.DecompositionAnalysis => "Decomposition (Analysis)",
        PipelineRunType.Decomposition => "Decomposition",
        _ => "Implementation"
    };

    private static string FormatConsolidationRunType(ConsolidationRunType type) => type switch
    {
        ConsolidationRunType.BrainConsolidation => "Brain Consolidation",
        ConsolidationRunType.RefactoringDetection => "Refactoring Detection",
        ConsolidationRunType.HarnessSuggestions => "Harness Suggestions",
        _ => type.ToString()
    };

    private static string FormatConsolidationRunTypeShort(ConsolidationRunType type) => type switch
    {
        ConsolidationRunType.BrainConsolidation => "Brain",
        ConsolidationRunType.RefactoringDetection => "Refactor",
        ConsolidationRunType.HarnessSuggestions => "Harness",
        _ => type.ToString()
    };

    private static string GetConsolidationTypeIcon(ConsolidationRunType type) => type switch
    {
        ConsolidationRunType.BrainConsolidation => "🧠",
        ConsolidationRunType.RefactoringDetection => "🔄",
        ConsolidationRunType.HarnessSuggestions => "✨",
        _ => "📋"
    };

    private static string FormatDuration(DateTime startedAt, DateTime? completedAt)
    {
        if (completedAt is null) return "—";
        var duration = completedAt.Value - startedAt;
        return duration.ToString(@"hh\:mm\:ss");
    }

    private static string FormatTimestamp(DateTime timestamp)
    {
        var local = timestamp.Kind == DateTimeKind.Utc ? timestamp.ToLocalTime() : timestamp;
        var ago = DateTime.Now - local;
        if (ago.TotalMinutes < 60) return $"{(int)ago.TotalMinutes}m ago";
        if (ago.TotalHours < 24) return $"{(int)ago.TotalHours}h ago";
        if (ago.TotalDays < 7) return $"{(int)ago.TotalDays}d ago";
        return local.ToString("yyyy-MM-dd HH:mm");
    }

    private ProviderConfig? ResolveProvider(string? configId)
    {
        if (string.IsNullOrEmpty(configId)) return null;
        return _providerConfigLookup.GetValueOrDefault(configId);
    }

    private string ResolveProfileName(string profileId)
    {
        var profile = _profileLookup.GetValueOrDefault(profileId);
        return profile != null ? profile.DisplayName : $"{Truncate(profileId, 8)} (deleted)";
    }

    private string ResolveQgcName(string qgcId)
    {
        var qgc = _qgcLookup.GetValueOrDefault(qgcId);
        return qgc != null ? qgc.DisplayName : $"{Truncate(qgcId, 8)} (deleted)";
    }

    public void Dispose()
    {
        _disposed = true;
        _refreshTimer?.Dispose();
        PipelineService.OnChange -= HandleStateChanged;
        ConsolidationService.OnChange -= HandleStateChanged;
    }
}
