@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject CodingAgentWebUI.Services.KiroExecutionService ExecutionService
@inject IJSRuntime JS

<div class="chat-container">
    <header class="chat-header">
        <h1>Kiro Web UI</h1>
        @if (ExecutionService.CurrentState is not null)
        {
            <span class="state-badge state-@ExecutionService.CurrentState.ToString()?.ToLowerInvariant()">
                @ExecutionService.CurrentState
            </span>
        }
    </header>

    <div class="message-list" id="messageList">
        @foreach (var message in ExecutionService.Messages)
        {
            <div class="message message-@message.Role.ToString().ToLowerInvariant()">
                <div class="message-role">
                    @(message.Role == CodingAgentWebUI.Models.ChatMessageRole.User ? "You" : message.Role == CodingAgentWebUI.Models.ChatMessageRole.Assistant ? "Kiro" : "System")
                    <span class="message-timestamp">@message.Timestamp.ToLocalTime().ToString("h:mm tt")</span>
                </div>
                <div class="message-content">
                    <pre>@message.Content</pre>
                </div>

                @if (message.IsStreaming)
                {
                    <span class="streaming-indicator">▌</span>
                }

                @if (message.FileChanges is { Count: > 0 })
                {
                    <details class="file-changes">
                        <summary>File Changes (@message.FileChanges.Count)</summary>
                        @foreach (var group in message.FileChanges.GroupBy(f => f.Type))
                        {
                            <div class="file-group">
                                <strong class="file-type file-type-@group.Key.ToString().ToLowerInvariant()">@group.Key</strong>
                                <ul>
                                    @foreach (var file in group)
                                    {
                                        <li>@file.Path</li>
                                    }
                                </ul>
                            </div>
                        }
                    </details>
                }

                @if (message.TestResults is not null)
                {
                    <div class="test-results @(message.TestResults.FailedTests == 0 && message.TestResults.TotalTests > 0 ? "tests-passed" : "tests-failed")">
                        <span class="test-icon">@(message.TestResults.FailedTests == 0 && message.TestResults.TotalTests > 0 ? "✅" : "❌")</span>
                        Tests: @message.TestResults.PassedTests/@message.TestResults.TotalTests passed
                        @if (message.TestResults.FailedTests > 0)
                        {
                            <span class="test-failed-count">(@message.TestResults.FailedTests failed)</span>
                        }
                    </div>
                }

                @if (message.ExitCode is not null && !message.IsStreaming)
                {
                    <div class="exit-code exit-code-@(message.ExitCode == 0 ? "success" : "error")">
                        Exit code: @message.ExitCode
                    </div>
                }
            </div>
        }
    </div>

    <div class="input-area">
        @if (!string.IsNullOrEmpty(_validationMessage))
        {
            <div class="validation-message">@_validationMessage</div>
        }
        <div class="input-row">
            <input type="text"
                   @bind="_promptText"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown"
                   placeholder="Enter prompt..."
                   disabled="@ExecutionService.IsExecuting"
                   class="prompt-input" />
            <button @onclick="SendPrompt"
                    disabled="@ExecutionService.IsExecuting"
                    class="send-button">
                @if (ExecutionService.IsExecuting)
                {
                    <span class="loading-indicator">⏳</span>
                }
                else
                {
                    <span>Send</span>
                }
            </button>
        </div>
        <button @onclick="ClearSession" class="clear-button" disabled="@ExecutionService.IsExecuting">
            Clear Session
        </button>
    </div>
</div>

@code {
    private string _promptText = string.Empty;
    private string? _validationMessage;

    protected override void OnInitialized()
    {
        ExecutionService.OnChange += HandleStateChanged;
    }

    private async void HandleStateChanged()
    {
        await InvokeAsync(async () =>
        {
            StateHasChanged();
            await JS.InvokeVoidAsync("scrollToBottom", "messageList");
        });
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !ExecutionService.IsExecuting)
        {
            await SendPrompt();
        }
    }

    private async Task SendPrompt()
    {
        _validationMessage = null;

        if (string.IsNullOrWhiteSpace(_promptText))
        {
            _validationMessage = "Please enter a prompt.";
            return;
        }

        var prompt = _promptText;
        _promptText = string.Empty;

        try
        {
            await ExecutionService.ExecutePromptAsync(prompt, CancellationToken.None);
        }
        catch (Exception ex)
        {
            _validationMessage = $"Error: {ex.Message}";
        }
    }

    private void ClearSession()
    {
        ExecutionService.ClearSession();
        _validationMessage = null;
    }

    public void Dispose()
    {
        ExecutionService.OnChange -= HandleStateChanged;
    }
}
