            _pipelineValidationMessage = "Installation ID must be a valid number.";
            _pipelineValidationSuccess = false;
            return;
        }

        _pipelineLoadingRepos = true;
        _pipelineValidationMessage = null;
        StateHasChanged();

        var (credOk, credMsg) = await GitHubValidator.ValidateAppCredentialsAsync(
            _pipelineProviderForm.ApiUrl, _pipelineProviderForm.ClientId, installationId,
            _pipelineProviderForm.PrivateKeyBase64, CancellationToken.None);
        if (!credOk)
        {
            _pipelineValidationMessage = credMsg;
            _pipelineValidationSuccess = false;
            _pipelineLoadingRepos = false;
            return;
        }

        var repos = await GitHubValidator.ListRepositoriesWithAppAsync(
            _pipelineProviderForm.ApiUrl, _pipelineProviderForm.ClientId, installationId,
            _pipelineProviderForm.PrivateKeyBase64, CancellationToken.None);
        _pipelineAvailableRepos = repos.ToList();
        _pipelineValidationMessage = $"{credMsg} — {repos.Count} repositories found";
        _pipelineValidationSuccess = true;
        _pipelineLoadingRepos = false;
    }

    // --- Fetch Agent Models ---
    private async Task FetchAgentModels()
    {
        if (string.IsNullOrWhiteSpace(_agentForm.ExecutablePath))
        {
            ShowStatus("Enter the Executable Path first.", isError: true);
            return;
        }

        _agentLoadingModels = true;
        StateHasChanged();

        try
        {
            var psi = new System.Diagnostics.ProcessStartInfo
            {
                FileName = _agentForm.ExecutablePath,
                Arguments = "chat --list-models --format json",
                RedirectStandardOutput = true,
                RedirectStandardError = true,
                UseShellExecute = false,
                CreateNoWindow = true
            };

            using var process = System.Diagnostics.Process.Start(psi);
            if (process == null)
            {
                ShowStatus("Failed to start kiro-cli process.", isError: true);
                return;
            }

            using var timeoutCts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            var stdoutTask = process.StandardOutput.ReadToEndAsync(timeoutCts.Token);
            var stderrTask = process.StandardError.ReadToEndAsync(timeoutCts.Token);
            var output = await stdoutTask;
            await process.WaitForExitAsync(timeoutCts.Token);
            var stderr = await stderrTask;

            if (process.ExitCode != 0)
            {
                ShowStatus($"kiro-cli exited with code {process.ExitCode}: {stderr}", isError: true);
                return;
            }

            using var doc = System.Text.Json.JsonDocument.Parse(output);
            var models = new List<AgentModelInfo>();
            if (doc.RootElement.TryGetProperty("models", out var modelsArray))
            {
                foreach (var m in modelsArray.EnumerateArray())
                {
                    models.Add(new AgentModelInfo
                    {
                        ModelId = m.GetProperty("model_id").GetString() ?? "",
                        Description = m.TryGetProperty("description", out var d) ? d.GetString() ?? "" : "",
                        RateMultiplier = m.TryGetProperty("rate_multiplier", out var r) ? r.GetDouble() : 1.0
                    });
                }
            }

            _agentAvailableModels = models;
            // Keep current selection if it's "auto" or matches a fetched model; otherwise reset to "auto"
            if (_agentForm.Model != "auto" && models.Count > 0 && !models.Any(m => m.ModelId == _agentForm.Model))
                _agentForm.Model = "auto";

            ShowStatus($"{models.Count} model(s) loaded.");
        }
        catch (Exception ex)
        {
            ShowStatus($"Failed to fetch models: {ex.Message}", isError: true);
        }
        finally
        {
            _agentLoadingModels = false;
        }
    }

    // --- Delete ---
    private async Task DeleteProvider(string id, ProviderKind kind)
    {
        try
        {
            await ConfigStore.DeleteProviderConfigAsync(id, kind, CancellationToken.None);
            await LoadAllData();
            ShowStatus($"{kind} provider deleted.");
        }
        catch (Exception ex)
        {
            ShowStatus($"Failed to delete: {ex.Message}", isError: true);
        }
    }

    // --- Pipeline Config ---
    private async Task SavePipelineConfig()
    {
        var config = new PipelineConfiguration
        {
            AutonomousMode = _pipelineConfig.AutonomousMode,
            MaxRetries = _pipelineConfig.MaxRetries,
            AgentTimeout = TimeSpan.FromMinutes(_agentTimeoutMinutes),
            MinCoverageThreshold = _pipelineConfig.MinCoverageThreshold,
            SecurityScanEnabled = false,
            SelfReviewEnabled = _pipelineConfig.SelfReviewEnabled,
            SelfReviewMaxIterations = _pipelineConfig.SelfReviewMaxIterations,
            SelfReviewPrompt = _pipelineConfig.SelfReviewPrompt,
            ExternalCiEnabled = _pipelineConfig.ExternalCiEnabled,
            ExternalCiTimeout = TimeSpan.FromMinutes(_externalCiTimeoutMinutes),
            ExternalCiPollInterval = TimeSpan.FromSeconds(_externalCiPollIntervalSeconds),
            BlacklistedPaths = _blacklistedPathsText
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .ToArray(),
            BlacklistMode = _pipelineConfig.BlacklistMode,
            CleanupSuccessfulWorkspaces = _pipelineConfig.CleanupSuccessfulWorkspaces,
            FailedWorkspaceRetentionDays = _pipelineConfig.FailedWorkspaceRetentionDays
        };

        try
        {
            await ConfigStore.SavePipelineConfigAsync(config, CancellationToken.None);
            ShowStatus("Pipeline configuration saved.");
        }
        catch (Exception ex)
        {
            ShowStatus($"Failed to save: {ex.Message}", isError: true);
        }
    }

    private void ShowStatus(string message, bool isError = false)
    {
        _statusMessage = message;
        _isError = isError;
    }

    // --- Related Providers Modal ---
    private bool _showRelatedProvidersModal;
    private string _relatedModalOwner = "";
    private string _relatedModalRepo = "";
    private string _relatedModalBaseBranch = "main";
    private List<RelatedProviderItem> _relatedModalItems = new();
    private Dictionary<string, string> _relatedModalSharedSettings = new();
    private string? _relatedModalStatus;
    private bool _relatedModalIsError;
    private bool _relatedModalSaving;

    private static readonly string[] SharedGitHubSettingKeys = ["apiUrl", "clientId", "appId", "installationId", "privateKeyBase64", "owner", "repo"];

    private void ShowRelatedProvidersModal(ProviderConfig savedConfig)
    {
        if (savedConfig.ProviderType != "GitHub") return;

        var sourceKind = savedConfig.Kind;
        var targetKinds = new[] { ProviderKind.Issue, ProviderKind.Repository, ProviderKind.Pipeline }
            .Where(k => k != sourceKind).ToList();

        _relatedModalOwner = savedConfig.Settings.GetValueOrDefault("owner", "");
        _relatedModalRepo = savedConfig.Settings.GetValueOrDefault("repo", "");
        _relatedModalBaseBranch = "main";
        _relatedModalSharedSettings = SharedGitHubSettingKeys
            .Where(k => savedConfig.Settings.ContainsKey(k))
            .ToDictionary(k => k, k => savedConfig.Settings[k]);
        _relatedModalStatus = null;
        _relatedModalIsError = false;
        _relatedModalSaving = false;

        _relatedModalItems = new();
        foreach (var kind in targetKinds)
        {
            var existingList = kind switch
            {
                ProviderKind.Issue => _issueProviders,
                ProviderKind.Repository => _repoProviders,
                ProviderKind.Pipeline => _pipelineProviders,
                _ => new List<ProviderConfig>()
            };
            var existing = existingList.FirstOrDefault(p =>
                p.ProviderType == "GitHub"
                && p.Settings.GetValueOrDefault("owner", "") == _relatedModalOwner
                && p.Settings.GetValueOrDefault("repo", "") == _relatedModalRepo);

            _relatedModalItems.Add(new RelatedProviderItem { Kind = kind, Selected = true, Existing = existing });
        }

        _showRelatedProvidersModal = true;
    }

    private void DismissRelatedProvidersModal()
    {
        _showRelatedProvidersModal = false;
    }

    private void HandleModalKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") DismissRelatedProvidersModal();
    }

    private async Task ConfirmRelatedProviders()
    {
        _relatedModalSaving = true;
        _relatedModalStatus = null;
        StateHasChanged();

        try
        {
            var created = 0;
            var updated = 0;
            foreach (var item in _relatedModalItems.Where(i => i.Selected).ToList())
            {
                var settings = new Dictionary<string, string>(_relatedModalSharedSettings);
                if (item.Kind == ProviderKind.Repository)
                    settings["baseBranch"] = string.IsNullOrWhiteSpace(_relatedModalBaseBranch) ? "main" : _relatedModalBaseBranch;

                var config = new ProviderConfig
                {
                    Id = item.Existing?.Id ?? Guid.NewGuid().ToString(),
                    Kind = item.Kind,
                    ProviderType = "GitHub",
                    DisplayName = item.Existing?.DisplayName ?? $"{_relatedModalOwner}/{_relatedModalRepo} - {item.Kind}",
                    Settings = settings
                };

                await ConfigStore.SaveProviderConfigAsync(config, CancellationToken.None);
                item.Selected = false; // Mark as done so retry won't duplicate
                if (item.Existing != null) updated++; else created++;
            }

            await LoadAllData();
            _showRelatedProvidersModal = false;
            ShowStatus($"Related providers: {created} created, {updated} updated.");
        }
        catch (Exception ex)
        {
            _relatedModalStatus = $"Failed: {ex.Message}";
            _relatedModalIsError = true;
        }
        finally
        {
            _relatedModalSaving = false;
        }
    }

    private class RelatedProviderItem
    {
        public ProviderKind Kind { get; set; }
        public bool Selected { get; set; }
        public ProviderConfig? Existing { get; set; }
    }

