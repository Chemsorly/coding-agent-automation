    private async Task OnPipelineKeyFileSelected(InputFileChangeEventArgs e)
    {
        await ReadPemFileAsync(e, base64 => _pipelineProviderForm.PrivateKeyBase64 = base64);
    }

    // --- File Upload Handlers ---
    private async Task OnIssueKeyFileSelected(InputFileChangeEventArgs e)
    {
