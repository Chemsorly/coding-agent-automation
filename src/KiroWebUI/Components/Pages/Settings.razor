    }

    private async Task OnRepoKeyFileSelected(InputFileChangeEventArgs e)
    {
        await ReadPemFileAsync(e, base64 => _repoForm.PrivateKeyBase64 = base64);
    }

    private async Task ReadPemFileAsync(InputFileChangeEventArgs e, Action<string> setter)
    {
        var file = e.File;
        if (file is null) return;

        // Limit to 32KB — PEM files are typically ~3KB
        const int maxSize = 32 * 1024;
        using var stream = file.OpenReadStream(maxSize);
        using var reader = new StreamReader(stream);
        var pemContent = await reader.ReadToEndAsync();
        var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(pemContent));
        setter(base64);
        StateHasChanged();
    }

    // --- Fetch Repos ---
    private async Task FetchIssueRepos()
    {
        if (string.IsNullOrWhiteSpace(_issueForm.ClientId) || string.IsNullOrWhiteSpace(_issueForm.InstallationId)
            || string.IsNullOrWhiteSpace(_issueForm.PrivateKeyBase64))
        {
            _issueValidationMessage = "Enter Client ID, Installation ID, and Private Key first.";
            _issueValidationSuccess = false;
            return;
        }

        if (!long.TryParse(_issueForm.InstallationId, out var installationId))
        {
            _issueValidationMessage = "Installation ID must be a valid number.";
            _issueValidationSuccess = false;
            return;
        }

        _issueLoadingRepos = true;
        _issueValidationMessage = null;
        StateHasChanged();

        var (credOk, credMsg) = await GitHubValidator.ValidateAppCredentialsAsync(
            _issueForm.ApiUrl, _issueForm.ClientId, installationId, _issueForm.PrivateKeyBase64, CancellationToken.None);
        if (!credOk)
        {
            _issueValidationMessage = credMsg;
            _issueValidationSuccess = false;
            _issueLoadingRepos = false;
            return;
        }

        var repos = await GitHubValidator.ListRepositoriesWithAppAsync(
            _issueForm.ApiUrl, _issueForm.ClientId, installationId, _issueForm.PrivateKeyBase64, CancellationToken.None);
        _issueAvailableRepos = repos.ToList();
        _issueValidationMessage = $"{credMsg} — {repos.Count} repositories found";
        _issueValidationSuccess = true;
        _issueLoadingRepos = false;
    }

