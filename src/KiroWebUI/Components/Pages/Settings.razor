@page "/settings"
@rendermode InteractiveServer
@using KiroWebUI.Pipeline.Interfaces
@using KiroWebUI.Pipeline.Models
@using KiroWebUI.Pipeline.Services
@inject IConfigurationStore ConfigStore
@inject GitHubValidationService GitHubValidator

<div class="settings-page">
    <header class="settings-header">
        <h1>Settings</h1>
    </header>

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <div class="settings-status @(_isError ? "status-error" : "status-success")">@_statusMessage</div>
    }

    <div class="settings-sections">
        <!-- Issue Providers Section -->
        <section class="settings-section">
            <h2>Issue Providers</h2>
            <div class="provider-list">
                @foreach (var p in _issueProviders)
                {
                    <div class="provider-card">
                        <div class="provider-info">
                            <strong>@p.DisplayName</strong>
                            <span class="provider-type">@p.ProviderType</span>
                            <span class="provider-detail">@p.Settings.GetValueOrDefault("owner", "")/@p.Settings.GetValueOrDefault("repo", "")</span>
                        </div>
                        <div class="provider-actions">
                            <button class="btn-edit" @onclick="() => EditIssueProvider(p)">Edit</button>
                            <button class="btn-delete" @onclick="() => DeleteProvider(p.Id, ProviderKind.Issue)">Delete</button>
                        </div>
                    </div>
                }
            </div>
            @if (_showIssueForm)
            {
                <div class="provider-form-row">
                    <div class="provider-form">
                        <h3>@(_editingIssueProvider != null ? "Edit" : "Add") Issue Provider</h3>
                        <div class="form-group">
                            <label>Provider Type</label>
                            <select @bind="_issueForm.ProviderType"><option value="GitHub">GitHub</option></select>
                        </div>
                        <div class="form-group">
                            <label>Display Name</label>
                            <input type="text" @bind="_issueForm.DisplayName" placeholder="My GitHub Issues" />
                        </div>
                        <div class="form-group">
                            <label>API URL</label>
                            <input type="text" @bind="_issueForm.ApiUrl" placeholder="https://api.github.com" />
                        </div>
                        <div class="form-group">
                            <label>Client ID</label>
                            <input type="text" @bind="_issueForm.ClientId" placeholder="Iv1.abc123..." />
                        </div>
                        <div class="form-group">
                            <label>App ID</label>
                            <input type="text" @bind="_issueForm.AppId" placeholder="123456" />
                        </div>
                        <div class="form-group">
                            <label>Installation ID</label>
                            <input type="text" @bind="_issueForm.InstallationId" placeholder="78901234" />
                        </div>
                        <div class="form-group">
                            <label>Private Key (.pem file)</label>
                            <InputFile OnChange="OnIssueKeyFileSelected" accept=".pem" />
                            <div class="input-with-action" style="margin-top: 0.5rem;">
                                @if (!string.IsNullOrEmpty(_issueForm.PrivateKeyBase64))
                                {
                                    <span class="key-status" style="color: #4ade80;">✅ Key loaded</span>
                                }
                                <button class="btn-edit" @onclick="FetchIssueRepos" disabled="@_issueLoadingRepos">
                                    @(_issueLoadingRepos ? "Loading..." : "Fetch Repos")
                                </button>
                            </div>
                        </div>
                        @if (_issueAvailableRepos.Count > 0)
                        {
                            <div class="form-group">
                                <label>Repository</label>
                                <select @bind="_issueSelectedRepo">
                                    <option value="">-- Select Repository --</option>
                                    @foreach (var r in _issueAvailableRepos)
                                    {
                                        <option value="@r.FullName">@r.FullName</option>
                                    }
                                </select>
                            </div>
                        }
                        else
                        {
                            <div class="form-group">
                                <label>Owner</label>
                                <input type="text" @bind="_issueForm.Owner" placeholder="owner" />
                            </div>
                            <div class="form-group">
                                <label>Repository</label>
                                <input type="text" @bind="_issueForm.Repo" placeholder="repo" />
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_issueValidationMessage))
                        {
                            <div class="settings-status @(_issueValidationSuccess ? "status-success" : "status-error")">@_issueValidationMessage</div>
                        }
                        <div class="form-buttons">
                            <button class="btn-save" @onclick="SaveIssueProvider" disabled="@_issueSaving">
                                @(_issueSaving ? "Validating..." : "Save")
                            </button>
                            <button class="btn-cancel" @onclick="() => { _showIssueForm = false; _issueAvailableRepos.Clear(); _issueValidationMessage = null; }">Cancel</button>
                        </div>
                    </div>
                    <div class="provider-help">
                        <h4>🔐 GitHub App Setup</h4>
                        <p>Configure a <strong>GitHub App</strong> for authentication. See
                            <a href="https://docs.github.com/en/apps/creating-github-apps/registering-a-github-app/registering-a-github-app" target="_blank">GitHub App docs</a>.</p>
                        <p class="help-heading">Required permissions:</p>
                        <ul>
                            <li><strong>Issues: Read &amp; write</strong> — fetch and list issues</li>
                        </ul>
                        <p class="help-heading">Fields:</p>
                        <ul>
                            <li><strong>Client ID</strong> — from the App's General settings page (e.g. <code>Iv1.abc123...</code>)</li>
                            <li><strong>App ID</strong> — numeric ID from the App's settings page</li>
                            <li><strong>Installation ID</strong> — from the installation URL (<code>github.com/settings/installations/{'{'}id{'}'}</code>)</li>
                            <li><strong>Private Key</strong> — upload the .pem file downloaded from the App's settings</li>
                            <li><strong>API URL</strong> — use <code>https://api.github.com</code> for github.com, or your GitHub Enterprise URL</li>
                        </ul>
                        <p class="help-tip">💡 You can reuse the same GitHub App for the Repository Provider if you add Contents and Pull requests permissions.</p>
                    </div>
                </div>
            }
            else
            {
                <button class="btn-add" @onclick="ShowAddIssueProvider">+ Add Issue Provider</button>
            }
        </section>

        <!-- Repository Providers Section -->
        <section class="settings-section">
            <h2>Repository Providers</h2>
            <div class="provider-list">
                @foreach (var p in _repoProviders)
                {
                    <div class="provider-card">
                        <div class="provider-info">
                            <strong>@p.DisplayName</strong>
                            <span class="provider-type">@p.ProviderType</span>
                            <span class="provider-detail">@p.Settings.GetValueOrDefault("owner", "")/@p.Settings.GetValueOrDefault("repo", "") → @p.Settings.GetValueOrDefault("baseBranch", "main")</span>
                        </div>
                        <div class="provider-actions">
                            <button class="btn-edit" @onclick="() => EditRepoProvider(p)">Edit</button>
                            <button class="btn-delete" @onclick="() => DeleteProvider(p.Id, ProviderKind.Repository)">Delete</button>
                        </div>
                    </div>
                }
            </div>
            @if (_showRepoForm)
            {
                <div class="provider-form-row">
                    <div class="provider-form">
                        <h3>@(_editingRepoProvider != null ? "Edit" : "Add") Repository Provider</h3>
                        <div class="form-group">
                            <label>Provider Type</label>
                            <select @bind="_repoForm.ProviderType"><option value="GitHub">GitHub</option></select>
                        </div>
                        <div class="form-group">
                            <label>Display Name</label>
                            <input type="text" @bind="_repoForm.DisplayName" placeholder="My GitHub Repo" />
                        </div>
                        <div class="form-group">
                            <label>API URL</label>
                            <input type="text" @bind="_repoForm.ApiUrl" placeholder="https://api.github.com" />
                        </div>
                        <div class="form-group">
                            <label>Client ID</label>
                            <input type="text" @bind="_repoForm.ClientId" placeholder="Iv1.abc123..." />
                        </div>
                        <div class="form-group">
                            <label>App ID</label>
                            <input type="text" @bind="_repoForm.AppId" placeholder="123456" />
                        </div>
                        <div class="form-group">
                            <label>Installation ID</label>
                            <input type="text" @bind="_repoForm.InstallationId" placeholder="78901234" />
                        </div>
                        <div class="form-group">
                            <label>Private Key (.pem file)</label>
                            <InputFile OnChange="OnRepoKeyFileSelected" accept=".pem" />
                            <div class="input-with-action" style="margin-top: 0.5rem;">
                                @if (!string.IsNullOrEmpty(_repoForm.PrivateKeyBase64))
                                {
                                    <span class="key-status" style="color: #4ade80;">✅ Key loaded</span>
                                }
                                <button class="btn-edit" @onclick="FetchRepoRepos" disabled="@_repoLoadingRepos">
                                    @(_repoLoadingRepos ? "Loading..." : "Fetch Repos")
                                </button>
                            </div>
                        </div>
                        @if (_repoAvailableRepos.Count > 0)
                        {
                            <div class="form-group">
                                <label>Repository</label>
                                <select @bind="_repoSelectedRepo">
                                    <option value="">-- Select Repository --</option>
                                    @foreach (var r in _repoAvailableRepos)
                                    {
                                        <option value="@r.FullName">@r.FullName</option>
                                    }
                                </select>
                            </div>
                        }
                        else
                        {
                            <div class="form-group">
                                <label>Owner</label>
                                <input type="text" @bind="_repoForm.Owner" placeholder="owner" />
                            </div>
                            <div class="form-group">
                                <label>Repository</label>
                                <input type="text" @bind="_repoForm.Repo" placeholder="repo" />
                            </div>
                        }
                        <div class="form-group">
                            <label>Base Branch</label>
                            <input type="text" @bind="_repoForm.BaseBranch" placeholder="main" />
                        </div>
                        @if (!string.IsNullOrEmpty(_repoValidationMessage))
                        {
                            <div class="settings-status @(_repoValidationSuccess ? "status-success" : "status-error")">@_repoValidationMessage</div>
                        }
                        <div class="form-buttons">
                            <button class="btn-save" @onclick="SaveRepoProvider" disabled="@_repoSaving">
                                @(_repoSaving ? "Validating..." : "Save")
                            </button>
                            <button class="btn-cancel" @onclick="() => { _showRepoForm = false; _repoAvailableRepos.Clear(); _repoValidationMessage = null; }">Cancel</button>
                        </div>
                    </div>
                    <div class="provider-help">
                        <h4>🔐 GitHub App Setup</h4>
                        <p>Configure a <strong>GitHub App</strong> for authentication. See
                            <a href="https://docs.github.com/en/apps/creating-github-apps/registering-a-github-app/registering-a-github-app" target="_blank">GitHub App docs</a>.</p>
                        <p class="help-heading">Required permissions:</p>
                        <ul>
                            <li><strong>Contents: Read &amp; write</strong> — clone, push branches, commit</li>
                            <li><strong>Pull requests: Read &amp; write</strong> — create PRs</li>
                        </ul>
                        <p class="help-heading">Fields:</p>
                        <ul>
                            <li><strong>Client ID</strong> — from the App's General settings page (e.g. <code>Iv1.abc123...</code>)</li>
                            <li><strong>App ID</strong> — numeric ID from the App's settings page</li>
                            <li><strong>Installation ID</strong> — from the installation URL (<code>github.com/settings/installations/{'{'}id{'}'}</code>)</li>
                            <li><strong>Private Key</strong> — upload the .pem file downloaded from the App's settings</li>
                            <li><strong>API URL</strong> — use <code>https://api.github.com</code> for github.com, or your GitHub Enterprise URL</li>
                            <li><strong>Base Branch</strong> — the branch PRs will target (e.g. <code>main</code>, <code>develop</code>)</li>
                        </ul>
                        <p class="help-tip">💡 Use the same GitHub App as the Issue Provider — just ensure it has Contents and Pull requests permissions.</p>
                    </div>
                </div>
            }
            else
            {
                <button class="btn-add" @onclick="ShowAddRepoProvider">+ Add Repository Provider</button>
            }
        </section>

        <!-- Agent Providers Section -->
        <section class="settings-section">
            <h2>Agent Providers</h2>
            <div class="provider-list">
                @foreach (var p in _agentProviders)
                {
                    <div class="provider-card">
                        <div class="provider-info">
                            <strong>@p.DisplayName</strong>
                            <span class="provider-type">@p.ProviderType</span>
                            <span class="provider-detail">@p.Settings.GetValueOrDefault("executablePath", "") · @(p.Settings.GetValueOrDefault("timeout", "30"))min</span>
                        </div>
                        <div class="provider-actions">
                            <button class="btn-edit" @onclick="() => EditAgentProvider(p)">Edit</button>
                            <button class="btn-delete" @onclick="() => DeleteProvider(p.Id, ProviderKind.Agent)">Delete</button>
                        </div>
                    </div>
                }
            </div>
            @if (_showAgentForm)
            {
                <div class="provider-form-row">
                    <div class="provider-form">
                        <h3>@(_editingAgentProvider != null ? "Edit" : "Add") Agent Provider</h3>
                        <div class="form-group">
                            <label>Provider Type</label>
                            <select @bind="_agentForm.ProviderType"><option value="KiroCli">KiroCli</option></select>
                        </div>
                        <div class="form-group">
                            <label>Display Name</label>
                            <input type="text" @bind="_agentForm.DisplayName" placeholder="Kiro CLI Agent" />
                        </div>
                        <div class="form-group">
                            <label>Executable Path</label>
                            <input type="text" @bind="_agentForm.ExecutablePath" placeholder="/root/.local/bin/kiro-cli" />
                        </div>
                        <div class="form-group">
                            <label>Timeout (minutes)</label>
                            <input type="number" @bind="_agentForm.TimeoutMinutes" min="1" />
                        </div>
                        <div class="form-group">
                            <label>Agent Name</label>
                            <input type="text" @bind="_agentForm.AgentName" placeholder="default" />
                        </div>
                        <div class="form-buttons">
                            <button class="btn-save" @onclick="SaveAgentProvider">Save</button>
                            <button class="btn-cancel" @onclick="() => _showAgentForm = false">Cancel</button>
                        </div>
                    </div>
                    <div class="provider-help">
                        <h4>🤖 Kiro CLI Setup</h4>
                        <p>The agent provider runs the Kiro CLI to generate code. Kiro CLI must be installed and authenticated separately.</p>
                        <p class="help-heading">Prerequisites:</p>
                        <ul>
                            <li>Install Kiro CLI — it's bundled with the Docker image, or install manually</li>
                            <li>Run <code>kiro-cli login</code> once to authenticate (device code flow)</li>
                        </ul>
                        <p class="help-heading">Fields:</p>
                        <ul>
                            <li><strong>Executable Path</strong> — full path to the kiro-cli binary (e.g. <code>/home/ubuntu/.local/bin/kiro-cli</code>)</li>
                            <li><strong>Timeout</strong> — max minutes per agent invocation before it's killed</li>
                            <li><strong>Agent Name</strong> — leave as <code>default</code> unless you have a custom agent configured</li>
                        </ul>
                        <p class="help-tip">💡 Auth tokens are stored in <code>~/.local/share/kiro-cli/</code> and persist across runs when using a Docker volume.</p>
                    </div>
                </div>
            }
            else
            {
                <button class="btn-add" @onclick="ShowAddAgentProvider">+ Add Agent Provider</button>
            }
        </section>

        <!-- Pipeline Configuration Section -->
        <section class="settings-section">
            <h2>Pipeline Providers</h2>
            <div class="provider-list">
                @foreach (var p in _pipelineProviders)
                {
                    <div class="provider-card">
                        <div class="provider-info">
                            <strong>@p.DisplayName</strong>
                            <span class="provider-type">@p.ProviderType</span>
                            <span class="provider-detail">@p.Settings.GetValueOrDefault("owner", "")/@p.Settings.GetValueOrDefault("repo", "")</span>
                        </div>
                        <div class="provider-actions">
                            <button class="btn-edit" @onclick="() => EditPipelineProvider(p)">Edit</button>
                            <button class="btn-delete" @onclick="() => DeleteProvider(p.Id, ProviderKind.Pipeline)">Delete</button>
                        </div>
                    </div>
                }
            </div>
            @if (_showPipelineProviderForm)
            {
                <div class="provider-form-row">
                    <div class="provider-form">
                        <h3>@(_editingPipelineProvider != null ? "Edit" : "Add") Pipeline Provider</h3>
                        <div class="form-group">
                            <label>Provider Type</label>
                            <select @bind="_pipelineProviderForm.ProviderType"><option value="GitHub">GitHub</option></select>
                        </div>
                        <div class="form-group">
                            <label>Display Name</label>
                            <input type="text" @bind="_pipelineProviderForm.DisplayName" placeholder="My GitHub CI" />
                        </div>
                        <div class="form-group">
                            <label>API URL</label>
                            <input type="text" @bind="_pipelineProviderForm.ApiUrl" placeholder="https://api.github.com" />
                        </div>
                        <div class="form-group">
                            <label>Client ID</label>
                            <input type="text" @bind="_pipelineProviderForm.ClientId" placeholder="Iv1.abc123..." />
                        </div>
                        <div class="form-group">
                            <label>Installation ID</label>
                            <input type="text" @bind="_pipelineProviderForm.InstallationId" placeholder="78901234" />
                        </div>
                        <div class="form-group">
                            <label>Private Key (.pem file)</label>
                            <InputFile OnChange="OnPipelineKeyFileSelected" accept=".pem" />
                            @if (!string.IsNullOrEmpty(_pipelineProviderForm.PrivateKeyBase64))
                            {
                                <span class="key-status" style="color: #4ade80;">✅ Key loaded</span>
                            }
                        </div>
                        <div class="form-group">
                            <label>Owner</label>
                            <input type="text" @bind="_pipelineProviderForm.Owner" placeholder="owner" />
                        </div>
                        <div class="form-group">
                            <label>Repository</label>
                            <input type="text" @bind="_pipelineProviderForm.Repo" placeholder="repo" />
                        </div>
                        <div class="form-buttons">
                            <button class="btn-save" @onclick="SavePipelineProvider">Save</button>
                            <button class="btn-cancel" @onclick="() => _showPipelineProviderForm = false">Cancel</button>
                        </div>
                    </div>
                    <div class="provider-help">
                        <h4>🔄 GitHub Actions CI</h4>
                        <p>Reads CI/CD pipeline status from GitHub Actions workflow runs. Used as an external quality gate.</p>
                        <p class="help-heading">Required permissions:</p>
                        <ul>
                            <li><strong>Actions: Read</strong> — read workflow run status and job results</li>
                        </ul>
                        <p class="help-tip">💡 Use the same GitHub App as the Issue/Repository providers if it has Actions read permission.</p>
                    </div>
                </div>
            }
            else
            {
                <button class="btn-add" @onclick="ShowAddPipelineProvider">+ Add Pipeline Provider</button>
            }
        </section>

        <!-- Pipeline Configuration Section -->
        <section class="settings-section">
            <h2>Pipeline Configuration</h2>
            <div class="provider-form">
                <div class="form-group">
                    <label>Max Retries</label>
                    <input type="number" @bind="_pipelineConfig.MaxRetries" min="0" max="10" />
                </div>
                <div class="form-group">
                    <label>Agent Timeout (minutes)</label>
                    <input type="number" @bind="_agentTimeoutMinutes" min="1" />
                </div>
                <div class="form-group">
                    <label>Min Coverage Threshold (%)</label>
                    <input type="number" @bind="_pipelineConfig.MinCoverageThreshold" min="0" max="100" step="0.1" />
                </div>
                <div class="form-group form-checkbox">
                    <label>
                        <input type="checkbox" @bind="_pipelineConfig.SecurityScanEnabled" />
                        Security Scan Enabled
                    </label>
                </div>
                <div class="form-group form-checkbox">
                    <label>
                        <input type="checkbox" @bind="_pipelineConfig.SelfReviewEnabled" />
                        Agent Self-Review Enabled
                    </label>
                </div>
                @if (_pipelineConfig.SelfReviewEnabled)
                {
                    <div class="form-group">
                        <label>Max Review Iterations</label>
                        <input type="number" @bind="_pipelineConfig.SelfReviewMaxIterations" min="1" max="5" />
                    </div>
                    <div class="form-group">
                        <label>Review Prompt</label>
                        <textarea @bind="_pipelineConfig.SelfReviewPrompt" rows="4" style="width:100%;"></textarea>
                    </div>
                }
                <div class="form-group form-checkbox">
                    <label>
                        <input type="checkbox" @bind="_pipelineConfig.ExternalCiEnabled" />
                        External CI Quality Gate
                    </label>
                </div>
                @if (_pipelineConfig.ExternalCiEnabled)
                {
                    <div class="form-group">
                        <label>CI Timeout (minutes)</label>
                        <input type="number" @bind="_externalCiTimeoutMinutes" min="1" max="60" />
                    </div>
                    <div class="form-group">
                        <label>CI Poll Interval (seconds)</label>
                        <input type="number" @bind="_externalCiPollIntervalSeconds" min="10" max="300" />
                    </div>
                }
                <div class="form-buttons">
                    <button class="btn-save" @onclick="SavePipelineConfig">Save Pipeline Configuration</button>
                </div>
            </div>
        </section>
    </div>
</div>

@code {
    private List<ProviderConfig> _issueProviders = new();
    private List<ProviderConfig> _repoProviders = new();
    private List<ProviderConfig> _agentProviders = new();
    private List<ProviderConfig> _pipelineProviders = new();
    private PipelineConfigForm _pipelineConfig = new();
    private int _agentTimeoutMinutes = 30;
    private int _externalCiTimeoutMinutes = 15;
    private int _externalCiPollIntervalSeconds = 30;

    private string? _statusMessage;
    private bool _isError;

    // Issue provider form
    private bool _showIssueForm;
    private ProviderConfig? _editingIssueProvider;
    private IssueProviderForm _issueForm = new();
    private List<(string FullName, string Owner, string Name)> _issueAvailableRepos = new();
    private string _issueSelectedRepo = "";
    private bool _issueLoadingRepos;
    private string? _issueValidationMessage;
    private bool _issueValidationSuccess;
    private bool _issueSaving;

    // Repo provider form
    private bool _showRepoForm;
    private ProviderConfig? _editingRepoProvider;
    private RepoProviderForm _repoForm = new();
    private List<(string FullName, string Owner, string Name)> _repoAvailableRepos = new();
    private string _repoSelectedRepo = "";
    private bool _repoLoadingRepos;
    private string? _repoValidationMessage;
    private bool _repoValidationSuccess;
    private bool _repoSaving;

    // Agent provider form
    private bool _showAgentForm;
    private ProviderConfig? _editingAgentProvider;
    private AgentProviderForm _agentForm = new();

    // Pipeline provider form
    private bool _showPipelineProviderForm;
    private ProviderConfig? _editingPipelineProvider;
    private PipelineProviderForm _pipelineProviderForm = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAllData();
    }

    private async Task LoadAllData()
    {
        try
        {
            _issueProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Issue, CancellationToken.None)).ToList();
            _repoProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Repository, CancellationToken.None)).ToList();
            _agentProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Agent, CancellationToken.None)).ToList();
            _pipelineProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Pipeline, CancellationToken.None)).ToList();

            var config = await ConfigStore.LoadPipelineConfigAsync(CancellationToken.None);
            _pipelineConfig = new PipelineConfigForm
            {
                MaxRetries = config.MaxRetries,
                MinCoverageThreshold = config.MinCoverageThreshold,
                SecurityScanEnabled = config.SecurityScanEnabled,
                SelfReviewEnabled = config.SelfReviewEnabled,
                SelfReviewMaxIterations = config.SelfReviewMaxIterations,
                SelfReviewPrompt = config.SelfReviewPrompt,
                ExternalCiEnabled = config.ExternalCiEnabled
            };
            _agentTimeoutMinutes = (int)config.AgentTimeout.TotalMinutes;
            _externalCiTimeoutMinutes = (int)config.ExternalCiTimeout.TotalMinutes;
            _externalCiPollIntervalSeconds = (int)config.ExternalCiPollInterval.TotalSeconds;
        }
        catch (Exception ex)
        {
            ShowStatus($"Failed to load settings: {ex.Message}", isError: true);
        }
    }

    // --- Issue Provider CRUD ---
    private void ShowAddIssueProvider()
    {
        _editingIssueProvider = null;
        _issueForm = new IssueProviderForm();
        _issueAvailableRepos.Clear();
        _issueSelectedRepo = "";
        _issueValidationMessage = null;
        _showIssueForm = true;
    }

    private void EditIssueProvider(ProviderConfig p)
    {
        _editingIssueProvider = p;
        _issueForm = new IssueProviderForm
        {
            ProviderType = p.ProviderType,
            DisplayName = p.DisplayName,
            ApiUrl = p.Settings.GetValueOrDefault("apiUrl", ""),
            ClientId = p.Settings.GetValueOrDefault("clientId", ""),
            AppId = p.Settings.GetValueOrDefault("appId", ""),
            InstallationId = p.Settings.GetValueOrDefault("installationId", ""),
            PrivateKeyBase64 = p.Settings.GetValueOrDefault("privateKeyBase64", ""),
            Owner = p.Settings.GetValueOrDefault("owner", ""),
            Repo = p.Settings.GetValueOrDefault("repo", "")
        };
        _showIssueForm = true;
    }

    private async Task SaveIssueProvider()
    {
        if (string.IsNullOrWhiteSpace(_issueForm.DisplayName))
        {
            _issueValidationMessage = "Display Name is required.";
            _issueValidationSuccess = false;
            return;
        }

        // Apply selected repo from dropdown if available
        if (!string.IsNullOrEmpty(_issueSelectedRepo))
        {
            var selected = _issueAvailableRepos.FirstOrDefault(r => r.FullName == _issueSelectedRepo);
            if (selected != default)
            {
                _issueForm.Owner = selected.Owner;
                _issueForm.Repo = selected.Name;
            }
        }

        if (string.IsNullOrWhiteSpace(_issueForm.Owner) || string.IsNullOrWhiteSpace(_issueForm.Repo))
        {
            _issueValidationMessage = "Owner and Repository are required.";
            _issueValidationSuccess = false;
            return;
        }

        // Validate App credentials
        _issueSaving = true;
        _issueValidationMessage = "Validating GitHub App credentials...";
        _issueValidationSuccess = true;
        StateHasChanged();

        if (!long.TryParse(_issueForm.InstallationId, out var installationId))
        {
            _issueValidationMessage = "Installation ID must be a valid number.";
            _issueValidationSuccess = false;
            _issueSaving = false;
            return;
        }

        var (success, message) = await GitHubValidator.ValidateAppCredentialsAsync(
            _issueForm.ApiUrl, _issueForm.ClientId, installationId, _issueForm.PrivateKeyBase64, CancellationToken.None,
            _issueForm.Owner, _issueForm.Repo);

        if (!success)
        {
            _issueValidationMessage = message;
            _issueValidationSuccess = false;
            _issueSaving = false;
            return;
        }

        var config = new ProviderConfig
        {
            Id = _editingIssueProvider?.Id ?? Guid.NewGuid().ToString(),
            Kind = ProviderKind.Issue,
            ProviderType = _issueForm.ProviderType,
            DisplayName = _issueForm.DisplayName,
            Settings = new Dictionary<string, string>
            {
                ["apiUrl"] = _issueForm.ApiUrl,
                ["clientId"] = _issueForm.ClientId,
                ["appId"] = _issueForm.AppId,
                ["installationId"] = _issueForm.InstallationId,
                ["privateKeyBase64"] = _issueForm.PrivateKeyBase64,
                ["owner"] = _issueForm.Owner,
                ["repo"] = _issueForm.Repo
            }
        };

        try
        {
            await ConfigStore.SaveProviderConfigAsync(config, CancellationToken.None);
            _showIssueForm = false;
            _issueAvailableRepos.Clear();
            _issueValidationMessage = null;
            await LoadAllData();
            ShowStatus($"Issue provider saved. {message}");
        }
        catch (Exception ex)
        {
            ShowStatus($"Failed to save: {ex.Message}", isError: true);
        }
        finally
        {
            _issueSaving = false;
        }
    }

