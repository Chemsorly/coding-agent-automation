@page "/agent-coding"
@rendermode InteractiveServer
@implements IDisposable
@using KiroWebUI.Pipeline.Interfaces
@using KiroWebUI.Pipeline.Models
@using KiroWebUI.Pipeline.Services
@inject PipelineOrchestrationService PipelineService
@inject IConfigurationStore ConfigStore
@inject IProviderFactory ProviderFactory
@inject IJSRuntime JS

<div class="agent-coding-page">
    <header class="agent-header">
        <h1>Agent Coding</h1>
        @if (PipelineService.ActiveRun is not null)
        {
            <span class="step-badge step-@PipelineService.ActiveRun.CurrentStep.ToString().ToLowerInvariant()">
                @PipelineService.ActiveRun.CurrentStep
            </span>
        }
    </header>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="settings-status status-error">@_errorMessage</div>
    }

    @{
        var activeRun = PipelineService.ActiveRun;
        var hasActiveRun = activeRun is not null
            && activeRun.CurrentStep is not (PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled);
        var hasFinishedRun = activeRun is { CurrentStep: PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled };
    }

    <div class="agent-content-layout @(hasActiveRun || hasFinishedRun ? "with-sidebar" : "")">
        <div class="agent-main">
            @if (!PipelineService.IsRunning && activeRun is null or { CurrentStep: PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled })
            {
                <!-- Completion Summary -->
                @if (hasFinishedRun && _showCompletionOnly)
                {
                    <PipelineSummary Run="activeRun!" MaxRetries="@_maxRetries"
                                     OnBackToIssues="BackToIssues" />
                }

                <!-- Issue Selection View -->
                @if (activeRun is null || hasFinishedRun)
                {
                    @if (!_showCompletionOnly)
                    {
                        <div class="issue-selection">
                            <h2>Select an Issue</h2>
                            <div class="form-group">
                                <label>Issue Provider</label>
                                <select @bind="_selectedIssueProviderId" @bind:after="OnIssueProviderChanged">
                                    <option value="">-- Select Provider --</option>
                                    @foreach (var p in _issueProviders)
                                    {
                                        <option value="@p.Id">@p.DisplayName</option>
                                    }
                                </select>
                            </div>

                            @if (_loadingIssues)
                            {
                                <div class="loading-text">Loading issues...</div>
                            }

                            @if (_issues.Count > 0)
                            {
                                @if (_availableLabels.Count > 0)
                                {
                                    <div class="label-filter">
                                        <div class="label-filter-header">
                                            <span class="label-filter-title">Filter by labels:</span>
                                            @if (_selectedLabels.Count > 0)
                                            {
                                                <button class="label-clear-btn" @onclick="ClearLabelFilter">Clear all</button>
                                            }
                                        </div>
                                        @if (_selectedLabels.Count > 0)
                                        {
                                            <div class="label-active-filters">
                                                @foreach (var label in _selectedLabels.OrderBy(l => l))
                                                {
                                                    <button class="label-chip label-chip-active"
                                                            aria-label="Remove filter: @label"
                                                            @onclick="() => ToggleLabel(label)">@label ✕</button>
                                                }
                                            </div>
                                        }
                                        <div class="label-chip-list">
                                            @foreach (var label in _availableLabels)
                                            {
                                                <button class="label-chip @(_selectedLabels.Contains(label) ? "label-chip-selected" : "")"
                                                        aria-pressed="@(_selectedLabels.Contains(label) ? "true" : "false")"
                                                        @onclick="() => ToggleLabel(label)">@label</button>
                                            }
                                        </div>
                                    </div>
                                }

                                @if (_selectedLabels.Count > 0)
                                {
                                    <div class="label-filter-count" aria-live="polite">Showing @FilteredIssues.Count of @_issues.Count issues</div>
                                }

                                <div class="issue-list">
                                    @foreach (var issue in FilteredIssues)
                                    {
                                        <div class="issue-card @(_selectedIssueId == issue.Identifier ? "issue-selected" : "")"
                                             @onclick="() => SelectIssue(issue.Identifier)">
                                            <span class="issue-id">#@issue.Identifier</span>
                                            <span class="issue-title">@issue.Title</span>
                                            @if (issue.Labels.Count > 0)
                                            {
                                                <div class="issue-labels">
                                                    @foreach (var label in issue.Labels)
                                                    {
                                                        <span class="issue-label">@label</span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            @if (_loadingIssueDetail)
                            {
                                <div class="loading-text">Loading issue details...</div>
                            }

                            @if (_selectedIssueDetail != null)
                            {
                                <div class="issue-detail-panel">
                                    <h3>#@_selectedIssueDetail.Identifier @_selectedIssueDetail.Title</h3>
                                    <pre class="issue-description">@_selectedIssueDetail.Description</pre>
                                    @if (_selectedIssueDetail.Labels.Count > 0)
                                    {
                                        <div class="issue-labels">
                                            @foreach (var label in _selectedIssueDetail.Labels)
                                            {
                                                <span class="issue-label">@label</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(_selectedIssueId))
                            {
                                <div class="form-group">
                                    <label>Repository Provider</label>
                                    <select @bind="_selectedRepoProviderId">
                                        <option value="">-- Select Repository --</option>
                                        @foreach (var p in _repoProviders)
                                        {
                                            <option value="@p.Id">@p.DisplayName (@p.Settings.GetValueOrDefault("owner", "")/@p.Settings.GetValueOrDefault("repo", "") → @p.Settings.GetValueOrDefault("baseBranch", "main"))</option>
                                        }
                                    </select>
                                </div>

                                <button class="btn-save" @onclick="StartPipeline"
                                        disabled="@(string.IsNullOrEmpty(_selectedRepoProviderId))">
                                    🚀 Start Pipeline
                                </button>
                            }
                        </div>
                    }
                }
            }
            else if (activeRun is not null)
            {
                var run = activeRun;

                <!-- Pipeline Progress View -->
                @if (run.CurrentStep is PipelineStep.CloningRepository or PipelineStep.CreatingBranch
                    or PipelineStep.AnalyzingCode or PipelineStep.GeneratingCode
                    or PipelineStep.ReviewingCode
                    or PipelineStep.RunningQualityGates
                    or PipelineStep.CreatingPullRequest or PipelineStep.Created
                    or PipelineStep.PostingAnalysis)
                {
                    <div class="progress-view">
                        <h2>Pipeline in Progress</h2>

                        <div class="output-panel" id="outputPanel">
                            @foreach (var line in _outputLines.TakeLast(200))
                            {
                                <div class="output-line">@line</div>
                            }
                        </div>
                    </div>
                }

                <!-- Analysis Approval View -->
                @if (run.CurrentStep == PipelineStep.WaitingForAnalysisApproval)
                {
                    <div class="analysis-approval-panel">
                        <h2>Review Agent Analysis</h2>
                        <p class="analysis-subtitle">The agent analyzed the codebase in context of issue <strong>#@run.IssueIdentifier @run.IssueTitle</strong>. Review the analysis before proceeding to implementation.</p>

                        <div class="analysis-content" id="analysisContent">
                            @if (!string.IsNullOrWhiteSpace(run.AnalysisContent))
                            {
                                <pre class="analysis-text">@run.AnalysisContent</pre>
                            }
                            else
                            {
                                <p class="analysis-fallback">Agent analysis was not available. A metadata-based analysis was posted to the issue instead.</p>
                            }
                        </div>

                        <div class="analysis-actions">
                            <button class="btn-save" @onclick="ApproveAnalysis">
                                ✅ Approve &amp; Continue to Implementation
                            </button>
                        </div>
                    </div>
                }

                <!-- Chat Panel View -->
                @if (run.CurrentStep == PipelineStep.WaitingForChat)
                {
                    <div class="chat-panel">
                        <h2>Chat with Agent</h2>

                        <div class="chat-history" id="chatHistory">
                            @foreach (var entry in run.ChatHistory.ToArray())
                            {
                                <div class="chat-entry chat-@entry.Role.ToString().ToLowerInvariant()">
                                    <div class="chat-role">
                                        @(entry.Role == ChatRole.User ? "You" : entry.Role == ChatRole.Agent ? "Agent" : "System")
                                        <span class="chat-timestamp">@entry.Timestamp.ToLocalTime().ToString("h:mm tt")</span>
                                    </div>
                                    <pre class="chat-content">@entry.Content</pre>
                                </div>
                            }
                        </div>

                        <div class="chat-input-area">
                            <div class="input-row">
                                <input type="text"
                                       @bind="_chatInput"
                                       @bind:event="oninput"
                                       @onkeydown="HandleChatKeyDown"
                                       placeholder="Send follow-up instructions..."
                                       disabled="@_isSending"
                                       class="prompt-input" />
                                <button class="send-button" @onclick="SendChatMessage" disabled="@_isSending">
                                    @(_isSending ? "⏳" : "Send")
                                </button>
                            </div>
                            <div class="chat-actions">
                                <button class="btn-save" @onclick="ProceedToQualityGates" disabled="@_isSending">
                                    Proceed to Quality Gates
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        @if (activeRun is not null && (hasActiveRun || hasFinishedRun))
        {
            <PipelineSidebar Run="activeRun" IsRunning="PipelineService.IsRunning"
                             OnCancel="CancelPipeline" MaxRetries="@_maxRetries" />
        }
    </div>

    <!-- Run History Panel -->
    <div class="run-history">
        <h2>Run History</h2>
        @{
            var history = PipelineService.GetRunHistory();
        }
        @if (history.Count == 0)
        {
            <p class="no-history">No pipeline runs yet.</p>
        }
        else
        {
            <div class="history-list">
                @foreach (var h in history)
                {
                    <div class="history-card">
                        <div class="history-info">
                            <span class="history-id">@h.RunId[..8]</span>
                            <span class="history-title">#@h.IssueIdentifier @h.IssueTitle</span>
                            <span class="step-badge step-@h.FinalStep.ToString().ToLowerInvariant()">@h.FinalStep</span>
                        </div>
                        <div class="history-meta">
                            <span>@h.StartedAt.ToLocalTime().ToString("g")</span>
                            @if (h.CompletedAt.HasValue)
                            {
                                <span>Duration: @((h.CompletedAt.Value - h.StartedAt).ToString(@"hh\:mm\:ss"))</span>
                            }
                            @if (!string.IsNullOrEmpty(h.PullRequestUrl))
                            {
                                <a href="@h.PullRequestUrl" target="_blank" rel="noopener noreferrer">PR</a>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<ProviderConfig> _issueProviders = new();
    private List<ProviderConfig> _repoProviders = new();
    private List<IssueSummary> _issues = new();
    private List<string> _availableLabels = new();
    private HashSet<string> _selectedLabels = new();
    private List<IssueSummary>? _filteredIssuesCache;
    private List<string> _outputLines = new();
    private IssueDetail? _selectedIssueDetail;
    private bool _loadingIssueDetail;

    private string _selectedIssueProviderId = "";
    private string _selectedIssueId = "";
    private string _selectedRepoProviderId = "";
    private string? _errorMessage;
    private bool _loadingIssues;
    private bool _showCompletionOnly;
    private string _chatInput = "";
    private bool _isSending;
    private bool _disposed;
    private Timer? _elapsedTimer;
    private int _maxRetries = 3;

    private IReadOnlyList<IssueSummary> FilteredIssues =>
        _filteredIssuesCache ??= _selectedLabels.Count == 0
            ? _issues
            : _issues.Where(i => i.Labels.Any(l => _selectedLabels.Contains(l))).ToList();

    private void ToggleLabel(string label)
    {
        if (!_selectedLabels.Remove(label))
            _selectedLabels.Add(label);
        _filteredIssuesCache = null;
        ClearSelectionIfFiltered();
    }

    private void ClearLabelFilter()
    {
        _selectedLabels.Clear();
        _filteredIssuesCache = null;
    }

    private void ClearSelectionIfFiltered()
    {
        if (!string.IsNullOrEmpty(_selectedIssueId)
            && !FilteredIssues.Any(i => i.Identifier == _selectedIssueId))
        {
            _selectedIssueId = "";
            _selectedIssueDetail = null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        PipelineService.OnChange += HandleStateChanged;
        PipelineService.OnOutputLine += HandleOutputLine;

        _elapsedTimer = new Timer(ElapsedTimerTick, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));

        try
        {
            _issueProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Issue, CancellationToken.None)).ToList();
            _repoProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Repository, CancellationToken.None)).ToList();

            var config = await ConfigStore.LoadPipelineConfigAsync(CancellationToken.None);
            _maxRetries = config.MaxRetries;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load providers: {ex.Message}";
        }
    }

    private async void ElapsedTimerTick(object? state)
    {
        if (_disposed) return;
        var run = PipelineService.ActiveRun;
        if (run is null) return;
        if (run.CurrentStep is PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled)
            return;

        try
        {
            await InvokeAsync(() => { if (!_disposed) StateHasChanged(); });
        }
        catch (ObjectDisposedException) { }
    }

    private async void HandleStateChanged()
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed) return;

                var run = PipelineService.ActiveRun;
                if (run is { CurrentStep: PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled })
                    _showCompletionOnly = true;

                StateHasChanged();
                try
                {
                    await JS.InvokeVoidAsync("scrollToBottom", "outputPanel");
                    await JS.InvokeVoidAsync("scrollToBottom", "chatHistory");
                    await JS.InvokeVoidAsync("scrollActiveStepIntoView", "sidebarSteps");
                }
                catch { }
            });
        }
        catch (ObjectDisposedException) { }
    }

    private async void HandleOutputLine(string line)
    {
        if (_disposed) return;
        _outputLines.Add(line);
        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed) return;
                StateHasChanged();
                try
                {
                    await JS.InvokeVoidAsync("scrollToBottom", "outputPanel");
                }
                catch { }
            });
        }
        catch (ObjectDisposedException) { }
    }

    private async Task OnIssueProviderChanged()
    {
        _issues.Clear();
        _selectedIssueId = "";
        _selectedLabels.Clear();
        _availableLabels.Clear();
        _filteredIssuesCache = null;
        _errorMessage = null;

        if (string.IsNullOrEmpty(_selectedIssueProviderId))
            return;

        _loadingIssues = true;
        try
        {
            var providerConfig = _issueProviders.FirstOrDefault(p => p.Id == _selectedIssueProviderId);
            if (providerConfig == null) return;

            var issueProvider = ProviderFactory.CreateIssueProvider(providerConfig);
            var issues = await issueProvider.ListOpenIssuesAsync(CancellationToken.None);
            _issues = issues.ToList();
            _availableLabels = _issues.SelectMany(i => i.Labels).Distinct().OrderBy(l => l).ToList();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to fetch issues: {ex.Message}";
        }
        finally
        {
            _loadingIssues = false;
        }
    }

    private async Task SelectIssue(string issueId)
    {
        _selectedIssueId = issueId;
        _selectedIssueDetail = null;
        _loadingIssueDetail = true;
        StateHasChanged();

        try
        {
            var providerConfig = _issueProviders.FirstOrDefault(p => p.Id == _selectedIssueProviderId);
            if (providerConfig != null)
            {
                var issueProvider = ProviderFactory.CreateIssueProvider(providerConfig);
                _selectedIssueDetail = await issueProvider.GetIssueAsync(issueId, CancellationToken.None);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load issue details: {ex.Message}";
        }
        finally
        {
            _loadingIssueDetail = false;
        }
    }

    private async Task StartPipeline()
    {
        _errorMessage = null;

        if (PipelineService.IsRunning)
        {
            _errorMessage = "A pipeline run is already in progress.";
            return;
        }

        if (string.IsNullOrEmpty(_selectedIssueProviderId) || string.IsNullOrEmpty(_selectedRepoProviderId)
            || string.IsNullOrEmpty(_selectedIssueId))
        {
            _errorMessage = "Please select an issue provider, issue, and repository provider.";
            return;
        }

        _outputLines.Clear();
        _showCompletionOnly = false;

        try
        {
            _ = Task.Run(async () =>
            {
                try
                {
                    await PipelineService.StartPipelineAsync(
                        _selectedIssueProviderId, _selectedRepoProviderId,
                        _selectedIssueId, CancellationToken.None);
                }
                catch (Exception ex)
                {
                    await InvokeAsync(() =>
                    {
                        _errorMessage = $"Pipeline failed: {ex.Message}";
                        StateHasChanged();
                    });
                }
            });
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to start pipeline: {ex.Message}";
        }
    }

    private async Task HandleChatKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_isSending)
        {
            await SendChatMessage();
        }
    }

    private async Task SendChatMessage()
    {
        if (string.IsNullOrWhiteSpace(_chatInput) || _isSending)
            return;

        var message = _chatInput;
        _chatInput = "";
        _isSending = true;
        _errorMessage = null;

        try
        {
            await PipelineService.SendChatMessageAsync(message, CancellationToken.None);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Chat error: {ex.Message}";
        }
        finally
        {
            _isSending = false;
        }
    }

    private async Task ProceedToQualityGates()
    {
        _isSending = true;
        _errorMessage = null;

        try
        {
            await PipelineService.ProceedToQualityGatesAsync(CancellationToken.None);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Quality gate error: {ex.Message}";
        }
        finally
        {
            _isSending = false;
        }
    }

    private async Task ApproveAnalysis()
    {
        _errorMessage = null;

        try
        {
            _ = Task.Run(async () =>
            {
                try
                {
                    await PipelineService.ApproveAnalysisAsync(CancellationToken.None);
                }
                catch (Exception ex)
                {
                    await InvokeAsync(() =>
                    {
                        _errorMessage = $"Pipeline failed: {ex.Message}";
                        StateHasChanged();
                    });
                }
            });
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to approve analysis: {ex.Message}";
        }
    }

    private async Task CancelPipeline()
    {
        try
        {
            await PipelineService.CancelPipelineAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Cancel error: {ex.Message}";
        }
    }

    private void BackToIssues()
    {
        _showCompletionOnly = false;
        _errorMessage = null;
    }

    public void Dispose()
    {
        _disposed = true;
        _elapsedTimer?.Dispose();
        PipelineService.OnChange -= HandleStateChanged;
        PipelineService.OnOutputLine -= HandleOutputLine;
    }
}
