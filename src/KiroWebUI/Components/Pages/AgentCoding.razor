@page "/agent-coding"
@rendermode InteractiveServer
@implements IDisposable
@using KiroWebUI.Pipeline.Interfaces
@using KiroWebUI.Pipeline.Models
@using KiroWebUI.Pipeline.Services
@inject PipelineOrchestrationService PipelineService
@inject IConfigurationStore ConfigStore
@inject IProviderFactory ProviderFactory
@inject IJSRuntime JS

<div class="agent-coding-page">
    <header class="agent-header">
        <h1>Agent Coding</h1>
        @if (PipelineService.ActiveRun is not null)
        {
            <span class="step-badge step-@PipelineService.ActiveRun.CurrentStep.ToString().ToLowerInvariant()">
                @PipelineService.ActiveRun.CurrentStep
            </span>
        }
    </header>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="settings-status status-error">@_errorMessage</div>
    }

    @{
        var activeRun = PipelineService.ActiveRun;
        var hasActiveRun = activeRun is not null
            && activeRun.CurrentStep is not (PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled);
        var hasFinishedRun = activeRun is { CurrentStep: PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled };
    }

    <div class="agent-content-layout @(hasActiveRun || hasFinishedRun ? "with-sidebar" : "")">
        <div class="agent-main">
            @if (!PipelineService.IsRunning && activeRun is null or { CurrentStep: PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled })
            {
                <!-- Completion Summary -->
                @if (hasFinishedRun && _showCompletionOnly)
                {
                    <PipelineSummary Run="activeRun!" MaxRetries="@_maxRetries"
                                     OnBackToIssues="BackToIssues" />
                }

                <!-- Issue Selection + Pipeline Setup (two-column) -->
                @if (activeRun is null || hasFinishedRun)
                {
                    @if (!_showCompletionOnly)
                    {
                        <div class="pipeline-setup-layout">
                            <!-- Left: Browse Issues -->
                            <div class="pipeline-setup-issues">
                              <div class="pipeline-setup-card">
                                <div class="config-category">
                                    <div class="config-category-title">Browse Issues</div>
                                    <div class="form-group">
                                        <label>Issue Provider</label>
                                        <select @bind="_selectedIssueProviderId" @bind:after="OnIssueProviderChanged">
                                            <option value="">-- Select Provider --</option>
                                            @foreach (var p in _issueProviders)
                                            {
                                                <option value="@p.Id">@p.DisplayName (@p.ProviderType: @p.Settings.GetValueOrDefault("owner", "")/@p.Settings.GetValueOrDefault("repo", ""))</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                @if (_loadingIssues)
                                {
                                    <div class="loading-text">Loading issues...</div>
                                }

                                @if (_issues.Count > 0)
                                {
                                    @if (_availableLabels.Count > 0)
                                    {
                                        <div class="label-filter">
                                            <div class="label-filter-header">
                                                <span class="label-filter-title">Filter by labels:</span>
                                                @if (_selectedLabels.Count > 0)
                                                {
                                                    <button class="label-clear-btn" @onclick="ClearLabelFilter">Clear all</button>
                                                }
                                            </div>
                                            @if (_selectedLabels.Count > 0)
                                            {
                                                <div class="label-active-filters">
                                                    @foreach (var label in _selectedLabels.OrderBy(l => l))
                                                    {
                                                        <button class="label-chip label-chip-active"
                                                                aria-label="Remove filter: @label"
                                                                @onclick="() => ToggleLabel(label)">@label ✕</button>
                                                    }
                                                </div>
                                            }
                                            <div class="label-chip-list">
                                                @foreach (var label in _availableLabels)
                                                {
                                                    <button class="label-chip @(_selectedLabels.Contains(label) ? "label-chip-selected" : "")"
                                                            aria-pressed="@(_selectedLabels.Contains(label) ? "true" : "false")"
                                                            @onclick="() => ToggleLabel(label)">@label</button>
                                                }
                                            </div>
                                        </div>
                                    }

                                    @if (_selectedLabels.Count > 0)
                                    {
                                        <div class="label-filter-count" aria-live="polite">Showing @FilteredIssues.Count of @_issues.Count issues</div>
                                    }

                                    <div class="issue-list">
                                        @foreach (var issue in FilteredIssues)
                                        {
                                            <div class="issue-card @(_selectedIssueId == issue.Identifier ? "issue-selected" : "")"
                                                 @onclick="() => SelectIssue(issue.Identifier)">
                                                <span class="issue-id">#@issue.Identifier</span>
                                                <span class="issue-title">@issue.Title</span>
                                                @if (issue.Labels.Count > 0)
                                                {
                                                    <div class="issue-labels">
                                                        @foreach (var label in issue.Labels)
                                                        {
                                                            <span class="issue-label">@label</span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                        @if (FilteredIssues.Count == 0 && _selectedLabels.Count > 0)
                                        {
                                            <div class="issue-list-empty" role="status">
                                                @if (_selectedLabels.Count == 1 && _selectedLabels.Contains(AgentLabels.Next))
                                                {
                                                    <span>No issues labeled <code>@AgentLabels.Next</code>. Label issues in GitHub to queue them for the agent.</span>
                                                }
                                                else
                                                {
                                                    <span>No issues match the selected filters.</span>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div class="issue-pagination">
                                        <button class="btn-page" disabled="@(_currentPage <= 1)" @onclick="PreviousPage">← Previous</button>
                                        <span class="page-indicator">Page @_currentPage</span>
                                        <button class="btn-page" disabled="@(!_hasMoreIssues)" @onclick="NextPage">Next →</button>
                                    </div>
                                }

                                @if (_loadingIssueDetail)
                                {
                                    <div class="loading-text">Loading issue details...</div>
                                }

                                @if (_selectedIssueDetail != null)
                                {
                                    <div class="issue-detail-panel">
                                        <h3>#@_selectedIssueDetail.Identifier @_selectedIssueDetail.Title</h3>
                                        <pre class="issue-description">@_selectedIssueDetail.Description</pre>
                                        @if (_selectedIssueDetail.Labels.Count > 0)
                                        {
                                            <div class="issue-labels">
                                                @foreach (var label in _selectedIssueDetail.Labels)
                                                {
                                                    <span class="issue-label">@label</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                              </div>
                            </div>

                            <!-- Right: Pipeline Setup (sticky) -->
                            <div class="pipeline-setup-panel">
                                <div class="pipeline-setup-card">
                                    <div class="config-category">
                                        <div class="config-category-title">Providers</div>
                                        <div class="form-group">
                                            <label>Repository Provider</label>
                                            <select @bind="_selectedRepoProviderId">
                                                <option value="">-- Select Repository --</option>
                                                @foreach (var p in _repoProviders)
                                                {
                                                    <option value="@p.Id">@p.DisplayName (@p.ProviderType: @p.Settings.GetValueOrDefault("owner", "")/@p.Settings.GetValueOrDefault("repo", "") → @p.Settings.GetValueOrDefault("baseBranch", "main"))</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Agent Provider</label>
                                            <select @bind="_selectedAgentProviderId">
                                                <option value="">-- Select Agent --</option>
                                                @foreach (var p in _agentProviders)
                                                {
                                                    <option value="@p.Id">@p.DisplayName (@p.ProviderType: @p.Settings.GetValueOrDefault("executablePath", ""))</option>
                                                }
                                            </select>
                                        </div>
                                        @if (_pipelineProviders.Count > 0)
                                        {
                                            <div class="form-group">
                                                <label>Pipeline Provider (CI)</label>
                                                <select @bind="_selectedPipelineProviderId">
                                                    <option value="">-- None --</option>
                                                    @foreach (var p in _pipelineProviders)
                                                    {
                                                        <option value="@p.Id">@p.DisplayName (@p.ProviderType: @p.Settings.GetValueOrDefault("owner", "")/@p.Settings.GetValueOrDefault("repo", ""))</option>
                                                    }
                                                </select>
                                            </div>
                                        }
                                        @if (_brainProviders.Count > 0)
                                        {
                                            <div class="form-group">
                                                <label>Brain Repository</label>
                                                <select @bind="_selectedBrainProviderId">
                                                    <option value="">-- None --</option>
                                                    @foreach (var p in _brainProviders)
                                                    {
                                                        <option value="@p.Id">@p.DisplayName (@p.Settings.GetValueOrDefault("owner", "")/@p.Settings.GetValueOrDefault("repo", ""))</option>
                                                    }
                                                </select>
                                            </div>
                                        }
                                    </div>

                                    @if (!string.IsNullOrEmpty(_selectedIssueId) && _selectedIssueDetail != null)
                                    {
                                        <div class="config-category">
                                            <div class="config-category-title">Selected Issue</div>
                                            <div class="pipeline-selected-issue">
                                                <strong>#@_selectedIssueDetail.Identifier</strong> @_selectedIssueDetail.Title
                                                @if (_selectedIssueDetail.Labels.Count > 0)
                                                {
                                                    <div class="issue-labels" style="margin-top: 6px;">
                                                        @foreach (var label in _selectedIssueDetail.Labels)
                                                        {
                                                            <span class="issue-label">@label</span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }

                                    <button class="btn-save pipeline-start-btn" @onclick="StartPipeline"
                                            disabled="@(!CanStartPipeline)">
                                        🚀 Start Pipeline
                                    </button>

                                    @if (!CanStartPipeline && !string.IsNullOrEmpty(_selectedIssueProviderId))
                                    {
                                        <div class="pipeline-setup-hint">
                                            @if (string.IsNullOrEmpty(_selectedIssueId))
                                            {
                                                <span>Select an issue to continue</span>
                                            }
                                            else if (string.IsNullOrEmpty(_selectedRepoProviderId))
                                            {
                                                <span>Select a repository provider</span>
                                            }
                                            else if (string.IsNullOrEmpty(_selectedAgentProviderId))
                                            {
                                                <span>Select an agent provider</span>
                                            }
                                        </div>
                                    }

                                    <!-- Run History -->
                                    @{
                                        var history = PipelineService.GetRunHistory();
                                    }
                                    @if (history.Count > 0)
                                    {
                                        <div class="config-category" style="margin-top: 8px;">
                                            <div class="config-category-title run-history-toggle-title" @onclick="() => _historyExpanded = !_historyExpanded" role="button" tabindex="0">
                                                <span>Run History</span>
                                                <span class="run-history-count">@history.Count</span>
                                                <span class="run-history-toggle">@(_historyExpanded ? "▾" : "▸")</span>
                                            </div>
                                            @if (_historyExpanded)
                                            {
                                                <div class="history-list">
                                                    @foreach (var h in history)
                                                    {
                                                        <div class="history-card">
                                                            <div class="history-info">
                                                                <span class="history-title">#@h.IssueIdentifier @Truncate(h.IssueTitle, 40)</span>
                                                                <span class="step-badge step-@h.FinalStep.ToString().ToLowerInvariant()">@h.FinalStep</span>
                                                            </div>
                                                            <div class="history-meta">
                                                                <span>@h.StartedAt.ToLocalTime().ToString("g")</span>
                                                                @if (h.CompletedAt.HasValue)
                                                                {
                                                                    <span>@((h.CompletedAt.Value - h.StartedAt).ToString(@"hh\:mm\:ss"))</span>
                                                                }
                                                                @if (!string.IsNullOrEmpty(h.PullRequestUrl))
                                                                {
                                                                    <a href="@h.PullRequestUrl" target="_blank" rel="noopener noreferrer">PR</a>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            }
            else if (activeRun is not null)
            {
                var run = activeRun;

                <!-- Pipeline Progress View -->
                @if (run.CurrentStep is PipelineStep.CloningRepository or PipelineStep.CreatingBranch
                    or PipelineStep.SyncingBrainRepoPreRun
                    or PipelineStep.AnalyzingCode or PipelineStep.GeneratingCode
                    or PipelineStep.ReviewingCode
                    or PipelineStep.RunningQualityGates
                    or PipelineStep.CreatingPullRequest or PipelineStep.Created
                    or PipelineStep.PostingAnalysis
                    or PipelineStep.SyncingBrainRepoPostRun)
                {
                    <div class="progress-view">
                        <h2>Pipeline in Progress</h2>

                        <div class="output-panel" id="outputPanel">
                            @foreach (var line in _outputLines.TakeLast(200))
                            {
                                <div class="output-line">@line</div>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        @if (activeRun is not null && (hasActiveRun || hasFinishedRun))
        {
            <PipelineSidebar Run="activeRun" IsRunning="PipelineService.IsRunning"
                             OnCancel="CancelPipeline" MaxRetries="@_maxRetries" />
        }
    </div>
</div>

@code {
    private List<ProviderConfig> _issueProviders = new();
    private List<ProviderConfig> _repoProviders = new();
    private List<ProviderConfig> _agentProviders = new();
    private List<ProviderConfig> _pipelineProviders = new();
    private List<ProviderConfig> _brainProviders = new();
    private List<IssueSummary> _issues = new();
    private List<string> _availableLabels = new();
    private HashSet<string> _selectedLabels = new();
    private List<IssueSummary>? _filteredIssuesCache;
    private List<string> _outputLines = new();
    private IssueDetail? _selectedIssueDetail;
    private bool _historyExpanded;
    private bool _loadingIssueDetail;

    private string _selectedIssueProviderId = "";
    private string _selectedIssueId = "";
    private string _selectedRepoProviderId = "";
    private string _selectedAgentProviderId = "";
    private string _selectedPipelineProviderId = "";
    private string _selectedBrainProviderId = "";
    private string? _errorMessage;
    private bool _loadingIssues;
    private bool _showCompletionOnly;
    private bool _disposed;
    private Timer? _elapsedTimer;
    private int _maxRetries = 3;
    private int _currentPage = 1;
    private int _issuePageSize = 25;
    private bool _hasMoreIssues;

    private bool CanStartPipeline =>
        !string.IsNullOrEmpty(_selectedIssueProviderId)
        && !string.IsNullOrEmpty(_selectedIssueId)
        && !string.IsNullOrEmpty(_selectedRepoProviderId)
        && !string.IsNullOrEmpty(_selectedAgentProviderId);

    private IReadOnlyList<IssueSummary> FilteredIssues =>
        _filteredIssuesCache ??= _selectedLabels.Count == 0
            ? _issues
            : _issues.Where(i => i.Labels.Any(l => _selectedLabels.Contains(l))).ToList();

    private void ToggleLabel(string label)
    {
        if (!_selectedLabels.Remove(label))
            _selectedLabels.Add(label);
        _filteredIssuesCache = null;
        ClearSelectionIfFiltered();
    }

    private void ClearLabelFilter()
    {
        _selectedLabels.Clear();
        _filteredIssuesCache = null;
    }

    private void ClearSelectionIfFiltered()
    {
        if (!string.IsNullOrEmpty(_selectedIssueId)
            && !FilteredIssues.Any(i => i.Identifier == _selectedIssueId))
        {
            _selectedIssueId = "";
            _selectedIssueDetail = null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        PipelineService.OnChange += HandleStateChanged;
        PipelineService.OnOutputLine += HandleOutputLine;

        _elapsedTimer = new Timer(ElapsedTimerTick, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));

        try
        {
            _issueProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Issue, CancellationToken.None)).ToList();
            _repoProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Repository, CancellationToken.None)).ToList();
            _agentProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Agent, CancellationToken.None)).ToList();
            _pipelineProviders = (await ConfigStore.LoadProviderConfigsAsync(ProviderKind.Pipeline, CancellationToken.None)).ToList();

            // Filter brain providers from repository providers
            _brainProviders = _repoProviders.Where(p => p.RepositoryRole == RepositoryRole.Brain).ToList();

            var config = await ConfigStore.LoadPipelineConfigAsync(CancellationToken.None);
            _maxRetries = config.MaxRetries;
            _issuePageSize = Math.Clamp(config.IssuePageSize, 1, 100);

            // Pre-populate from LastUsedProviderIds
            if (config.LastUsedProviderIds.TryGetValue("issue", out var lastIssue) && _issueProviders.Any(p => p.Id == lastIssue))
                _selectedIssueProviderId = lastIssue;
            if (config.LastUsedProviderIds.TryGetValue("repository", out var lastRepo) && _repoProviders.Any(p => p.Id == lastRepo))
                _selectedRepoProviderId = lastRepo;
            if (config.LastUsedProviderIds.TryGetValue("agent", out var lastAgent) && _agentProviders.Any(p => p.Id == lastAgent))
                _selectedAgentProviderId = lastAgent;
            if (config.LastUsedProviderIds.TryGetValue("brain", out var lastBrain) && _brainProviders.Any(p => p.Id == lastBrain))
                _selectedBrainProviderId = lastBrain;
            if (config.LastUsedProviderIds.TryGetValue("pipeline", out var lastPipeline) && _pipelineProviders.Any(p => p.Id == lastPipeline))
                _selectedPipelineProviderId = lastPipeline;

            // Auto-select if only one provider of each type (fallback when no last-used)
            if (string.IsNullOrEmpty(_selectedRepoProviderId) && _repoProviders.Count == 1) _selectedRepoProviderId = _repoProviders[0].Id;
            if (string.IsNullOrEmpty(_selectedAgentProviderId) && _agentProviders.Count == 1) _selectedAgentProviderId = _agentProviders[0].Id;
            if (string.IsNullOrEmpty(_selectedPipelineProviderId) && _pipelineProviders.Count == 1) _selectedPipelineProviderId = _pipelineProviders[0].Id;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load providers: {ex.Message}";
        }
    }

    private async void ElapsedTimerTick(object? state)
    {
        if (_disposed) return;
        var run = PipelineService.ActiveRun;
        if (run is null) return;
        if (run.CurrentStep is PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled)
            return;

        try
        {
            await InvokeAsync(() => { if (!_disposed) StateHasChanged(); });
        }
        catch (ObjectDisposedException) { }
    }

    private async void HandleStateChanged()
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed) return;

                var run = PipelineService.ActiveRun;
                if (run is { CurrentStep: PipelineStep.Completed or PipelineStep.Failed or PipelineStep.Cancelled })
                    _showCompletionOnly = true;

                StateHasChanged();
                try
                {
                    await JS.InvokeVoidAsync("scrollToBottom", "outputPanel");
                    await JS.InvokeVoidAsync("scrollActiveStepIntoView", "sidebarSteps");
                }
                catch { }
            });
        }
        catch (ObjectDisposedException) { }
    }

    private async void HandleOutputLine(string line)
    {
        if (_disposed) return;
        _outputLines.Add(line);
        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed) return;
                StateHasChanged();
                try
                {
                    await JS.InvokeVoidAsync("scrollToBottom", "outputPanel");
                }
                catch { }
            });
        }
        catch (ObjectDisposedException) { }
    }

    private async Task OnIssueProviderChanged()
    {
        _issues.Clear();
        _selectedIssueId = "";
        _selectedLabels.Clear();
        _availableLabels.Clear();
        _filteredIssuesCache = null;
        _errorMessage = null;
        _currentPage = 1;
        _hasMoreIssues = false;

        if (string.IsNullOrEmpty(_selectedIssueProviderId))
            return;

        await LoadIssuePage();
    }

    private async Task LoadIssuePage()
    {
        _loadingIssues = true;
        _filteredIssuesCache = null;
        _selectedIssueId = "";
        _selectedIssueDetail = null;
        _selectedLabels.Clear();
        try
        {
            var providerConfig = _issueProviders.FirstOrDefault(p => p.Id == _selectedIssueProviderId);
            if (providerConfig == null) return;

            var issueProvider = ProviderFactory.CreateIssueProvider(providerConfig);
            var result = await issueProvider.ListOpenIssuesAsync(_currentPage, _issuePageSize, CancellationToken.None);
            _issues = result.Items.ToList();
            _hasMoreIssues = result.HasMore;
            // TODO: [UX-12a] _availableLabels is derived from the current page only, not the full repo label set.
            // Auto-filter may not activate if agent:next issues are on a different page.
            _availableLabels = _issues.SelectMany(i => i.Labels).Distinct().OrderBy(l => l).ToList();
            // TODO: [UX-12a] Pagination re-applies auto-filter, discarding user's manual filter choices.
            // Move auto-select to OnIssueProviderChanged or use a flag to only auto-filter on initial load.
            if (_availableLabels.Contains(AgentLabels.Next))
            {
                _selectedLabels.Add(AgentLabels.Next);
                _filteredIssuesCache = null;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to fetch issues: {ex.Message}";
        }
        finally
        {
            _loadingIssues = false;
        }
    }

    private async Task PreviousPage()
    {
        if (_currentPage <= 1) return;
        _currentPage--;
        await LoadIssuePage();
    }

    private async Task NextPage()
    {
        if (!_hasMoreIssues) return;
        _currentPage++;
        await LoadIssuePage();
    }

    private async Task SelectIssue(string issueId)
    {
        _selectedIssueId = issueId;
        _selectedIssueDetail = null;
        _loadingIssueDetail = true;
        StateHasChanged();

        try
        {
            var providerConfig = _issueProviders.FirstOrDefault(p => p.Id == _selectedIssueProviderId);
            if (providerConfig != null)
            {
                var issueProvider = ProviderFactory.CreateIssueProvider(providerConfig);
                _selectedIssueDetail = await issueProvider.GetIssueAsync(issueId, CancellationToken.None);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load issue details: {ex.Message}";
        }
        finally
        {
            _loadingIssueDetail = false;
        }
    }

    private async Task StartPipeline()
    {
        _errorMessage = null;

        if (PipelineService.IsRunning)
        {
            _errorMessage = "A pipeline run is already in progress.";
            return;
        }

        if (!CanStartPipeline)
        {
            _errorMessage = "Please select an issue, repository provider, and agent provider.";
            return;
        }

        _outputLines.Clear();
        _showCompletionOnly = false;

        try
        {
            _ = Task.Run(async () =>
            {
                try
                {
                    await PipelineService.StartPipelineAsync(
                        _selectedIssueProviderId, _selectedRepoProviderId,
                        _selectedIssueId, _selectedAgentProviderId, CancellationToken.None,
                        brainProviderId: string.IsNullOrEmpty(_selectedBrainProviderId) ? null : _selectedBrainProviderId,
                        pipelineProviderId: string.IsNullOrEmpty(_selectedPipelineProviderId) ? null : _selectedPipelineProviderId);
                }
                catch (Exception ex)
                {
                    await InvokeAsync(() =>
                    {
                        _errorMessage = $"Pipeline failed: {ex.Message}";
                        StateHasChanged();
                    });
                }
            });
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to start pipeline: {ex.Message}";
        }
    }

    private async Task CancelPipeline()
    {
        try
        {
            await PipelineService.CancelPipelineAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Cancel error: {ex.Message}";
        }
    }

    private void BackToIssues()
    {
        _showCompletionOnly = false;
        _errorMessage = null;
    }

    public void Dispose()
    {
        _disposed = true;
        _elapsedTimer?.Dispose();
        PipelineService.OnChange -= HandleStateChanged;
        PipelineService.OnOutputLine -= HandleOutputLine;
    }

    private static string Truncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength] + "…";
}
