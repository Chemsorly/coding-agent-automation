@inherits LayoutComponentBase
@implements IDisposable
@using KiroWebUI.Pipeline.Services
@inject PipelineLoopService LoopService

<div class="app-layout">
    <nav class="sidebar" role="navigation" aria-label="Main navigation">
        <div class="sidebar-brand">Kiro</div>
        <NavLink href="/" class="sidebar-link" Match="NavLinkMatch.All">
            <span class="sidebar-icon">💬</span>
            <span>Chat</span>
        </NavLink>
        <NavLink href="/agent-refinement" class="sidebar-link">
            <span class="sidebar-icon">🔬</span>
            <span>Agent Refinement</span>
        </NavLink>
        <NavLink href="/agent-coding" class="sidebar-link">
            <span class="sidebar-icon">🤖</span>
            <span>Agent Coding</span>
            @if (LoopService.IsLoopActive)
            {
                <span class="sidebar-loop-indicator" title="Pipeline loop is active">🔄</span>
            }
        </NavLink>
        <NavLink href="/settings" class="sidebar-link">
            <span class="sidebar-icon">⚙️</span>
            <span>Settings</span>
        </NavLink>
        <NavLink href="/about" class="sidebar-link">
            <span class="sidebar-icon">ℹ️</span>
            <span>About</span>
        </NavLink>
    </nav>
    <main class="main-content">
        @Body
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        LoopService.OnChange += HandleLoopChanged;
    }

    private async void HandleLoopChanged()
    {
        try { await InvokeAsync(StateHasChanged); }
        catch (ObjectDisposedException) { }
    }

    public void Dispose()
    {
        LoopService.OnChange -= HandleLoopChanged;
    }
}
