# =============================================================================
# Environment variables for docker-compose
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Shared secret for orchestrator↔agent authentication (required)
# Generate with: openssl rand -hex 32
AGENT_API_KEY=

# Logging level (Trace, Debug, Information, Warning, Error, Critical)
LOG_LEVEL=Information

# =============================================================================
# OTEL Observability (optional — leave ENDPOINT empty to disable telemetry export)
# =============================================================================
# Grafana Cloud example:
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
#   OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(instanceId:token)>
#
# Self-hosted collector example:
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
#   OTEL_EXPORTER_OTLP_PROTOCOL=grpc
#   OTEL_EXPORTER_OTLP_HEADERS=

OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_HEADERS=

# Deployment environment tag for OTEL resource attributes
DEPLOYMENT_ENVIRONMENT=production
